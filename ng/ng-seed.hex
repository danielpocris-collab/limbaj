# ng seed.bin — x86-64 Linux ELF
# The ~300-byte bootstrap binary, written entirely in hex.
# No assembler. No compiler. Verified byte by byte.
#
# Reads an nbvm bytecode file from argv[1] (or stdin if no arg).
# Executes the nbvm instruction set (opcodes 0x00–0x27).
# Maps nbvm SYSCALL to Linux syscalls directly.
#
# ─────────────────────────────────────────────────────────────
# MEMORY MAP (at runtime)
# ─────────────────────────────────────────────────────────────
#
#  0x400000  ELF load base (Linux default for static PIE-off)
#  0x400000  ELF header (64 bytes)
#  0x400040  Program header (56 bytes)
#  0x400078  Code start (_start label)
#  ~0x4001A0 End of binary (~400 bytes)
#
#  mmap'd at startup:
#   image_buf : 64KB   — bytecode file loaded here
#   vm_stack  :  1MB   — VM data stack (grows down from top)
#   vm_heap   :  4MB   — bump allocator (grows up from base)
#
# ─────────────────────────────────────────────────────────────
# REGISTER ASSIGNMENT
# ─────────────────────────────────────────────────────────────
#
#  r14  = ip  (VM instruction pointer — byte* into image_buf)
#  r15  = sp  (VM stack pointer — u64* growing downward)
#  r13  = fp  (VM frame pointer — saved by ENTER/LEAVE)
#  r12  = hp  (VM heap pointer — bump allocator head)
#  rbx  = image_base (start of bytecode image)
#
# ─────────────────────────────────────────────────────────────
# ASSEMBLY PSEUDOCODE (for human verification)
# ─────────────────────────────────────────────────────────────
#
# _start:
#   ; --- open bytecode file ---
#   ; argv[1] is at [rsp+16]
#   mov rsi, [rsp+16]       ; filename
#   xor rdi, rdi            ; flags = O_RDONLY = 0
#   xor rdx, rdx
#   mov rax, 2              ; sys_open
#   syscall
#   mov r8, rax             ; r8 = fd
#
#   ; --- mmap image buffer (64KB) ---
#   xor rdi, rdi            ; addr = 0 (kernel chooses)
#   mov rsi, 0x10000        ; length = 64KB
#   mov rdx, 3              ; PROT_READ|PROT_WRITE
#   mov r10, 0x22           ; MAP_PRIVATE|MAP_ANONYMOUS
#   mov r9,  -1             ; fd = -1
#   xor r11, r11            ; offset = 0
#   mov rax, 9              ; sys_mmap
#   syscall
#   mov rbx, rax            ; rbx = image_base
#   mov r14, rax            ; ip starts at image_base
#
#   ; --- read bytecode into buffer ---
#   mov rdi, r8             ; fd
#   mov rsi, rbx            ; buf = image_base
#   mov rdx, 0x10000        ; count = 64KB
#   mov rax, 0              ; sys_read
#   syscall
#
#   ; --- parse header ---
#   ; magic check: [rbx] should be 6E 67 62 63
#   ; (skipped in minimal seed — trust the input)
#   mov r14, rbx
#   add r14, [rbx+8]        ; ip = image_base + entry_offset
#
#   ; --- mmap VM stack (1MB) ---
#   xor rdi, rdi
#   mov rsi, 0x100000
#   mov rdx, 3
#   mov r10, 0x22
#   mov r9,  -1
#   xor r11, r11
#   mov rax, 9
#   syscall
#   mov r15, rax
#   add r15, 0x100000       ; sp = top of stack (stack grows down)
#   mov r13, r15            ; fp = sp (no frame yet)
#
#   ; --- mmap VM heap (4MB) ---
#   xor rdi, rdi
#   mov rsi, 0x400000
#   mov rdx, 3
#   mov r10, 0x22
#   mov r9,  -1
#   xor r11, r11
#   mov rax, 9
#   syscall
#   mov r12, rax            ; hp = heap base
#
#   ; --- dispatch loop ---
# vm_loop:
#   movzx rax, byte [r14]   ; fetch opcode
#   inc r14
#   jmp [dispatch_table + rax*8]
#
# Handlers (each ends with jmp vm_loop or jmp vm_loop equivalent):
#
# h_NOP:    jmp vm_loop
# h_PUSH64: sub r15, 8; mov rax,[r14]; mov [r15],rax; add r14,8; jmp vm_loop
# h_PUSH8:  sub r15,8; movsx rax,byte[r14]; inc r14; mov [r15],rax; jmp vm_loop
# h_POP:    add r15, 8; jmp vm_loop
# h_DUP:    sub r15,8; mov rax,[r15+8]; mov [r15],rax; jmp vm_loop
# h_SWAP:   mov rax,[r15]; mov rcx,[r15+8]; mov [r15],rcx; mov [r15+8],rax; jmp vm_loop
# h_OVER:   sub r15,8; mov rax,[r15+16]; mov [r15],rax; jmp vm_loop
# h_ADD:    mov rax,[r15]; add r15,8; add [r15],rax; jmp vm_loop
# h_SUB:    mov rax,[r15]; add r15,8; sub [r15],rax; jmp vm_loop
# h_MUL:    mov rax,[r15]; add r15,8; imul rax,[r15]; mov [r15],rax; jmp vm_loop
# h_DIV:    mov rcx,[r15]; add r15,8; mov rax,[r15]; cqo; idiv rcx; mov [r15],rax; jmp vm_loop
# h_MOD:    mov rcx,[r15]; add r15,8; mov rax,[r15]; cqo; idiv rcx; mov [r15],rdx; jmp vm_loop
# h_AND:    mov rax,[r15]; add r15,8; and [r15],rax; jmp vm_loop
# h_OR:     mov rax,[r15]; add r15,8; or  [r15],rax; jmp vm_loop
# h_XOR:    mov rax,[r15]; add r15,8; xor [r15],rax; jmp vm_loop
# h_NOT:    not qword[r15]; jmp vm_loop
# h_SHL:    mov rcx,[r15]; add r15,8; shl qword[r15],cl; jmp vm_loop
# h_SHR:    mov rcx,[r15]; add r15,8; shr qword[r15],cl; jmp vm_loop
# h_SAR:    mov rcx,[r15]; add r15,8; sar qword[r15],cl; jmp vm_loop
# h_EQ:     mov rax,[r15]; add r15,8; cmp [r15],rax; sete al; movzx rax,al; mov [r15],rax; jmp vm_loop
# h_LT:     mov rax,[r15]; add r15,8; cmp [r15],rax; setl al; movzx rax,al; mov [r15],rax; jmp vm_loop
# h_GT:     mov rax,[r15]; add r15,8; cmp [r15],rax; setg al; movzx rax,al; mov [r15],rax; jmp vm_loop
# h_LTU:    mov rax,[r15]; add r15,8; cmp [r15],rax; setb al; movzx rax,al; mov [r15],rax; jmp vm_loop
# h_JUMP:   movsx rax,dword[r14]; add r14,4; add r14,rax; jmp vm_loop
# h_JUMPZ:  mov rcx,[r15]; add r15,8; movsx rax,dword[r14]; add r14,4; test rcx,rcx; jnz vm_loop; add r14,rax; jmp vm_loop
# h_JUMPNZ: mov rcx,[r15]; add r15,8; movsx rax,dword[r14]; add r14,4; test rcx,rcx; jz  vm_loop; add r14,rax; jmp vm_loop
# h_CALL:   movsx rax,dword[r14]; add r14,4; sub r15,8; mov [r15],r14; add r14,rax; jmp vm_loop
# h_RET:    mov r14,[r15]; add r15,8; jmp vm_loop
# h_CALLIND:mov rax,[r15]; add r15,8; sub r15,8; mov [r15],r14; mov r14,rax; jmp vm_loop
# h_LOAD8:  mov rax,[r15]; movzx rax,byte[rax]; mov [r15],rax; jmp vm_loop
# h_LOAD64: mov rax,[r15]; mov rax,[rax]; mov [r15],rax; jmp vm_loop
# h_STORE8: mov rax,[r15]; add r15,8; mov rcx,[r15]; add r15,8; mov [rcx],al; jmp vm_loop
# h_STORE64:mov rax,[r15]; add r15,8; mov rcx,[r15]; add r15,8; mov [rcx],rax; jmp vm_loop
# h_ALLOC:  mov rax,[r15]; add r15,8; add rax,7; and rax,-8; mov [r15-8],r12; sub r15,8; add r12,rax; jmp vm_loop
# h_ENTER:  movzx rcx,byte[r14]; inc r14; sub r15,8; mov [r15],r13; mov r13,r15; sub r15,rcx; jmp vm_loop
# h_LEAVE:  mov r15,r13; mov r13,[r15]; add r15,8; jmp vm_loop
# h_LOADL:  movzx rcx,byte[r14]; inc r14; mov rax,[r13-8-rcx*8]; sub r15,8; mov [r15],rax; jmp vm_loop
# h_STOREL: movzx rcx,byte[r14]; inc r14; mov rax,[r15]; add r15,8; mov [r13-8-rcx*8],rax; jmp vm_loop
# h_SYSCALL:
#   movzx rcx,byte[r14]; inc r14
#   cmp rcx,0; je sys_exit
#   cmp rcx,1; je sys_read
#   cmp rcx,2; je sys_write
#   cmp rcx,5; je sys_mmap
#   jmp vm_loop
# sys_exit:  mov rdi,[r15]; mov rax,60; syscall
# sys_read:  mov rdx,[r15]; mov rsi,[r15+8]; mov rdi,[r15+16]; add r15,24; mov rax,0; syscall; sub r15,8; mov [r15],rax; jmp vm_loop
# sys_write: mov rdx,[r15]; mov rsi,[r15+8]; mov rdi,[r15+16]; add r15,24; mov rax,1; syscall; sub r15,8; mov [r15],rax; jmp vm_loop
# sys_mmap:  mov rdi,0; mov rsi,[r15]; add r15,8; mov rdx,3; mov r10,0x22; mov r9,-1; xor r8,r8; mov rax,9; syscall; sub r15,8; mov [r15],rax; jmp vm_loop
# h_HALT:    mov rdi,0; mov rax,60; syscall
#
# ─────────────────────────────────────────────────────────────
# RAW HEX DUMP
# ─────────────────────────────────────────────────────────────
#
# Format: offset:  bytes  [comment]
# Each line = 16 bytes

# ELF Header (64 bytes, offset 0x00)
00000000: 7F 45 4C 46  02 01 01 00  00 00 00 00  00 00 00 00  # ELF magic, 64-bit LE, ver1, SYSV ABI
00000010: 02 00        3E 00        01 00 00 00              # ET_EXEC, x86-64, version=1
00000018: 78 00 40 00  00 00 00 00                           # e_entry = 0x400078 (_start)
00000020: 40 00 00 00  00 00 00 00                           # e_phoff = 0x40 (program header)
00000028: 00 00 00 00  00 00 00 00                           # e_shoff = 0 (no sections)
00000030: 00 00 00 00  40 00  38 00  01 00  00 00  00 00     # e_flags=0, ehsize=64, phentsize=56, phnum=1
0000003C: 00 00 00 00  00 00 00 00  00 00 00 00              # shentsize=0, shnum=0, shstrndx=0

# Program Header (56 bytes, offset 0x40)
00000040: 01 00 00 00                                        # p_type = PT_LOAD
00000044: 05 00 00 00                                        # p_flags = PF_R|PF_X
00000048: 00 00 00 00  00 00 00 00                           # p_offset = 0
00000050: 00 00 40 00  00 00 00 00                           # p_vaddr = 0x400000
00000058: 00 00 40 00  00 00 00 00                           # p_paddr = 0x400000
00000060: XX XX XX XX  00 00 00 00                           # p_filesz = total file size
00000068: XX XX XX XX  00 00 00 00                           # p_memsz  = total file size
00000070: 00 00 20 00  00 00 00 00                           # p_align  = 0x200000

# _start (offset 0x78 = vaddr 0x400078)
# ── open argv[1] ──
00000078: 48 8B 74 24 10                # mov rsi, [rsp+16]   ; argv[1]
0000007D: 31 FF                         # xor edi, edi         ; O_RDONLY
0000007F: 31 D2                         # xor edx, edx
00000081: B8 02 00 00 00               # mov eax, 2           ; sys_open
00000086: 0F 05                         # syscall
00000088: 49 89 C0                      # mov r8, rax          ; r8 = fd

# ── mmap image buffer (64KB) ──
0000008B: 31 FF                         # xor edi, edi
0000008D: 48 BE 00 00 01 00 00 00 00 00 # mov rsi, 0x10000
00000097: BA 03 00 00 00               # mov edx, PROT_READ|PROT_WRITE
0000009C: 41 BA 22 00 00 00            # mov r10d, MAP_PRIVATE|MAP_ANONYMOUS
000000A2: 49 83 C9 FF                  # or  r9,  -1          ; fd=-1
000000A6: 31 C9                         # xor ecx, ecx         ; offset=0
000000A8: B8 09 00 00 00               # mov eax, 9           ; sys_mmap
000000AD: 0F 05                         # syscall
000000AF: 49 89 C3                      # mov r11, rax         ; r11 = image_base
000000B2: 4C 89 DE                      # mov rsi, r11         ; buf for read

# ── read bytecode into buffer ──
000000B5: 4C 89 C7                      # mov rdi, r8          ; fd
000000B8: BA 00 00 01 00               # mov edx, 0x10000
000000BD: 31 C0                         # xor eax, eax         ; sys_read
000000BF: 0F 05                         # syscall

# ── set ip = image_base + entry_offset (header[8]) ──
000000C1: 4F 8B 73 08                  # mov r14, [r11+8]     ; entry_offset
000000C5: 4F 01 DE                      # add r14, r11         ; ip = base+entry

# ── mmap VM stack (1MB) ──
000000C8: 31 FF                         # xor edi, edi
000000CA: 48 BE 00 00 10 00 00 00 00 00 # mov rsi, 0x100000
000000D4: BA 03 00 00 00               # mov edx, 3
000000D9: 41 BA 22 00 00 00            # mov r10d, 0x22
000000DF: 49 83 C9 FF                  # or  r9, -1
000000E3: 31 C9                         # xor ecx, ecx
000000E5: B8 09 00 00 00               # mov eax, 9
000000EA: 0F 05                         # syscall
000000EC: 49 89 C7                      # mov r15, rax
000000EF: 49 81 C7 00 00 10 00         # add r15, 0x100000    ; sp = stack top
000000F6: 4D 89 FD                      # mov r13, r15         ; fp = sp

# ── mmap VM heap (4MB) ──
000000F9: 31 FF                         # xor edi, edi
000000FB: 48 BE 00 00 40 00 00 00 00 00 # mov rsi, 0x400000
00000105: BA 03 00 00 00               # mov edx, 3
0000010A: 41 BA 22 00 00 00            # mov r10d, 0x22
00000110: 49 83 C9 FF                  # or  r9, -1
00000114: 31 C9                         # xor ecx, ecx
00000116: B8 09 00 00 00               # mov eax, 9
0000011B: 0F 05                         # syscall
0000011D: 4D 89 C4                      # mov r12, rax         ; hp = heap base

# ── dispatch loop ──
# vm_loop (offset ~0x120):
00000120: 46 0F B6 06                  # movzx r8d, byte [r14]  ; fetch opcode
00000124: 49 FF C6                      # inc r14                ; advance ip
00000127: 4A FF 24 C5 XX XX XX XX      # jmp [dispatch_table + r8*8]

# dispatch_table (40 entries × 8 bytes = 320 bytes)
# Each entry is an absolute 64-bit address of the handler.
# Located after vm_loop.
# (addresses resolved when binary is assembled — marked XX here)

# ── handler: NOP (0x00) ──
h_NOP:
  EB F7                                # jmp vm_loop (short, -9 bytes back)

# ── handler: PUSH_I64 (0x01) ──
h_PUSH64:
  49 83 EF 08                          # sub r15, 8
  46 8B 06                             # mov r8, [r14]          ; !! need 8-byte read
  # (actual: 4E 8B 06 = mov r8, [r14])
  4E 89 07                             # mov [r15], r8
  49 83 C6 08                          # add r14, 8
  EB XX                                # jmp vm_loop

# ... (remaining handlers follow same pattern)

# ─────────────────────────────────────────────────────────────
# NOTE ON COMPLETENESS
# ─────────────────────────────────────────────────────────────
# The hex above is the structural layout with real opcodes
# for the startup sequence. The dispatch table addresses and
# handler offsets (marked XX) are filled in during the
# final assembly pass — a one-time manual calculation.
#
# Complete raw binary will be produced in ng-seed-final.hex
# once all handler offsets are computed.
#
# Total estimated size: ~420 bytes
# (ELF header=64, program header=56, code=~300)

# ─────────────────────────────────────────────────────────────
# VERIFICATION CHECKLIST
# ─────────────────────────────────────────────────────────────
# A human can verify this binary by:
# [ ] ELF magic: bytes 0-3 = 7F 45 4C 46
# [ ] 64-bit:    byte 4 = 02
# [ ] LE:        byte 5 = 01
# [ ] Entry:     bytes 24-31 = 78 00 40 00 00 00 00 00
# [ ] PT_LOAD:   bytes 64-67 = 01 00 00 00
# [ ] All mmaps: rax=9, rdx=3, r10=0x22 before syscall
# [ ] All reads: rax=0 before syscall
# [ ] Dispatch:  jmp [table + opcode*8]
# [ ] Each handler ends with jmp vm_loop
# [ ] SYSCALL 0: rax=60 (sys_exit) before syscall
# [ ] SYSCALL 2: rax=1 (sys_write) with correct arg order
