form BigStruct {
    f1 :: str,
    f2 :: i64,
    f3 :: str,
    f4 :: str,
    f5 :: str,
    f6 :: str,
    f7 :: i64,
    f8 :: str,
    f9 :: i64,
    f10 :: i64,
    f11 :: str,
    f12 :: i64,
    f13 :: i64,
    f14 :: str,
    f15 :: str,
    f16 :: i64,
    f17 :: str,
    f18 :: str,
    f19 :: i64,
    f20 :: str
}

flow make_big(s :: str) -> BigStruct {
    vary bs :: BigStruct = BigStruct{
        f1 = s, f2 = 0, f3 = "", f4 = "", f5 = "",
        f6 = "", f7 = 0, f8 = "", f9 = 0, f10 = 0,
        f11 = "", f12 = 0, f13 = 0, f14 = "", f15 = "",
        f16 = 0, f17 = "", f18 = "", f19 = 0, f20 = ""
    }
    yield bs
}

flow main(s :: str) -> i64 {
    println("start")
    bind bs :: BigStruct = make_big(s)
    println("made")
    println(bs.f1)
    println(str_from_i64(bs.f2))
    bind f17val :: str = bs.f17
    println(f17val)
    bind f19val :: i64 = bs.f19
    println(str_from_i64(f19val))
    bind f20val :: str = bs.f20
    println(f20val)
    yield 99
}
