// --- ng native compiler ------------------------------------------
// Compiles ng source directly to Windows PE x86-64 executable.
// No C. No gcc. Just ng to .exe.
//
// Usage: limbaj selfhost ng_native.ng <input.ng>
//        (produces output.exe)
//
// Strategy: stack-based code generation.
// - Expressions push results onto the machine stack.
// - Variables are at fixed offsets in the stack frame.
// - Function calls use Microsoft x64 ABI.

// ==================================================================
// SECTION 0: REUSE LEXER FROM ng_compiler
// ==================================================================

flow tk_eof() -> i64       { yield 0 }
flow tk_ident() -> i64     { yield 1 }
flow tk_integer() -> i64   { yield 2 }
flow tk_string() -> i64    { yield 3 }
flow tk_lparen() -> i64    { yield 4 }
flow tk_rparen() -> i64    { yield 5 }
flow tk_lbrace() -> i64    { yield 6 }
flow tk_rbrace() -> i64    { yield 7 }
flow tk_lbracket() -> i64  { yield 8 }
flow tk_rbracket() -> i64  { yield 9 }
flow tk_comma() -> i64     { yield 10 }
flow tk_dot() -> i64       { yield 11 }
flow tk_colon() -> i64     { yield 12 }
flow tk_dcolon() -> i64    { yield 13 }
flow tk_plus() -> i64      { yield 14 }
flow tk_minus() -> i64     { yield 15 }
flow tk_star() -> i64      { yield 16 }
flow tk_slash() -> i64     { yield 17 }
flow tk_percent() -> i64   { yield 18 }
flow tk_eq() -> i64        { yield 19 }
flow tk_eqeq() -> i64      { yield 20 }
flow tk_neq() -> i64       { yield 21 }
flow tk_lt() -> i64        { yield 22 }
flow tk_le() -> i64        { yield 23 }
flow tk_gt() -> i64        { yield 24 }
flow tk_ge() -> i64        { yield 25 }
flow tk_arrow() -> i64     { yield 26 }
flow tk_larrow() -> i64    { yield 27 }
flow tk_bang() -> i64      { yield 28 }

form Token {
    kind :: i64,
    start :: i64,
    end :: i64
}

flow make_token(k :: i64, s :: i64, e :: i64) -> Token {
    yield Token{ kind = k, start = s, end = e }
}

flow is_space(ch :: i64) -> bool { yield ch == 32 or ch == 9 or ch == 10 or ch == 13 }
flow is_digit(ch :: i64) -> bool { yield ch >= 48 and ch <= 57 }
flow is_alpha(ch :: i64) -> bool { yield (ch >= 65 and ch <= 90) or (ch >= 97 and ch <= 122) or ch == 95 }
flow is_alnum(ch :: i64) -> bool { yield is_alpha(ch) or is_digit(ch) }

flow skip_ws(src :: str, pos :: i64) -> i64 {
    vary i :: i64 = pos
    bind len :: i64 = str_len(src)
    spin i < len {
        bind ch :: i64 = str_byte_at(src, i)
        check not is_space(ch) {
            check ch == 47 and i + 1 < len and str_byte_at(src, i + 1) == 47 {
                i <- i + 2
                spin i < len and str_byte_at(src, i) != 10 { i <- i + 1 }
            } otherwise {
                yield i
            }
        }
        i <- i + 1
    }
    yield i
}

flow next_token(src :: str, pos :: i64) -> Token {
    bind i :: i64 = skip_ws(src, pos)
    bind len :: i64 = str_len(src)
    check i >= len { yield make_token(tk_eof(), i, i) }
    bind ch :: i64 = str_byte_at(src, i)
    check is_alpha(ch) {
        vary j :: i64 = i + 1
        spin j < len and is_alnum(str_byte_at(src, j)) { j <- j + 1 }
        yield make_token(tk_ident(), i, j)
    }
    check is_digit(ch) {
        vary j :: i64 = i + 1
        spin j < len and is_digit(str_byte_at(src, j)) { j <- j + 1 }
        yield make_token(tk_integer(), i, j)
    }
    check ch == 34 {
        vary j :: i64 = i + 1
        spin j < len and str_byte_at(src, j) != 34 {
            check str_byte_at(src, j) == 92 { j <- j + 1 }
            j <- j + 1
        }
        check j < len { j <- j + 1 }
        yield make_token(tk_string(), i, j)
    }
    check i + 1 < len {
        bind ch2 :: i64 = str_byte_at(src, i + 1)
        check ch == 58 and ch2 == 58 { yield make_token(tk_dcolon(), i, i + 2) }
        check ch == 61 and ch2 == 61 { yield make_token(tk_eqeq(), i, i + 2) }
        check ch == 33 and ch2 == 61 { yield make_token(tk_neq(), i, i + 2) }
        check ch == 60 and ch2 == 61 { yield make_token(tk_le(), i, i + 2) }
        check ch == 62 and ch2 == 61 { yield make_token(tk_ge(), i, i + 2) }
        check ch == 45 and ch2 == 62 { yield make_token(tk_arrow(), i, i + 2) }
        check ch == 60 and ch2 == 45 { yield make_token(tk_larrow(), i, i + 2) }
    }
    check ch == 40 { yield make_token(tk_lparen(), i, i + 1) }
    check ch == 41 { yield make_token(tk_rparen(), i, i + 1) }
    check ch == 123 { yield make_token(tk_lbrace(), i, i + 1) }
    check ch == 125 { yield make_token(tk_rbrace(), i, i + 1) }
    check ch == 91 { yield make_token(tk_lbracket(), i, i + 1) }
    check ch == 93 { yield make_token(tk_rbracket(), i, i + 1) }
    check ch == 44 { yield make_token(tk_comma(), i, i + 1) }
    check ch == 46 { yield make_token(tk_dot(), i, i + 1) }
    check ch == 58 { yield make_token(tk_colon(), i, i + 1) }
    check ch == 43 { yield make_token(tk_plus(), i, i + 1) }
    check ch == 45 { yield make_token(tk_minus(), i, i + 1) }
    check ch == 42 { yield make_token(tk_star(), i, i + 1) }
    check ch == 47 { yield make_token(tk_slash(), i, i + 1) }
    check ch == 37 { yield make_token(tk_percent(), i, i + 1) }
    check ch == 61 { yield make_token(tk_eq(), i, i + 1) }
    check ch == 60 { yield make_token(tk_lt(), i, i + 1) }
    check ch == 62 { yield make_token(tk_gt(), i, i + 1) }
    check ch == 33 { yield make_token(tk_bang(), i, i + 1) }
    yield make_token(tk_eof(), i + 1, i + 1)
}

flow sp(src :: str, s :: i64, e :: i64) -> str { yield str_slice(src, s, e) }
flow sp_eq(src :: str, tok :: Token, exp :: str) -> bool { yield str_eq(str_slice(src, tok.start, tok.end), exp) }

// ==================================================================
// SECTION 1: BYTE BUFFER HELPERS
// ==================================================================

// We use the buf_* builtins for byte arrays.
// Wrappers for convenience:

flow emit_u8(buf :: i64, v :: i64) -> i64 {
    yield buf_push(buf, v % 256)
}

flow emit_u16(buf :: i64, v :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, v % 256)
    b <- buf_push(b, (v / 256) % 256)
    yield b
}

flow emit_u32(buf :: i64, v :: i64) -> i64 {
    vary b :: i64 = buf
    // Handle negative values: convert to unsigned 32-bit via two's complement
    vary uv :: i64 = v
    check uv < 0 { uv <- uv + 4294967296 }
    b <- buf_push(b, uv % 256)
    b <- buf_push(b, (uv / 256) % 256)
    b <- buf_push(b, (uv / 65536) % 256)
    b <- buf_push(b, (uv / 16777216) % 256)
    yield b
}

flow emit_u64(buf :: i64, v :: i64) -> i64 {
    vary b :: i64 = buf
    b <- emit_u32(b, v)
    // Upper 32 bits: for small positive values this is 0
    // For simplicity, handle sign extension
    check v >= 0 {
        b <- emit_u32(b, v / 4294967296)
    } otherwise {
        b <- emit_u32(b, 4294967295)
    }
    yield b
}

flow emit_zeros(buf :: i64, n :: i64) -> i64 {
    vary b :: i64 = buf
    vary i :: i64 = 0
    spin i < n { b <- buf_push(b, 0) i <- i + 1 }
    yield b
}

flow emit_bytes(buf :: i64, src :: str) -> i64 {
    // Emit raw bytes from a string
    vary b :: i64 = buf
    vary i :: i64 = 0
    bind len :: i64 = str_len(src)
    spin i < len {
        b <- buf_push(b, str_byte_at(src, i))
        i <- i + 1
    }
    yield b
}

flow append_csv_i64_to_u32_store(store :: i64, csv :: str) -> i64 {
    vary out :: i64 = store
    vary pos :: i64 = 0
    bind len :: i64 = str_len(csv)
    spin pos < len {
        bind value_res :: LookupI64Cursor = csv_next_i64_opt(csv, pos)
        check value_res.found == 0 {
            yield out
        }
        out <- emit_u32(out, value_res.value)
        pos <- value_res.next_pos
    }
    yield out
}

// Pad buffer to alignment
flow pad_to(buf :: i64, align :: i64) -> i64 {
    vary b :: i64 = buf
    bind len :: i64 = buf_len(b)
    bind rem :: i64 = len % align
    check rem != 0 {
        vary i :: i64 = 0
        bind pad :: i64 = align - rem
        spin i < pad { b <- buf_push(b, 0) i <- i + 1 }
    }
    yield b
}

// Write u32 at specific offset (little-endian)
flow patch_u32(buf :: i64, offset :: i64, v :: i64) -> i64 {
    vary b :: i64 = buf
    vary uv :: i64 = v
    check uv < 0 { uv <- uv + 4294967296 }
    b <- buf_set(b, offset, uv % 256)
    b <- buf_set(b, offset + 1, (uv / 256) % 256)
    b <- buf_set(b, offset + 2, (uv / 65536) % 256)
    b <- buf_set(b, offset + 3, (uv / 16777216) % 256)
    yield b
}

// ==================================================================
// SECTION 2: FIRST PASS - COLLECT FUNCTIONS AND STRINGS
// ==================================================================

// Function info
form FuncInfo {
    name_start :: i64,
    name_end :: i64,
    param_count :: i64,
    body_start :: i64,
    code_offset :: i64
}

form LookupI64 {
    found :: i64,
    value :: i64
}

form LookupI64Cursor {
    found :: i64,
    value :: i64,
    next_pos :: i64
}

form LookupStr {
    found :: i64,
    value :: str
}

form LayoutScope {
    user_func_count :: i64
}

// We store up to 64 functions and 64 string literals
// Using parallel arrays since ng has no generic arrays

// Global state (passed as a struct)
form Compiler {
    src :: str,
    // Function table - parallel arrays
    fn_names :: str,       // comma-separated "name1,name2,..."
    fn_params :: i64,      // canonical u32 store of param counts
    fn_param_starts :: i64, // canonical u32 store of positions right after '('
    fn_bodies :: i64,      // canonical u32 store of body start positions
    fn_local_counts :: i64, // canonical u32 store of local counts for user function bodies
    builtin_offsets :: str, // legacy dead field; builtin_offset_store is canonical
    builtin_offset_store :: i64,
    fn_schedule_code_starts :: i64,
    fn_schedule_rdata_starts :: i64,
    fn_schedule_code_sizes :: i64,
    fn_schedule_rdata_sizes :: i64,
    executor_phase :: i64,
    executor_job_cursor :: i64,
    executor_apply_cursor :: i64,
    executor_effective_offsets :: i64,
    executor_total_round_count :: i64,
    executor_phase_round_count :: i64,
    executor_last_slice_budget :: i64,
    executor_phase_budget_scale :: i64,
    executor_phase_feedback_score :: i64,
    executor_last_round_completed_jobs :: i64,
    executor_scheduler_kind :: i64,
    executor_scheduler_plan_budget :: i64,
    executor_scheduler_apply_budget :: i64,
    fn_artifact_patch_offsets :: i64,
    fn_artifact_patch_targets :: i64,
    fn_artifact_patch_offset_store :: i64,
    fn_artifact_patch_target_store :: i64,
    fn_artifact_rdata_patch_offsets :: i64,
    fn_artifact_rdata_patch_targets :: i64,
    fn_artifact_rdata_patch_offset_store :: i64,
    fn_artifact_rdata_patch_target_store :: i64,
    fn_artifact_import_patch_offsets :: i64,
    fn_artifact_import_patch_targets :: i64,
    fn_artifact_import_patch_offset_store :: i64,
    fn_artifact_import_patch_target_store :: i64,
    // String table
    str_data :: str,       // accumulated string bytes with separators
    // Code buffer
    code :: i64,           // buf handle for .text section
    // Read-only data buffer
    rdata :: i64,          // buf handle for .rdata section
    // Variable tracking per function
    var_names :: str,      // comma-separated var names for current function
    // Current parse position (set by compile_* functions)
    pos :: i64,
    // Call patches: parallel CSVs of code offsets and target function indices
    patch_offsets :: str,
    patch_targets :: str,
    patch_offsets_store :: i64,
    patch_targets_store :: i64,
    rip_patch_offsets_store :: i64,
    rip_patch_targets_store :: i64,
    // RIP-relative string refs: local code patch offsets + local rdata offsets
    rdata_patch_offsets :: str,
    rdata_patch_targets :: str,
    // RIP-relative import refs: local code patch offsets + IAT slot indices
    import_patch_offsets :: str,
    import_patch_targets :: str,
    // Struct definitions: struct_names = CSV, struct_fields = ";"-separated field lists
    struct_names :: str,
    struct_fields :: str,
    // Variable types: CSV of type names ("i64", "str", "Token", "Compiler", etc.)
    var_types :: str,
    final_main_code_offset :: i64,
    final_effective_offsets :: i64,
    failed :: i64,
    failure_message :: str
}

form FunctionCompilePlan {
    fn_idx :: i64,
    param_count :: i64,
    param_start :: i64,
    body_start :: i64,
    body_local_count :: i64
}

form CompiledFunction {
    fn_idx :: i64,
    compile_ok :: i64,
    failure_message :: str,
    code_buf :: i64,
    rdata_buf :: i64,
    patch_offsets_local :: str,
    patch_targets_local :: str,
    patch_count_local :: i64,
    patch_offsets_local_store :: i64,
    patch_targets_local_store :: i64,
    rdata_patch_offsets_local :: str,
    rdata_patch_targets_local :: str,
    rdata_patch_count_local :: i64,
    rdata_patch_offsets_local_store :: i64,
    rdata_patch_targets_local_store :: i64,
    import_patch_offsets_local :: str,
    import_patch_targets_local :: str,
    import_patch_count_local :: i64,
    import_patch_offsets_local_store :: i64,
    import_patch_targets_local_store :: i64
}

form CompiledFunctionScheduleEntry {
    fn_idx :: i64,
    code_start :: i64,
    rdata_start :: i64,
    code_size :: i64,
    rdata_size :: i64
}

form CompiledFunctionJob {
    fn_idx :: i64,
    param_count :: i64,
    param_start :: i64,
    body_start :: i64,
    body_local_count :: i64
}

form CompiledFunctionJobResult {
    fn_idx :: i64,
    record_ok :: i64,
    message :: str,
    code_buf :: i64,
    rdata_buf :: i64,
    patch_offsets_local :: str,
    patch_targets_local :: str,
    patch_count_local :: i64,
    patch_offsets_local_store :: i64,
    patch_targets_local_store :: i64,
    rdata_patch_offsets_local :: str,
    rdata_patch_targets_local :: str,
    rdata_patch_count_local :: i64,
    rdata_patch_offsets_local_store :: i64,
    rdata_patch_targets_local_store :: i64,
    import_patch_offsets_local :: str,
    import_patch_targets_local :: str,
    import_patch_count_local :: i64,
    import_patch_offsets_local_store :: i64,
    import_patch_targets_local_store :: i64,
    code_start :: i64,
    rdata_start :: i64,
    code_size :: i64,
    rdata_size :: i64
}

form CompiledFunctionExecutorSchedulePolicy {
    plan_job_budget :: i64
    apply_job_budget :: i64
}

form CompiledFunctionExecutorScheduler {
    scheduler_kind :: i64
    plan_job_budget :: i64
    apply_job_budget :: i64
}

flow missing_i64() -> LookupI64 {
    yield LookupI64{ found = 0, value = 0 }
}

flow missing_i64_cursor() -> LookupI64Cursor {
    yield LookupI64Cursor{ found = 0, value = 0, next_pos = 0 }
}

flow missing_str() -> LookupStr {
    yield LookupStr{ found = 0, value = "" }
}

flow parse_int_result(src :: str, start :: i64, end :: i64) -> LookupI64 {
    check start >= end {
        yield missing_i64()
    }
    vary result :: i64 = 0
    vary i :: i64 = start
    spin i < end {
        bind ch :: i64 = str_byte_at(src, i)
        check ch < 48 or ch > 57 {
            yield missing_i64()
        }
        result <- result * 10 + (ch - 48)
        i <- i + 1
    }
    yield LookupI64{ found = 1, value = result }
}

flow csv_get_opt(csv :: str, n :: i64) -> LookupStr {
    vary idx :: i64 = 0
    vary start :: i64 = 0
    vary i :: i64 = 0
    bind len :: i64 = str_len(csv)
    spin i <= len {
        check i == len or str_byte_at(csv, i) == 44 {
            check idx == n {
                yield LookupStr{ found = 1, value = str_slice(csv, start, i) }
            }
            idx <- idx + 1
            start <- i + 1
        }
        i <- i + 1
    }
    yield missing_str()
}

flow csv_append(csv :: str, val :: str) -> str {
    check str_eq(csv, "") { yield val }
    yield str_concat(str_concat(csv, ","), val)
}

flow csv_count(csv :: str) -> i64 {
    check str_eq(csv, "") { yield 0 }
    vary count :: i64 = 1
    vary i :: i64 = 0
    bind len :: i64 = str_len(csv)
    spin i < len {
        check str_byte_at(csv, i) == 44 { count <- count + 1 }
        i <- i + 1
    }
    yield count
}

flow csv_next_i64_opt(csv :: str, start_pos :: i64) -> LookupI64Cursor {
    bind len :: i64 = str_len(csv)
    check start_pos < 0 or start_pos >= len {
        yield missing_i64_cursor()
    }
    vary end :: i64 = start_pos
    spin end <= len {
        check end == len or str_byte_at(csv, end) == 44 {
            bind value_res :: LookupI64 = parse_int_result(csv, start_pos, end)
            check value_res.found == 0 {
                yield missing_i64_cursor()
            }
            bind next_pos :: i64 = end + 1
            check next_pos > len {
                next_pos <- len
            }
            yield LookupI64Cursor{ found = 1, value = value_res.value, next_pos = next_pos }
        }
        end <- end + 1
    }
    yield missing_i64_cursor()
}

flow function_name_count(comp :: Compiler) -> i64 {
    bind count_res :: LookupI64 = u32_store_count_opt(comp.fn_params)
    check count_res.found == 1 {
        yield count_res.value
    }
    yield csv_count(comp.fn_names)
}

flow make_layout_scope(comp :: Compiler) -> LayoutScope {
    bind user_func_count :: i64 = function_name_count(comp) - builtin_function_count()
    yield LayoutScope{
        user_func_count = user_func_count
    }
}

flow load_u32_from_buf(buf :: i64, pos :: i64) -> i64 {
    yield buf_get(buf, pos) + buf_get(buf, pos + 1) * 256 + buf_get(buf, pos + 2) * 65536 + buf_get(buf, pos + 3) * 16777216
}

flow load_u32_store_opt(store :: i64, idx :: i64) -> LookupI64 {
    bind pos :: i64 = idx * 4
    check idx < 0 or pos + 3 >= buf_len(store) {
        yield missing_i64()
    }
    yield LookupI64{ found = 1, value = load_u32_from_buf(store, pos) }
}

flow u32_store_count_opt(store :: i64) -> LookupI64 {
    bind len :: i64 = buf_len(store)
    check len % 4 != 0 {
        yield missing_i64()
    }
    yield LookupI64{ found = 1, value = len / 4 }
}

flow u32_store_pair_count_opt(left :: i64, right :: i64) -> LookupI64 {
    bind left_count_res :: LookupI64 = u32_store_count_opt(left)
    bind right_count_res :: LookupI64 = u32_store_count_opt(right)
    check left_count_res.found == 0 or right_count_res.found == 0 {
        yield missing_i64()
    }
    check left_count_res.value != right_count_res.value {
        yield missing_i64()
    }
    yield left_count_res
}

flow load_indexed_u32_store_opt(store :: i64, idx :: i64) -> LookupI64 {
    bind count_res :: LookupI64 = u32_store_count_opt(store)
    check count_res.found == 0 or idx < 0 or idx >= count_res.value {
        yield missing_i64()
    }
    yield load_u32_store_opt(store, idx)
}

flow import_slot_count() -> i64 {
    yield 16
}

flow load_function_name_opt(comp :: Compiler, idx :: i64) -> LookupStr {
    yield csv_get_opt(comp.fn_names, idx)
}

flow load_struct_name_opt(comp :: Compiler, idx :: i64) -> LookupStr {
    yield csv_get_opt(comp.struct_names, idx)
}

flow load_struct_field_name_opt(fields :: str, idx :: i64) -> LookupStr {
    yield csv_get_opt(fields, idx)
}

flow load_var_name_opt(comp :: Compiler, idx :: i64) -> LookupStr {
    yield csv_get_opt(comp.var_names, idx)
}

flow load_var_type_opt(comp :: Compiler, idx :: i64) -> LookupStr {
    yield csv_get_opt(comp.var_types, idx)
}

flow load_function_param_count_opt(comp :: Compiler, idx :: i64) -> LookupI64 {
    yield load_indexed_u32_store_opt(comp.fn_params, idx)
}

flow load_function_param_start_opt(comp :: Compiler, idx :: i64) -> LookupI64 {
    yield load_indexed_u32_store_opt(comp.fn_param_starts, idx)
}

flow load_function_body_start_opt(comp :: Compiler, idx :: i64) -> LookupI64 {
    yield load_indexed_u32_store_opt(comp.fn_bodies, idx)
}

flow load_function_local_count_opt(comp :: Compiler, idx :: i64) -> LookupI64 {
    yield load_indexed_u32_store_opt(comp.fn_local_counts, idx)
}

flow validate_function_metadata_tables(comp :: Compiler) -> i64 {
    bind fn_total :: i64 = csv_count(comp.fn_names)
    bind param_count_res :: LookupI64 = u32_store_count_opt(comp.fn_params)
    bind param_start_count_res :: LookupI64 = u32_store_count_opt(comp.fn_param_starts)
    bind body_count_res :: LookupI64 = u32_store_count_opt(comp.fn_bodies)
    bind local_count_res :: LookupI64 = u32_store_count_opt(comp.fn_local_counts)
    check param_count_res.found == 0 or param_count_res.value != fn_total {
        yield 0
    }
    check param_start_count_res.found == 0 or param_start_count_res.value != fn_total {
        yield 0
    }
    check body_count_res.found == 0 or body_count_res.value != fn_total {
        yield 0
    }
    check local_count_res.found == 0 or local_count_res.value != fn_total {
        yield 0
    }
    yield 1
}

flow load_builtin_offset_opt(comp :: Compiler, builtin_idx :: i64) -> LookupI64 {
    bind builtin_count_res :: LookupI64 = u32_store_count_opt(comp.builtin_offset_store)
    check builtin_count_res.found == 0 or builtin_idx < 0 or builtin_idx >= builtin_count_res.value {
        yield missing_i64()
    }
    yield load_u32_store_opt(comp.builtin_offset_store, builtin_idx)
}

flow load_compiled_function_offset_opt(comp :: Compiler, fn_idx :: i64) -> LookupI64 {
    bind user_func_count :: i64 = compiled_function_schedule_count(comp)
    check fn_idx < 0 or fn_idx >= user_func_count {
        yield missing_i64()
    }
    yield load_u32_store_opt(comp.fn_schedule_code_starts, fn_idx)
}

flow load_effective_function_offset_opt(comp :: Compiler, fn_idx :: i64) -> LookupI64 {
    bind total_function_count :: i64 = function_name_count(comp)
    bind final_count_res :: LookupI64 = u32_store_count_opt(comp.final_effective_offsets)
    bind effective_count_res :: LookupI64 = u32_store_count_opt(comp.executor_effective_offsets)
    check fn_idx < 0 or fn_idx >= total_function_count {
        yield missing_i64()
    }
    check buf_len(comp.final_effective_offsets) > 0 {
        check final_count_res.found == 0 or fn_idx >= final_count_res.value {
            yield missing_i64()
        }
        yield load_u32_store_opt(comp.final_effective_offsets, fn_idx)
    }
    check buf_len(comp.executor_effective_offsets) > 0 {
        check effective_count_res.found == 0 or fn_idx >= effective_count_res.value {
            yield missing_i64()
        }
        yield load_u32_store_opt(comp.executor_effective_offsets, fn_idx)
    }
    bind user_func_count :: i64 = compiled_function_schedule_count(comp)
    check fn_idx < user_func_count {
        yield load_compiled_function_offset_opt(comp, fn_idx)
    }
    yield load_builtin_offset_opt(comp, fn_idx - user_func_count)
}

flow effective_function_offset_count(comp :: Compiler) -> i64 {
    bind final_count_res :: LookupI64 = u32_store_count_opt(comp.final_effective_offsets)
    bind effective_count_res :: LookupI64 = u32_store_count_opt(comp.executor_effective_offsets)
    check buf_len(comp.final_effective_offsets) > 0 and final_count_res.found == 1 {
        yield final_count_res.value
    }
    check buf_len(comp.executor_effective_offsets) > 0 and effective_count_res.found == 1 {
        yield effective_count_res.value
    }
    yield function_name_count(comp)
}

flow is_known_function_offset(comp :: Compiler, target_offset :: i64) -> i64 {
    bind total_function_count :: i64 = effective_function_offset_count(comp)
    vary fn_idx :: i64 = 0
    spin fn_idx < total_function_count {
        bind offset_res :: LookupI64 = load_effective_function_offset_opt(comp, fn_idx)
        check offset_res.found == 1 and offset_res.value == target_offset {
            yield 1
        }
        fn_idx <- fn_idx + 1
    }
    yield 0
}

flow pe_page_size() -> i64 {
    yield 4096
}

flow pe_text_rva() -> i64 {
    yield pe_page_size()
}

flow pe_reserved_text_vsize() -> i64 {
    yield 1048576
}

flow pe_rdata_rva() -> i64 {
    yield pe_text_rva() + pe_reserved_text_vsize()
}

flow pe_idata_rva() -> i64 {
    yield pe_text_rva() + pe_reserved_text_vsize() + 16384
}

flow pe_bss_rva() -> i64 {
    yield pe_text_rva() + pe_reserved_text_vsize() + 16384 + pe_page_size()
}

flow pe_iat_base_rva() -> i64 {
    yield pe_idata_rva() + 60
}

flow iat_rva(slot :: i64) -> i64 {
    bind iat_base :: i64 = pe_iat_base_rva()
    check slot > 4 {
        yield iat_base + (slot + 1) * 8
    }
    yield iat_base + slot * 8
}

flow is_known_rip_patch_target_rva(comp :: Compiler, target_rva :: i64) -> i64 {
    bind rdata_rva :: i64 = pe_rdata_rva()
    check target_rva >= rdata_rva and target_rva < rdata_rva + buf_len(comp.rdata) {
        yield 1
    }
    vary import_slot :: i64 = 0
    spin import_slot < import_slot_count() {
        check target_rva == iat_rva(import_slot) {
            yield 1
        }
        import_slot <- import_slot + 1
    }
    yield 0
}

flow builtin_function_count() -> i64 {
    yield 21
}

// Skip braces (reused)
flow skip_braces(src :: str, pos :: i64, depth :: i64) -> i64 {
    vary p :: i64 = pos
    vary d :: i64 = depth
    spin d > 0 {
        bind tok :: Token = next_token(src, p)
        check tok.kind == tk_eof() { yield p }
        check tok.kind == tk_lbrace() { d <- d + 1 }
        check tok.kind == tk_rbrace() { d <- d - 1 }
        p <- tok.end
    }
    yield p
}

// Count parameters of a flow
flow count_params(src :: str, pos :: i64) -> i64 {
    // pos is right after '('
    bind first :: Token = next_token(src, pos)
    check first.kind == tk_rparen() { yield 0 }
    vary count :: i64 = 1
    vary p :: i64 = pos
    spin true {
        bind tok :: Token = next_token(src, p)
        check tok.kind == tk_rparen() { yield count }
        check tok.kind == tk_comma() { count <- count + 1 }
        p <- tok.end
    }
    yield count
}

