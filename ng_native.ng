// Find opening brace of a flow body, return position after '{'
flow find_body_brace(src :: str, pos :: i64) -> i64 {
    vary p :: i64 = pos
    spin true {
        bind tok :: Token = next_token(src, p)
        check tok.kind == tk_lbrace() { yield tok.end }
        check tok.kind == tk_eof() { yield p }
        p <- tok.end
    }
    yield p
}

// First pass: collect all function names, param counts, body positions
// Collect field names from struct body, return comma-separated list
flow collect_struct_fields(src :: str, start :: i64) -> str {
    vary fields :: str = ""
    vary fp :: i64 = start
    vary fc :: i64 = 0
    spin true {
        bind ft :: Token = next_token(src, fp)
        check ft.kind == tk_rbrace() or ft.kind == tk_eof() { yield fields }
        check ft.kind == tk_ident() {
            bind dc :: Token = next_token(src, ft.end)
            check dc.kind == tk_dcolon() {
                check fc > 0 { fields <- str_concat(fields, ",") }
                fields <- str_concat(fields, sp(src, ft.start, ft.end))
                fc <- fc + 1
                bind tp :: Token = next_token(src, dc.end)
                fp <- tp.end
            } otherwise { fp <- dc.end }
        } otherwise { fp <- ft.end }
    }
    yield fields
}

flow collect_functions(src :: str) -> Compiler {
    vary comp :: Compiler = empty_compiler(src)
    vary p :: i64 = 0
    spin true {
        bind tok :: Token = next_token(src, p)
        check tok.kind == tk_eof() { yield comp }
        // Parse struct definitions
        check tok.kind == tk_ident() and sp_eq(src, tok, "form") {
            bind sname :: Token = next_token(src, tok.end)
            bind sb :: Token = next_token(src, sname.end)
            bind fields :: str = collect_struct_fields(src, sb.end)
            comp.struct_names <- csv_append(comp.struct_names, sp(src, sname.start, sname.end))
            comp.struct_fields <- str_concat(comp.struct_fields, str_concat(fields, ";"))
            p <- skip_braces(src, sb.end - 1, 0)
        }
        check tok.kind == tk_ident() and sp_eq(src, tok, "flow") {
            bind name :: Token = next_token(src, tok.end)
            bind lp :: Token = next_token(src, name.end)
            bind pc :: i64 = count_params(src, lp.end)
            bind body_start :: i64 = find_body_brace(src, lp.end)
            bind local_count :: i64 = count_locals(src, body_start)
            comp.fn_names <- csv_append(comp.fn_names, sp(src, name.start, name.end))
            comp.fn_params <- emit_u32(comp.fn_params, pc)
            comp.fn_param_starts <- emit_u32(comp.fn_param_starts, lp.end)
            comp.fn_bodies <- emit_u32(comp.fn_bodies, body_start)
            comp.fn_local_counts <- emit_u32(comp.fn_local_counts, local_count)
            p <- skip_braces(src, body_start, 1)
        } otherwise {
            p <- tok.end
        }
    }
    yield comp
}

flow struct_name_count(comp :: Compiler) -> i64 {
    yield csv_count(comp.struct_names)
}

// Get field list for struct at index i (from ";"-separated struct_fields).
flow get_struct_field_list_opt(comp :: Compiler, idx :: i64) -> LookupStr {
    check idx < 0 or idx >= struct_name_count(comp) {
        yield missing_str()
    }
    vary s :: str = comp.struct_fields
    vary i :: i64 = 0
    spin i < idx {
        bind sc :: i64 = str_len(s)
        vary j :: i64 = 0
        vary found_sep :: i64 = 0
        spin j < sc {
            check found_sep == 0 and str_byte_at(s, j) == 59 {  // ';'
                s <- str_slice(s, j + 1, str_len(s))
                found_sep <- 1
            }
            j <- j + 1
        }
        check found_sep == 0 {
            yield missing_str()
        }
        i <- i + 1
    }
    // s now starts with the right struct's fields, ending at ';'
    bind sc :: i64 = str_len(s)
    vary k :: i64 = 0
    spin k < sc {
        check str_byte_at(s, k) == 59 {
            yield LookupStr{ found = 1, value = str_slice(s, 0, k) }
        }
        k <- k + 1
    }
    yield missing_str()
}

// Find field offset (in bytes) for struct_name.field_name.
flow find_field_offset_opt(comp :: Compiler, struct_name :: str, field_name :: str) -> LookupI64 {
    vary si :: i64 = 0
    bind struct_total :: i64 = struct_name_count(comp)
    spin si < struct_total {
        bind struct_name_res :: LookupStr = load_struct_name_opt(comp, si)
        check struct_name_res.found == 0 {
            yield missing_i64()
        }
        check str_eq(struct_name_res.value, struct_name) {
            bind fields_res :: LookupStr = get_struct_field_list_opt(comp, si)
            check fields_res.found == 0 {
                yield missing_i64()
            }
            bind fields :: str = fields_res.value
            vary fi :: i64 = 0
            bind field_count :: i64 = csv_count(fields)
            spin fi < field_count {
                bind field_name_res :: LookupStr = load_struct_field_name_opt(fields, fi)
                check field_name_res.found == 0 {
                    yield missing_i64()
                }
                check str_eq(field_name_res.value, field_name) {
                    yield LookupI64{ found = 1, value = fi * 8 }
                }
                fi <- fi + 1
            }
            yield missing_i64()
        }
        si <- si + 1
    }
    yield missing_i64()
}

flow get_struct_size_opt(comp :: Compiler, struct_name :: str) -> LookupI64 {
    vary si :: i64 = 0
    bind struct_total :: i64 = struct_name_count(comp)
    spin si < struct_total {
        bind struct_name_res :: LookupStr = load_struct_name_opt(comp, si)
        check struct_name_res.found == 0 {
            yield missing_i64()
        }
        check str_eq(struct_name_res.value, struct_name) {
            bind fields_res :: LookupStr = get_struct_field_list_opt(comp, si)
            check fields_res.found == 0 {
                yield missing_i64()
            }
            bind fields :: str = fields_res.value
            yield LookupI64{ found = 1, value = csv_count(fields) * 8 }
        }
        si <- si + 1
    }
    yield missing_i64()
}

flow find_func_opt(comp :: Compiler, name :: str) -> LookupI64 {
    vary i :: i64 = 0
    bind fn_total :: i64 = function_name_count(comp)
    spin i < fn_total {
        bind fn_name_res :: LookupStr = load_function_name_opt(comp, i)
        check fn_name_res.found == 0 {
            yield missing_i64()
        }
        check str_eq(fn_name_res.value, name) {
            yield LookupI64{ found = 1, value = i }
        }
        i <- i + 1
    }
    yield missing_i64()
}

// ==================================================================
// SECTION 3: x86-64 CODE GENERATION
// ==================================================================

// Register encoding: RAX=0, RCX=1, RDX=2, RBX=3, RSP=4, RBP=5, RSI=6, RDI=7
// R8=0, R9=1 (with REX.B)

// Microsoft x64 calling convention:
// Args: RCX, RDX, R8, R9, then stack
// Return: RAX
// Caller-saved: RAX, RCX, RDX, R8, R9, R10, R11
// Callee-saved: RBX, RBP, RSI, RDI, R12-R15
// Shadow space: 32 bytes (4 * 8)
// Stack 16-byte aligned before CALL

// --- Instruction emitters ---

// push reg (64-bit)
flow x_push_reg(buf :: i64, reg :: i64) -> i64 {
    // 50+rd  (for RAX..RDI)
    yield buf_push(buf, 80 + reg)
}

// pop reg (64-bit)
flow x_pop_reg(buf :: i64, reg :: i64) -> i64 {
    yield buf_push(buf, 88 + reg)
}

// pop r8-r15
flow x_pop_r(buf :: i64, reg :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 65)   // REX.B
    b <- buf_push(b, 88 + reg)
    yield b
}

// mov reg, imm64 (REX.W + B8+rd + imm64)
flow x_mov_reg_imm64(buf :: i64, reg :: i64, imm :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)   // REX.W = 0x48
    b <- buf_push(b, 184 + reg)  // B8+rd
    b <- emit_u64(b, imm)
    yield b
}

// mov reg1, reg2 (REX.W + 89 /r)
flow x_mov_reg_reg(buf :: i64, dst :: i64, src2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)   // REX.W
    b <- buf_push(b, 137)  // 89 = mov r/m64, r64
    b <- buf_push(b, 192 + src2 * 8 + dst)  // ModRM
    yield b
}

// add reg1, reg2
flow x_add_reg_reg(buf :: i64, dst :: i64, src2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 1)    // 01
    b <- buf_push(b, 192 + src2 * 8 + dst)
    yield b
}

flow emit_exit_process_imm32(comp :: Compiler, code :: i64) -> Compiler {
    vary b :: i64 = comp.code
    // mov ecx, imm32
    b <- buf_push(b, 185)
    b <- emit_u32(b, code)
    // call [rip + ExitProcess@IAT]
    bind patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 0, patch_off)
    comp.code <- b
    yield comp
}

// sub reg1, reg2
flow x_sub_reg_reg(buf :: i64, dst :: i64, src2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 41)   // 29
    b <- buf_push(b, 192 + src2 * 8 + dst)
    yield b
}

// imul reg1, reg2 (REX.W + 0F AF /r)
flow x_imul_reg_reg(buf :: i64, dst :: i64, src2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 15)   // 0F
    b <- buf_push(b, 175)  // AF
    b <- buf_push(b, 192 + dst * 8 + src2)
    yield b
}

// idiv reg (REX.W + F7 /7) - divides RDX:RAX by reg
flow x_idiv_reg(buf :: i64, reg :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 247)  // F7
    b <- buf_push(b, 248 + reg)  // ModRM /7
    yield b
}

// cqo (sign extend RAX into RDX:RAX) - REX.W + 99
flow x_cqo(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 153)  // 99 = CQO
    yield b
}

// cmp reg1, reg2
flow x_cmp_reg_reg(buf :: i64, r1 :: i64, r2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 57)   // 39
    b <- buf_push(b, 192 + r2 * 8 + r1)
    yield b
}

// xor reg, reg (for zeroing)
flow x_xor_reg_reg(buf :: i64, r1 :: i64, r2 :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 49)   // 31
    b <- buf_push(b, 192 + r2 * 8 + r1)
    yield b
}

// ret
flow x_ret(buf :: i64) -> i64 {
    yield buf_push(buf, 195)  // C3
}

// call rel32
flow x_call_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 232)  // E8
    b <- emit_u32(b, rel)
    yield b
}

// jmp rel32
flow x_jmp_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 233)  // E9
    b <- emit_u32(b, rel)
    yield b
}

// je rel32 (0F 84)
flow x_je_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 132)
    b <- emit_u32(b, rel)
    yield b
}

// jne rel32 (0F 85)
flow x_jne_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 133)
    b <- emit_u32(b, rel)
    yield b
}

// jl rel32 (0F 8C)
flow x_jl_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 140)
    b <- emit_u32(b, rel)
    yield b
}

// jle rel32 (0F 8E)
flow x_jle_rel32(buf :: i64, rel :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 142)
    b <- emit_u32(b, rel)
    yield b
}

// sub rsp, imm8 (REX.W + 83 EC imm8)
flow x_sub_rsp_imm8(buf :: i64, imm :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)  // 83
    b <- buf_push(b, 236)  // EC = ModRM for RSP, /5
    b <- buf_push(b, imm % 256)
    yield b
}

// add rsp, imm8
flow x_add_rsp_imm8(buf :: i64, imm :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)  // 83
    b <- buf_push(b, 196)  // C4 = ModRM for RSP, /0
    b <- buf_push(b, imm % 256)
    yield b
}

// sub rsp, imm32
flow x_sub_rsp_imm32(buf :: i64, imm :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 129)  // 81
    b <- buf_push(b, 236)  // EC
    b <- emit_u32(b, imm)
    yield b
}

// mov [rbp + disp8], reg
flow x_mov_rbp_off8_reg(buf :: i64, off :: i64, reg :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)  // 89
    b <- buf_push(b, 69 + reg * 8)  // ModRM: mod=01, reg=reg, rm=RBP(5)
    // off is negative, emit as signed byte
    check off < 0 {
        b <- buf_push(b, (256 + off) % 256)
    } otherwise {
        b <- buf_push(b, off % 256)
    }
    yield b
}

// mov reg, [rbp + disp8]
flow x_mov_reg_rbp_off8(buf :: i64, reg :: i64, off :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)  // 8B
    b <- buf_push(b, 69 + reg * 8)  // ModRM
    check off < 0 {
        b <- buf_push(b, (256 + off) % 256)
    } otherwise {
        b <- buf_push(b, off % 256)
    }
    yield b
}

// mov [rbp + disp32], reg
flow x_mov_rbp_off32_reg(buf :: i64, off :: i64, reg :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)  // 89
    b <- buf_push(b, 133 + reg * 8)  // ModRM: mod=10, reg=reg, rm=RBP(5)
    check off < 0 {
        b <- emit_u32(b, 4294967296 + off)
    } otherwise {
        b <- emit_u32(b, off)
    }
    yield b
}

// mov reg, [rbp + disp32]
flow x_mov_reg_rbp_off32(buf :: i64, reg :: i64, off :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)  // 8B
    b <- buf_push(b, 133 + reg * 8)  // ModRM: mod=10
    check off < 0 {
        b <- emit_u32(b, 4294967296 + off)
    } otherwise {
        b <- emit_u32(b, off)
    }
    yield b
}

// setCC al (for comparison results)
// sete al = 0F 94 C0
flow x_sete_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 148)
    b <- buf_push(b, 192)
    yield b
}
// setne al = 0F 95 C0
flow x_setne_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 149)
    b <- buf_push(b, 192)
    yield b
}
// setl al = 0F 9C C0
flow x_setl_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 156)
    b <- buf_push(b, 192)
    yield b
}
// setle al = 0F 9E C0
flow x_setle_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 158)
    b <- buf_push(b, 192)
    yield b
}
// setg al = 0F 9F C0
flow x_setg_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 159)
    b <- buf_push(b, 192)
    yield b
}
// setge al = 0F 9D C0
flow x_setge_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 15)
    b <- buf_push(b, 157)
    b <- buf_push(b, 192)
    yield b
}

// movzx rax, al (REX.W + 0F B6 C0) - zero-extend byte to qword
flow x_movzx_rax_al(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 15)
    b <- buf_push(b, 182)
    b <- buf_push(b, 192)
    yield b
}

// lea rax, [rip + disp32] (for string addresses)
flow x_lea_rax_rip(buf :: i64, disp :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)  // 8D
    b <- buf_push(b, 5)    // ModRM: mod=00, reg=RAX, rm=RBP(101) = RIP-relative
    b <- emit_u32(b, disp)
    yield b
}

// Store helper: push rax (save expression result to stack)
flow x_push_rax(buf :: i64) -> i64 { yield x_push_reg(buf, 0) }
flow x_pop_rax(buf :: i64) -> i64 { yield x_pop_reg(buf, 0) }
flow x_pop_rcx(buf :: i64) -> i64 { yield x_pop_reg(buf, 1) }
flow x_pop_rdx(buf :: i64) -> i64 { yield x_pop_reg(buf, 2) }

// neg rax (REX.W + F7 /3) = two's complement negate
flow x_neg_rax(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 247)
    b <- buf_push(b, 216)  // D8 = ModRM /3, rax
    yield b
}

// test rax, rax (REX.W + 85 C0)
flow x_test_rax_rax(buf :: i64) -> i64 {
    vary b :: i64 = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 133)  // 85
    b <- buf_push(b, 192)  // C0
    yield b
}

// ==================================================================
// SECTION 4: STACK-BASED EXPRESSION COMPILER
// ==================================================================

// Variable layout: each function has locals at [rbp - 8], [rbp - 16], etc.
// Parameters: first 4 in rcx,rdx,r8,r9 - spilled to shadow space at entry

flow variable_name_count(comp :: Compiler) -> i64 {
    yield csv_count(comp.var_names)
}

flow find_var_opt(comp :: Compiler, name :: str) -> LookupI64 {
    vary i :: i64 = 0
    bind var_total :: i64 = variable_name_count(comp)
    spin i < var_total {
        bind var_name_res :: LookupStr = load_var_name_opt(comp, i)
        check var_name_res.found == 0 {
            yield missing_i64()
        }
        check str_eq(var_name_res.value, name) {
            yield LookupI64{ found = 1, value = -(i + 1) * 8 }
        }
        i <- i + 1
    }
    yield missing_i64()
}

flow add_var_typed(comp :: Compiler, name :: str, vtype :: str) -> Compiler {
    vary i :: i64 = 0
    bind var_total :: i64 = variable_name_count(comp)
    spin i < var_total {
        bind var_name_res :: LookupStr = load_var_name_opt(comp, i)
        check var_name_res.found == 0 { yield comp }
        check str_eq(var_name_res.value, name) { yield comp }
        i <- i + 1
    }
    comp.var_names <- csv_append(comp.var_names, name)
    comp.var_types <- csv_append(comp.var_types, vtype)
    yield comp
}

flow find_var_type_opt(comp :: Compiler, name :: str) -> LookupStr {
    vary i :: i64 = 0
    bind var_total :: i64 = variable_name_count(comp)
    spin i < var_total {
        bind var_name_res :: LookupStr = load_var_name_opt(comp, i)
        check var_name_res.found == 0 {
            yield missing_str()
        }
        bind var_type_res :: LookupStr = load_var_type_opt(comp, i)
        check var_type_res.found == 0 {
            yield missing_str()
        }
        check str_eq(var_name_res.value, name) {
            yield LookupStr{ found = 1, value = var_type_res.value }
        }
        i <- i + 1
    }
    yield missing_str()
}

// Count local variables in a function body (quick scan)
flow count_locals(src :: str, body_start :: i64) -> i64 {
    vary count :: i64 = 0
    vary p :: i64 = body_start
    vary depth :: i64 = 1
    spin depth > 0 {
        bind tok :: Token = next_token(src, p)
        check tok.kind == tk_eof() { yield count }
        check tok.kind == tk_lbrace() { depth <- depth + 1 }
        check tok.kind == tk_rbrace() { depth <- depth - 1 }
        check tok.kind == tk_ident() and (sp_eq(src, tok, "bind") or sp_eq(src, tok, "vary")) {
            count <- count + 1
        }
        p <- tok.end
    }
    yield count
}

// Compile expression, result in RAX. Returns Compiler with pos and code updated.
flow compile_expr(comp :: Compiler, pos :: i64) -> Compiler {
    comp <- compile_primary(comp, pos)
    comp <- compile_mul_tail(comp, comp.pos)
    comp <- compile_add_tail(comp, comp.pos)
    comp <- compile_cmp_tail(comp, comp.pos)
    comp <- compile_expr_tail(comp, comp.pos)
    yield comp
}

flow compile_primary(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)

    // Integer literal
    check tok.kind == tk_integer() {
        bind val_res :: LookupI64 = parse_int_result(src, tok.start, tok.end)
        check val_res.found == 0 {
            yield compiler_fail(comp, "bad int", tok.end)
        }
        bind val :: i64 = val_res.value
        comp.code <- x_mov_reg_imm64(comp.code, 0, val)
        comp.pos <- tok.end
        yield comp
    }

    // true/false
    check tok.kind == tk_ident() and sp_eq(src, tok, "true") {
        comp.code <- x_mov_reg_imm64(comp.code, 0, 1)
        comp.pos <- tok.end
        yield comp
    }
    check tok.kind == tk_ident() and sp_eq(src, tok, "false") {
        comp.code <- x_mov_reg_imm64(comp.code, 0, 0)
        comp.pos <- tok.end
        yield comp
    }

    // String literal - place in .rdata, emit lea rax, [rip+disp]
    check tok.kind == tk_string() {
        bind str_off :: i64 = buf_len(comp.rdata)
        vary si :: i64 = tok.start + 1
        spin si < tok.end - 1 {
            bind ch :: i64 = str_byte_at(src, si)
            check ch == 92 and si + 1 < tok.end - 1 {
                bind nc :: i64 = str_byte_at(src, si + 1)
                check nc == 110 { comp.rdata <- buf_push(comp.rdata, 10) }
                check nc != 110 { comp.rdata <- buf_push(comp.rdata, nc) }
                si <- si + 2
            } otherwise {
                comp.rdata <- buf_push(comp.rdata, ch)
                si <- si + 1
            }
        }
        comp.rdata <- buf_push(comp.rdata, 0)
        bind disp_patch_off :: i64 = buf_len(comp.code) + 3
        comp.code <- x_lea_rax_rip(comp.code, 0)
        comp.rdata_patch_offsets <- csv_append(comp.rdata_patch_offsets, str_from_i64(disp_patch_off))
        comp.rdata_patch_targets <- csv_append(comp.rdata_patch_targets, str_from_i64(str_off))
        comp.pos <- tok.end
        yield comp
    }

    // 'not' prefix
    check tok.kind == tk_ident() and sp_eq(src, tok, "not") {
        comp <- compile_primary(comp, tok.end)
        comp.code <- buf_push(comp.code, 72)
        comp.code <- buf_push(comp.code, 131)
        comp.code <- buf_push(comp.code, 240)
        comp.code <- buf_push(comp.code, 1)
        yield comp
    }

    // Unary minus
    check tok.kind == tk_minus() {
        comp <- compile_primary(comp, tok.end)
        comp.code <- x_neg_rax(comp.code)
        yield comp
    }

    // Parenthesized
    check tok.kind == tk_lparen() {
        comp <- compile_expr(comp, tok.end)
        bind cl :: Token = next_token(src, comp.pos)
        comp.pos <- cl.end
        yield comp
    }

    // Identifier (variable or function call or field access or struct literal)
    check tok.kind == tk_ident() {
        bind nx :: Token = next_token(src, tok.end)

        // Struct literal: StructName{field=val, ...}
        check nx.kind == tk_lbrace() {
            bind sname :: str = sp(src, tok.start, tok.end)
            bind ssize_res :: LookupI64 = get_struct_size_opt(comp, sname)
            check ssize_res.found == 1 {
                bind ssize :: i64 = ssize_res.value
                // malloc struct using outer function's stack frame
                comp.code <- x_sub_rsp_imm8(comp.code, 32)
                comp.code <- x_mov_reg_imm64(comp.code, 1, ssize)
                comp <- emit_local_import_call(comp, 13)
                comp.code <- x_add_rsp_imm8(comp.code, 32)
                // rax = struct ptr. Save it
                comp.code <- x_push_rax(comp.code)
                // Parse field assignments
                vary fp :: i64 = nx.end
                spin true {
                    bind ft :: Token = next_token(src, fp)
                    check ft.kind == tk_rbrace() {
                        comp.code <- x_pop_rax(comp.code)
                        comp.pos <- ft.end
                        yield comp
                    }
                    check ft.kind == tk_comma() { fp <- ft.end }
                    check ft.kind == tk_ident() {
                        bind feq :: Token = next_token(src, ft.end)
                        bind fname :: str = sp(src, ft.start, ft.end)
                        bind foff_res :: LookupI64 = find_field_offset_opt(comp, sname, fname)
                        check foff_res.found == 0 {
                            yield compiler_fail(comp, str_concat("no field ", str_concat(sname, str_concat(".", fname))), feq.end)
                        }
                        bind foff :: i64 = foff_res.value
                        comp <- compile_expr(comp, feq.end)
                        fp <- comp.pos
                        // rax = value, struct ptr is on stack
                        // mov rcx, [rsp]: peek struct ptr
                        // mov [rcx+foff], rax
                        comp.code <- x_mov_reg_reg(comp.code, 1, 0)  // rcx = value
                        // mov rax, [rsp]: 48 8B 04 24
                        comp.code <- buf_push(comp.code, 72)
                        comp.code <- buf_push(comp.code, 139)
                        comp.code <- buf_push(comp.code, 4)
                        comp.code <- buf_push(comp.code, 36)
                        // mov [rax+foff], rcx
                        check foff == 0 {
                            comp.code <- buf_push(comp.code, 72)
                            comp.code <- buf_push(comp.code, 137)
                            comp.code <- buf_push(comp.code, 8)
                        } otherwise {
                            check foff >= -128 and foff <= 127 {
                                comp.code <- buf_push(comp.code, 72)
                                comp.code <- buf_push(comp.code, 137)
                                comp.code <- buf_push(comp.code, 72)
                                comp.code <- buf_push(comp.code, foff)
                            } otherwise {
                                comp.code <- buf_push(comp.code, 72)
                                comp.code <- buf_push(comp.code, 137)
                                comp.code <- buf_push(comp.code, 136)
                                comp.code <- emit_u32(comp.code, foff)
                            }
                        }
                    } otherwise { fp <- ft.end }
                }
            }
        }

        // Field access: ident.field
        check nx.kind == tk_dot() {
            bind field_tok :: Token = next_token(src, nx.end)
            bind vname :: str = sp(src, tok.start, tok.end)
            bind fname :: str = sp(src, field_tok.start, field_tok.end)
            bind vtype_res :: LookupStr = find_var_type_opt(comp, vname)
            check vtype_res.found == 0 {
                yield compiler_fail(comp, str_concat("no vtype ", vname), field_tok.end)
            }
            bind vtype :: str = vtype_res.value
            bind foff_res :: LookupI64 = find_field_offset_opt(comp, vtype, fname)
            check foff_res.found == 0 {
                yield compiler_fail(comp, str_concat("no field ", str_concat(vtype, str_concat(".", fname))), field_tok.end)
            }
            bind foff :: i64 = foff_res.value
            // load struct ptr
            bind voff_res :: LookupI64 = find_var_opt(comp, vname)
            check voff_res.found == 0 {
                yield compiler_fail(comp, str_concat("no var ", vname), field_tok.end)
            }
            bind voff :: i64 = voff_res.value
            check voff >= -128 and voff <= 127 {
                comp.code <- x_mov_reg_rbp_off8(comp.code, 0, voff)
            } otherwise {
                comp.code <- x_mov_reg_rbp_off32(comp.code, 0, voff)
            }
            // mov rax, [rax+foff]
            check foff == 0 {
                // mov rax, [rax]: 48 8B 00
                comp.code <- buf_push(comp.code, 72)
                comp.code <- buf_push(comp.code, 139)
                comp.code <- buf_push(comp.code, 0)
            } otherwise {
                check foff >= -128 and foff <= 127 {
                    // mov rax, [rax+disp8]: 48 8B 40 DD
                    comp.code <- buf_push(comp.code, 72)
                    comp.code <- buf_push(comp.code, 139)
                    comp.code <- buf_push(comp.code, 64)
                    comp.code <- buf_push(comp.code, foff)
                } otherwise {
                    // mov rax, [rax+disp32]: 48 8B 80 DD DD DD DD
                    comp.code <- buf_push(comp.code, 72)
                    comp.code <- buf_push(comp.code, 139)
                    comp.code <- buf_push(comp.code, 128)
                    comp.code <- emit_u32(comp.code, foff)
                }
            }
            comp.pos <- field_tok.end
            yield comp
        }

        // Function call
        check nx.kind == tk_lparen() {
            bind fn_name :: str = sp(src, tok.start, tok.end)
            bind target_idx_res :: LookupI64 = find_func_opt(comp, fn_name)
            check target_idx_res.found == 0 {
                yield compiler_fail(comp, str_concat("no call ", fn_name), nx.end)
            }
            bind target_idx_str :: str = str_from_i64(target_idx_res.value)
            bind close_check :: Token = next_token(src, nx.end)
            check close_check.kind == tk_rparen() {
                comp.code <- x_sub_rsp_imm8(comp.code, 32)
                comp.patch_offsets <- csv_append(comp.patch_offsets, str_from_i64(buf_len(comp.code) + 1))
                comp.patch_targets <- csv_append(comp.patch_targets, target_idx_str)
                comp.code <- x_call_rel32(comp.code, 0)
                comp.code <- x_add_rsp_imm8(comp.code, 32)
                comp.pos <- close_check.end
                yield comp
            }

            vary arg_count :: i64 = 0
            vary ap :: i64 = nx.end
            spin true {
                bind at :: Token = next_token(src, ap)
                check at.kind == tk_rparen() {
                    check arg_count >= 4 { comp.code <- x_pop_r(comp.code, 1) }
                    check arg_count >= 3 { comp.code <- x_pop_r(comp.code, 0) }
                    check arg_count >= 2 { comp.code <- x_pop_rdx(comp.code) }
                    check arg_count >= 1 { comp.code <- x_pop_rcx(comp.code) }
                    comp.code <- x_sub_rsp_imm8(comp.code, 32)
                    comp.patch_offsets <- csv_append(comp.patch_offsets, str_from_i64(buf_len(comp.code) + 1))
                    comp.patch_targets <- csv_append(comp.patch_targets, target_idx_str)
                    comp.code <- x_call_rel32(comp.code, 0)
                    comp.code <- x_add_rsp_imm8(comp.code, 32)
                    comp.pos <- at.end
                    yield comp
                }
                comp <- compile_expr(comp, ap)
                ap <- comp.pos
                comp.code <- x_push_rax(comp.code)
                arg_count <- arg_count + 1
                bind mc :: Token = next_token(src, ap)
                check mc.kind == tk_comma() { ap <- mc.end }
            }
            comp.pos <- ap
            yield comp
        }

        // Variable reference
        bind vname :: str = sp(src, tok.start, tok.end)
        bind voff_res :: LookupI64 = find_var_opt(comp, vname)
        check voff_res.found == 0 {
            yield compiler_fail(comp, str_concat("no var ", vname), tok.end)
        }
        bind voff :: i64 = voff_res.value
        check voff >= -128 and voff <= 127 {
            comp.code <- x_mov_reg_rbp_off8(comp.code, 0, voff)
        } otherwise {
            comp.code <- x_mov_reg_rbp_off32(comp.code, 0, voff)
        }
        comp.pos <- tok.end
        yield comp
    }

    comp.pos <- tok.end
    yield comp
}

// Precedence levels: primary -> mul -> add -> cmp -> logic
// compile_expr calls compile_primary then compile_mul_tail

// Handle *, /, % (high precedence)
flow compile_mul_tail(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)
    check tok.kind == tk_star() or tok.kind == tk_slash() or tok.kind == tk_percent() {
        comp.code <- x_push_rax(comp.code)
        comp <- compile_primary(comp, tok.end)
        comp.code <- x_mov_reg_reg(comp.code, 1, 0)
        comp.code <- x_pop_rax(comp.code)
        check tok.kind == tk_star() { comp.code <- x_imul_reg_reg(comp.code, 0, 1) }
        check tok.kind == tk_slash() {
            comp.code <- x_cqo(comp.code)
            comp.code <- x_idiv_reg(comp.code, 1)
        }
        check tok.kind == tk_percent() {
            comp.code <- x_cqo(comp.code)
            comp.code <- x_idiv_reg(comp.code, 1)
            comp.code <- x_mov_reg_reg(comp.code, 0, 2)
        }
        yield compile_mul_tail(comp, comp.pos)
    }
    comp.pos <- pos
    yield comp
}

// Handle +, - (medium precedence)
flow compile_add_tail(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)
    check tok.kind == tk_plus() or tok.kind == tk_minus() {
        comp.code <- x_push_rax(comp.code)
        comp <- compile_primary(comp, tok.end)
        comp <- compile_mul_tail(comp, comp.pos)
        comp.code <- x_mov_reg_reg(comp.code, 1, 0)
        comp.code <- x_pop_rax(comp.code)
        check tok.kind == tk_plus() { comp.code <- x_add_reg_reg(comp.code, 0, 1) }
        check tok.kind == tk_minus() { comp.code <- x_sub_reg_reg(comp.code, 0, 1) }
        yield compile_add_tail(comp, comp.pos)
    }
    comp.pos <- pos
    yield comp
}

// Handle comparisons (low precedence)
flow compile_cmp_tail(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)
    check tok.kind == tk_eqeq() or tok.kind == tk_neq() or
          tok.kind == tk_lt() or tok.kind == tk_le() or
          tok.kind == tk_gt() or tok.kind == tk_ge() {
        comp.code <- x_push_rax(comp.code)
        comp <- compile_primary(comp, tok.end)
        comp <- compile_mul_tail(comp, comp.pos)
        comp <- compile_add_tail(comp, comp.pos)
        comp.code <- x_mov_reg_reg(comp.code, 1, 0)
        comp.code <- x_pop_rax(comp.code)
        comp.code <- x_cmp_reg_reg(comp.code, 0, 1)
        check tok.kind == tk_eqeq() { comp.code <- x_sete_al(comp.code) }
        check tok.kind == tk_neq() { comp.code <- x_setne_al(comp.code) }
        check tok.kind == tk_lt() { comp.code <- x_setl_al(comp.code) }
        check tok.kind == tk_le() { comp.code <- x_setle_al(comp.code) }
        check tok.kind == tk_gt() { comp.code <- x_setg_al(comp.code) }
        check tok.kind == tk_ge() { comp.code <- x_setge_al(comp.code) }
        comp.code <- x_movzx_rax_al(comp.code)
        yield compile_cmp_tail(comp, comp.pos)
    }
    comp.pos <- pos
    yield comp
}

// Handle and/or (lowest precedence)
flow compile_expr_tail(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)
    check tok.kind == tk_ident() and sp_eq(src, tok, "and") {
        comp.code <- x_push_rax(comp.code)
        comp <- compile_primary(comp, tok.end)
        comp <- compile_mul_tail(comp, comp.pos)
        comp <- compile_add_tail(comp, comp.pos)
        comp <- compile_cmp_tail(comp, comp.pos)
        comp.code <- x_mov_reg_reg(comp.code, 1, 0)
        comp.code <- x_pop_rax(comp.code)
        comp.code <- buf_push(comp.code, 72)
        comp.code <- buf_push(comp.code, 33)
        comp.code <- buf_push(comp.code, 200)
        yield compile_expr_tail(comp, comp.pos)
    }
    check tok.kind == tk_ident() and sp_eq(src, tok, "or") {
        comp.code <- x_push_rax(comp.code)
        comp <- compile_primary(comp, tok.end)
        comp <- compile_mul_tail(comp, comp.pos)
        comp <- compile_add_tail(comp, comp.pos)
        comp <- compile_cmp_tail(comp, comp.pos)
        comp.code <- x_mov_reg_reg(comp.code, 1, 0)
        comp.code <- x_pop_rax(comp.code)
        comp.code <- buf_push(comp.code, 72)
        comp.code <- buf_push(comp.code, 9)
        comp.code <- buf_push(comp.code, 200)
        yield compile_expr_tail(comp, comp.pos)
    }
    comp.pos <- pos
    yield comp
}

// ==================================================================
// SECTION 5: STATEMENT COMPILER
// ==================================================================

flow compile_stmt(comp :: Compiler, pos :: i64) -> Compiler {
    bind src :: str = comp.src
    bind tok :: Token = next_token(src, pos)

    // bind / vary
    check tok.kind == tk_ident() and (sp_eq(src, tok, "bind") or sp_eq(src, tok, "vary")) {
        bind name_tok :: Token = next_token(src, tok.end)
        bind dc :: Token = next_token(src, name_tok.end)  // :: (dcolon)
        bind type_tok :: Token = next_token(src, dc.end)
        bind eq :: Token = next_token(src, type_tok.end)
        bind vname :: str = sp(src, name_tok.start, name_tok.end)
        bind vtype :: str = sp(src, type_tok.start, type_tok.end)
        comp <- add_var_typed(comp, vname, vtype)
        comp <- compile_expr(comp, eq.end)
        bind voff_res :: LookupI64 = find_var_opt(comp, vname)
        check voff_res.found == 0 {
            yield compiler_fail(comp, str_concat("no var after ", vname), comp.pos)
        }
        bind voff :: i64 = voff_res.value
        check voff >= -128 and voff <= 127 {
            comp.code <- x_mov_rbp_off8_reg(comp.code, voff, 0)
        } otherwise {
            comp.code <- x_mov_rbp_off32_reg(comp.code, voff, 0)
        }
        yield comp
    }

    // yield expr
    check tok.kind == tk_ident() and sp_eq(src, tok, "yield") {
        comp <- compile_expr(comp, tok.end)
        comp.code <- x_mov_reg_reg(comp.code, 4, 5)
        comp.code <- x_pop_reg(comp.code, 5)
        comp.code <- x_ret(comp.code)
        yield comp
    }

    // check cond { body } otherwise { body }
    check tok.kind == tk_ident() and sp_eq(src, tok, "check") {
        comp <- compile_expr(comp, tok.end)
        comp.code <- x_test_rax_rax(comp.code)
        bind je_patch :: i64 = buf_len(comp.code)
        comp.code <- x_je_rel32(comp.code, 0)
        bind open :: Token = next_token(src, comp.pos)
        comp <- compile_body(comp, open.end)
        bind maybe_ow :: Token = next_token(src, comp.pos)
        check maybe_ow.kind == tk_ident() and sp_eq(src, maybe_ow, "otherwise") {
            bind jmp_patch :: i64 = buf_len(comp.code)
            comp.code <- x_jmp_rel32(comp.code, 0)
            bind else_off :: i64 = buf_len(comp.code)
            comp.code <- patch_u32(comp.code, je_patch + 2, else_off - (je_patch + 6))
            bind ow_open :: Token = next_token(src, maybe_ow.end)
            comp <- compile_body(comp, ow_open.end)
            bind end_off :: i64 = buf_len(comp.code)
            comp.code <- patch_u32(comp.code, jmp_patch + 1, end_off - (jmp_patch + 5))
            yield comp
        }
        bind here :: i64 = buf_len(comp.code)
        comp.code <- patch_u32(comp.code, je_patch + 2, here - (je_patch + 6))
        yield comp
    }

    // spin cond { body }
    check tok.kind == tk_ident() and sp_eq(src, tok, "spin") {
        bind loop_top :: i64 = buf_len(comp.code)
        bind cond_tok :: Token = next_token(src, tok.end)
        check sp_eq(src, cond_tok, "true") {
            bind open :: Token = next_token(src, cond_tok.end)
            comp <- compile_body(comp, open.end)
            bind here :: i64 = buf_len(comp.code)
            comp.code <- x_jmp_rel32(comp.code, loop_top - (here + 5))
            yield comp
        }
        comp <- compile_expr(comp, tok.end)
        comp.code <- x_test_rax_rax(comp.code)
        bind je_patch :: i64 = buf_len(comp.code)
        comp.code <- x_je_rel32(comp.code, 0)
        bind open :: Token = next_token(src, comp.pos)
        comp <- compile_body(comp, open.end)
        bind here :: i64 = buf_len(comp.code)
        comp.code <- x_jmp_rel32(comp.code, loop_top - (here + 5))
        bind end_off :: i64 = buf_len(comp.code)
        comp.code <- patch_u32(comp.code, je_patch + 2, end_off - (je_patch + 6))
        yield comp
    }

    // ident <- expr (assignment) or ident.field <- expr
    check tok.kind == tk_ident() {
        bind nx :: Token = next_token(src, tok.end)

        // ident.field <- expr (struct field assignment)
        check nx.kind == tk_dot() {
            bind field_tok :: Token = next_token(src, nx.end)
            bind arrow :: Token = next_token(src, field_tok.end)
            check arrow.kind == tk_larrow() {
                bind vname :: str = sp(src, tok.start, tok.end)
                bind fname :: str = sp(src, field_tok.start, field_tok.end)
                bind vtype_res :: LookupStr = find_var_type_opt(comp, vname)
                check vtype_res.found == 0 {
                    yield compiler_fail(comp, str_concat("no vtype ", vname), arrow.end)
                }
                bind vtype :: str = vtype_res.value
                bind foff_res :: LookupI64 = find_field_offset_opt(comp, vtype, fname)
                check foff_res.found == 0 {
                    yield compiler_fail(comp, str_concat("no field ", str_concat(vtype, str_concat(".", fname))), arrow.end)
                }
                bind foff :: i64 = foff_res.value
                // compile rhs into rax
                comp <- compile_expr(comp, arrow.end)
                // push rax (value), load struct ptr, store
                comp.code <- x_push_rax(comp.code)
                bind voff_res :: LookupI64 = find_var_opt(comp, vname)
                check voff_res.found == 0 {
                    yield compiler_fail(comp, str_concat("no var ", vname), arrow.end)
                }
                bind voff :: i64 = voff_res.value
                check voff >= -128 and voff <= 127 {
                    comp.code <- x_mov_reg_rbp_off8(comp.code, 1, voff)
                } otherwise {
                    comp.code <- x_mov_reg_rbp_off32(comp.code, 1, voff)
                }
                comp.code <- x_pop_rax(comp.code)
                // mov [rcx+foff], rax
                check foff == 0 {
                    // mov [rcx], rax: 48 89 01
                    comp.code <- buf_push(comp.code, 72)
                    comp.code <- buf_push(comp.code, 137)
                    comp.code <- buf_push(comp.code, 1)
                } otherwise {
                    check foff >= -128 and foff <= 127 {
                        // mov [rcx+disp8], rax: 48 89 41 DD
                        comp.code <- buf_push(comp.code, 72)
                        comp.code <- buf_push(comp.code, 137)
                        comp.code <- buf_push(comp.code, 65)
                        comp.code <- buf_push(comp.code, foff)
                    } otherwise {
                        // mov [rcx+disp32], rax: 48 89 81 DD DD DD DD
                        comp.code <- buf_push(comp.code, 72)
                        comp.code <- buf_push(comp.code, 137)
                        comp.code <- buf_push(comp.code, 129)
                        comp.code <- emit_u32(comp.code, foff)
                    }
                }
                yield comp
            }
        }

        check nx.kind == tk_larrow() {
            bind vname :: str = sp(src, tok.start, tok.end)
            comp <- compile_expr(comp, nx.end)
            bind voff_res :: LookupI64 = find_var_opt(comp, vname)
            check voff_res.found == 0 {
                yield compiler_fail(comp, str_concat("no var ", vname), nx.end)
            }
            bind voff :: i64 = voff_res.value
            check voff >= -128 and voff <= 127 {
                comp.code <- x_mov_rbp_off8_reg(comp.code, voff, 0)
            } otherwise {
                comp.code <- x_mov_rbp_off32_reg(comp.code, voff, 0)
            }
            yield comp
        }
        // Expression statement
        yield compile_expr(comp, pos)
    }

    // Other expression statement
    yield compile_expr(comp, pos)
}

flow compile_body(comp :: Compiler, pos :: i64) -> Compiler {
    vary p :: i64 = pos
    spin true {
        bind tok :: Token = next_token(comp.src, p)
        check tok.kind == tk_rbrace() or tok.kind == tk_eof() {
            comp.pos <- tok.end
            yield comp
        }
        comp <- compile_stmt(comp, p)
        p <- comp.pos
    }
    comp.pos <- p
    yield comp
}

// ==================================================================
// SECTION 6: FUNCTION COMPILATION
// ==================================================================

// Register function parameters from the recorded parameter-list start
flow register_params(comp :: Compiler, param_start :: i64, param_count :: i64) -> Compiler {
    bind src :: str = comp.src
    vary pp :: i64 = param_start
    vary pi :: i64 = 0
    spin pi < param_count {
        bind pt :: Token = next_token(src, pp)
        bind pname :: str = sp(src, pt.start, pt.end)
        bind dc :: Token = next_token(src, pt.end)
        bind ty :: Token = next_token(src, dc.end)
        bind ptype :: str = sp(src, ty.start, ty.end)
        comp <- add_var_typed(comp, pname, ptype)
        pp <- ty.end
        bind mc :: Token = next_token(src, pp)
        check mc.kind == tk_comma() { pp <- mc.end }
        pi <- pi + 1
    }
    yield comp
}

flow compiler_fail(comp :: Compiler, msg :: str, next_pos :: i64) -> Compiler {
    println(str_concat("E ", msg))
    comp.failed <- 1
    comp.failure_message <- msg
    comp.pos <- next_pos
    yield comp
}

flow validate_compiled_function_contract(compiled :: CompiledFunction, expected_fn_idx :: i64) -> LookupStr {
    bind patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.patch_offsets_local_store)
    bind patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.patch_targets_local_store)
    bind rdata_patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.rdata_patch_offsets_local_store)
    bind rdata_patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.rdata_patch_targets_local_store)
    bind import_patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.import_patch_offsets_local_store)
    bind import_patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.import_patch_targets_local_store)
    bind patch_offset_count_local :: i64 = csv_count(compiled.patch_offsets_local)
    bind patch_target_count_local :: i64 = csv_count(compiled.patch_targets_local)
    bind rdata_patch_offset_count_local :: i64 = csv_count(compiled.rdata_patch_offsets_local)
    bind rdata_patch_target_count_local :: i64 = csv_count(compiled.rdata_patch_targets_local)
    bind import_patch_offset_count_local :: i64 = csv_count(compiled.import_patch_offsets_local)
    bind import_patch_target_count_local :: i64 = csv_count(compiled.import_patch_targets_local)
    check compiled.fn_idx != expected_fn_idx {
        yield LookupStr{ found = 0, value = "cf idx mismatch" }
    }
    check compiled.compile_ok == 0 and str_len(compiled.failure_message) == 0 {
        yield LookupStr{ found = 0, value = "cf fail no msg" }
    }
    check compiled.compile_ok == 1 and str_len(compiled.failure_message) != 0 {
        yield LookupStr{ found = 0, value = "cf ok has msg" }
    }
    check patch_offset_count_local != compiled.patch_count_local or patch_target_count_local != compiled.patch_count_local {
        yield LookupStr{ found = 0, value = "cf patch csv bad" }
    }
    check patch_offset_store_count_res.found == 0 or patch_target_store_count_res.found == 0 {
        yield LookupStr{ found = 0, value = "cf patch store align" }
    }
    check patch_offset_store_count_res.value != compiled.patch_count_local or patch_target_store_count_res.value != compiled.patch_count_local {
        yield LookupStr{ found = 0, value = "cf patch store bad" }
    }
    check rdata_patch_offset_count_local != compiled.rdata_patch_count_local or rdata_patch_target_count_local != compiled.rdata_patch_count_local {
        yield LookupStr{ found = 0, value = "cf rpatch csv bad" }
    }
    check rdata_patch_offset_store_count_res.found == 0 or rdata_patch_target_store_count_res.found == 0 {
        yield LookupStr{ found = 0, value = "cf rpatch align" }
    }
    check rdata_patch_offset_store_count_res.value != compiled.rdata_patch_count_local or rdata_patch_target_store_count_res.value != compiled.rdata_patch_count_local {
        yield LookupStr{ found = 0, value = "cf rpatch bad" }
    }
    check import_patch_offset_count_local != compiled.import_patch_count_local or import_patch_target_count_local != compiled.import_patch_count_local {
        yield LookupStr{ found = 0, value = "cf ipatch csv bad" }
    }
    check import_patch_offset_store_count_res.found == 0 or import_patch_target_store_count_res.found == 0 {
        yield LookupStr{ found = 0, value = "cf ipatch align" }
    }
    check import_patch_offset_store_count_res.value != compiled.import_patch_count_local or import_patch_target_store_count_res.value != compiled.import_patch_count_local {
        yield LookupStr{ found = 0, value = "cf ipatch bad" }
    }
    yield LookupStr{ found = 1, value = "" }
}

flow build_compiled_function_schedule_entry(comp :: Compiler, compiled :: CompiledFunction) -> CompiledFunctionScheduleEntry {
    yield CompiledFunctionScheduleEntry{
        fn_idx = compiled.fn_idx,
        code_start = compiled_function_schedule_code_end(comp),
        rdata_start = compiled_function_schedule_rdata_end(comp),
        code_size = buf_len(compiled.code_buf),
        rdata_size = buf_len(compiled.rdata_buf)
    }
}

flow validate_compiled_function_schedule_entry(compiled :: CompiledFunction, schedule_entry :: CompiledFunctionScheduleEntry) -> LookupStr {
    check schedule_entry.fn_idx != compiled.fn_idx {
        yield LookupStr{ found = 0, value = "cf sched idx bad" }
    }
    check schedule_entry.code_start < 0 or schedule_entry.rdata_start < 0 {
        yield LookupStr{ found = 0, value = "cf sched code bad" }
    }
    check schedule_entry.code_size != buf_len(compiled.code_buf) {
        yield LookupStr{ found = 0, value = "cf sched code bad" }
    }
    check schedule_entry.rdata_size != buf_len(compiled.rdata_buf) {
        yield LookupStr{ found = 0, value = "cf rdata bad" }
    }
    yield LookupStr{ found = 1, value = "" }
}

flow compiled_function_schedule_count(comp :: Compiler) -> i64 {
    bind count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check count_res.found == 0 {
        yield -1
    }
    yield count_res.value
}

flow compiled_function_schedule_count_opt(comp :: Compiler) -> LookupI64 {
    bind code_start_count_res :: LookupI64 = u32_store_count_opt(comp.fn_schedule_code_starts)
    bind rdata_start_count_res :: LookupI64 = u32_store_count_opt(comp.fn_schedule_rdata_starts)
    bind code_size_count_res :: LookupI64 = u32_store_count_opt(comp.fn_schedule_code_sizes)
    bind rdata_size_count_res :: LookupI64 = u32_store_count_opt(comp.fn_schedule_rdata_sizes)
    check code_start_count_res.found == 0 or rdata_start_count_res.found == 0 or code_size_count_res.found == 0 or rdata_size_count_res.found == 0 {
        yield missing_i64()
    }
    check code_start_count_res.value != rdata_start_count_res.value or code_start_count_res.value != code_size_count_res.value or code_start_count_res.value != rdata_size_count_res.value {
        yield missing_i64()
    }
    yield code_start_count_res
}

flow compiled_function_schedule_code_end(comp :: Compiler) -> i64 {
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        yield -1
    }
    bind schedule_count :: i64 = schedule_count_res.value
    check schedule_count == 0 {
        yield buf_len(comp.code)
    }
    bind code_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, schedule_count - 1)
    bind code_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_sizes, schedule_count - 1)
    check code_start_res.found == 0 or code_size_res.found == 0 {
        yield -1
    }
    yield code_start_res.value + code_size_res.value
}

flow compiled_function_schedule_rdata_end(comp :: Compiler) -> i64 {
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        yield -1
    }
    bind schedule_count :: i64 = schedule_count_res.value
    check schedule_count == 0 {
        yield buf_len(comp.rdata)
    }
    bind rdata_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_starts, schedule_count - 1)
    bind rdata_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_sizes, schedule_count - 1)
    check rdata_start_res.found == 0 or rdata_size_res.found == 0 {
        yield -1
    }
    yield rdata_start_res.value + rdata_size_res.value
}

flow record_compiled_function_schedule(comp :: Compiler, schedule_entry :: CompiledFunctionScheduleEntry) -> Compiler {
    comp.fn_schedule_code_starts <- emit_u32(comp.fn_schedule_code_starts, schedule_entry.code_start)
    comp.fn_schedule_rdata_starts <- emit_u32(comp.fn_schedule_rdata_starts, schedule_entry.rdata_start)
    comp.fn_schedule_code_sizes <- emit_u32(comp.fn_schedule_code_sizes, schedule_entry.code_size)
    comp.fn_schedule_rdata_sizes <- emit_u32(comp.fn_schedule_rdata_sizes, schedule_entry.rdata_size)
    yield comp
}

flow reset_compiled_function_schedule_table(comp :: Compiler) -> Compiler {
    comp.fn_schedule_code_starts <- buf_new()
    comp.fn_schedule_rdata_starts <- buf_new()
    comp.fn_schedule_code_sizes <- buf_new()
    comp.fn_schedule_rdata_sizes <- buf_new()
    comp.fn_artifact_patch_offsets <- buf_new()
    comp.fn_artifact_patch_targets <- buf_new()
    comp.fn_artifact_patch_offset_store <- buf_new()
    comp.fn_artifact_patch_target_store <- buf_new()
    comp.fn_artifact_rdata_patch_offsets <- buf_new()
    comp.fn_artifact_rdata_patch_targets <- buf_new()
    comp.fn_artifact_rdata_patch_offset_store <- buf_new()
    comp.fn_artifact_rdata_patch_target_store <- buf_new()
    comp.fn_artifact_import_patch_offsets <- buf_new()
    comp.fn_artifact_import_patch_targets <- buf_new()
    comp.fn_artifact_import_patch_offset_store <- buf_new()
    comp.fn_artifact_import_patch_target_store <- buf_new()
    comp.patch_offsets <- ""
    comp.patch_targets <- ""
    comp.patch_offsets_store <- buf_new()
    comp.patch_targets_store <- buf_new()
    comp.rip_patch_offsets_store <- buf_new()
    comp.rip_patch_targets_store <- buf_new()
    yield comp
}

flow compiled_function_job_queue_count(comp :: Compiler) -> i64 {
    bind scope :: LayoutScope = make_layout_scope(comp)
    yield scope.user_func_count
}

flow compiled_function_executor_job_count(comp :: Compiler) -> i64 {
    check comp.executor_phase == 0 {
        yield 0
    }
    yield compiled_function_job_queue_count(comp)
}

flow reset_compiled_function_job_queue(comp :: Compiler) -> Compiler {
    yield comp
}

flow load_compiled_function_job_queue_entry(comp :: Compiler, idx :: i64) -> CompiledFunctionJob {
    bind param_count_res :: LookupI64 = load_function_param_count_opt(comp, idx)
    bind param_start_res :: LookupI64 = load_function_param_start_opt(comp, idx)
    bind body_start_res :: LookupI64 = load_function_body_start_opt(comp, idx)
    bind body_local_count_res :: LookupI64 = load_function_local_count_opt(comp, idx)
    yield CompiledFunctionJob{
        fn_idx = idx,
        param_count = param_count_res.value,
        param_start = param_start_res.value,
        body_start = body_start_res.value,
        body_local_count = body_local_count_res.value
    }
}

flow validate_compiled_function_job_queue(comp :: Compiler) -> i64 {
    bind scope :: LayoutScope = make_layout_scope(comp)
    bind job_count :: i64 = compiled_function_job_queue_count(comp)
    check job_count != scope.user_func_count {
        println(str_concat("E cf queue count ", str_concat(str_from_i64(scope.user_func_count), str_concat("/", str_from_i64(job_count)))))
        yield 0
    }
    vary qi :: i64 = 0
    spin qi < job_count {
        bind fn_name_res :: LookupStr = load_function_name_opt(comp, qi)
        check fn_name_res.found == 0 or str_eq(fn_name_res.value, "") {
            println(str_concat("E cf queue name ", str_from_i64(qi)))
            yield 0
        }
        bind param_count_res :: LookupI64 = load_function_param_count_opt(comp, qi)
        check param_count_res.found == 0 {
            println(str_concat("E cf queue pcount ", str_from_i64(qi)))
            yield 0
        }
        bind param_start_res :: LookupI64 = load_function_param_start_opt(comp, qi)
        check param_start_res.found == 0 {
            println(str_concat("E cf queue pstart ", str_from_i64(qi)))
            yield 0
        }
        bind body_start_res :: LookupI64 = load_function_body_start_opt(comp, qi)
        check body_start_res.found == 0 {
            println(str_concat("E cf queue body ", str_from_i64(qi)))
            yield 0
        }
        bind local_count_res :: LookupI64 = load_function_local_count_opt(comp, qi)
        check local_count_res.found == 0 {
            println(str_concat("E cf queue locals ", str_from_i64(qi)))
            yield 0
        }
        qi <- qi + 1
    }
    yield 1
}

flow reset_compiled_function_executor(comp :: Compiler) -> Compiler {
    comp.executor_phase <- 0
    comp.executor_job_cursor <- 0
    comp.executor_apply_cursor <- 0
    comp.executor_effective_offsets <- buf_new()
    comp.executor_total_round_count <- 0
    comp.executor_phase_round_count <- 0
    comp.executor_last_slice_budget <- 0
    comp.executor_phase_budget_scale <- 0
    comp.executor_phase_feedback_score <- 0
    comp.executor_last_round_completed_jobs <- 0
    comp.executor_scheduler_kind <- 0
    comp.executor_scheduler_plan_budget <- 0
    comp.executor_scheduler_apply_budget <- 0
    yield comp
}

flow compiled_function_executor_done(comp :: Compiler) -> i64 {
    yield comp.executor_phase == 3
}

flow compiled_function_executor_pending_jobs(comp :: Compiler) -> i64 {
    check comp.executor_phase == 1 {
        yield compiled_function_executor_job_count(comp) - comp.executor_job_cursor
    }
    check comp.executor_phase == 2 {
        bind scope :: LayoutScope = make_layout_scope(comp)
        yield scope.user_func_count - comp.executor_apply_cursor
    }
    yield 0
}

flow validate_compiled_function_executor(comp :: Compiler) -> i64 {
    bind scope :: LayoutScope = make_layout_scope(comp)
    bind job_count :: i64 = compiled_function_executor_job_count(comp)
    check comp.executor_phase < 0 or comp.executor_phase > 3 {
        println("E exec phase")
        yield 0
    }
    check comp.executor_job_cursor < 0 {
        println("E exec cursor")
        yield 0
    }
    check comp.executor_apply_cursor < 0 {
        println("E exec apply cursor")
        yield 0
    }
    check comp.executor_total_round_count < 0 or comp.executor_phase_round_count < 0 or comp.executor_last_slice_budget < 0 {
        println("E exec rounds")
        yield 0
    }
    check comp.executor_phase_budget_scale < 0 or comp.executor_phase_budget_scale > 4 {
        println("E exec scale")
        yield 0
    }
    check comp.executor_phase_feedback_score < 0 or comp.executor_phase_feedback_score > 4 {
        println("E exec score")
        yield 0
    }
    check comp.executor_scheduler_kind < 0 or comp.executor_scheduler_kind > 7 {
        println("E exec sched kind")
        yield 0
    }
    check comp.executor_scheduler_plan_budget < 0 or comp.executor_scheduler_apply_budget < 0 {
        println("E exec sched budget")
        yield 0
    }
    check comp.executor_last_round_completed_jobs < 0 {
        println("E exec last done")
        yield 0
    }
    check comp.executor_job_cursor > job_count {
        println("E exec cursor/count")
        yield 0
    }
    check comp.executor_apply_cursor > scope.user_func_count {
        println("E exec apply/count")
        yield 0
    }
    check comp.executor_phase == 0 {
        check comp.executor_job_cursor != 0 or comp.executor_apply_cursor != 0 or comp.executor_total_round_count != 0 or comp.executor_phase_round_count != 0 or comp.executor_last_slice_budget != 0 or comp.executor_phase_budget_scale != 0 or comp.executor_phase_feedback_score != 0 or comp.executor_last_round_completed_jobs != 0 {
            println("E exec idle dirty")
            yield 0
        }
        check buf_len(comp.executor_effective_offsets) != 0 {
            println("E exec idle eff")
            yield 0
        }
        check comp.executor_scheduler_kind == 0 {
            check comp.executor_scheduler_plan_budget != 0 or comp.executor_scheduler_apply_budget != 0 {
                println("E exec idle sched")
                yield 0
            }
        } otherwise {
            check comp.executor_scheduler_plan_budget <= 0 or comp.executor_scheduler_apply_budget <= 0 {
                println("E exec idle sched budget")
                yield 0
            }
        }
    } otherwise {
        check comp.executor_scheduler_kind == 0 or comp.executor_scheduler_plan_budget <= 0 or comp.executor_scheduler_apply_budget <= 0 {
            println("E exec sched missing")
            yield 0
        }
        check comp.executor_phase == 1 {
            check comp.executor_apply_cursor != 0 {
                println("E exec plan dirty")
                yield 0
            }
            check buf_len(comp.executor_effective_offsets) != 0 {
                println("E exec plan eff")
                yield 0
            }
            check comp.executor_phase_round_count > comp.executor_total_round_count {
                println("E exec plan rounds")
                yield 0
            }
            check comp.executor_phase_budget_scale <= 0 {
                println("E exec plan scale")
                yield 0
            }
            check comp.executor_phase_feedback_score <= 0 {
                println("E exec plan score")
                yield 0
            }
        } otherwise {
            bind exec_count_res :: LookupI64 = u32_store_count_opt(comp.executor_effective_offsets)
            check exec_count_res.found == 0 or exec_count_res.value != function_name_count(comp) {
                println("E exec eff len")
                yield 0
            }
            check comp.executor_phase_round_count > comp.executor_total_round_count {
                println("E exec apply rounds")
                yield 0
            }
            check comp.executor_phase == 2 and comp.executor_phase_budget_scale <= 0 {
                println("E exec apply scale")
                yield 0
            }
            check comp.executor_phase == 2 and comp.executor_phase_feedback_score <= 0 {
                println("E exec apply score")
                yield 0
            }
        }
    }
    yield 1
}

flow start_compiled_function_executor(comp :: Compiler) -> Compiler {
    check validate_compiled_function_job_queue(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf queue invalid"
        yield comp
    }
    check comp.executor_scheduler_kind == 0 or comp.executor_scheduler_plan_budget <= 0 or comp.executor_scheduler_apply_budget <= 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec scheduler"
        yield comp
    }
    comp.executor_phase <- 1
    comp.executor_job_cursor <- 0
    comp.executor_total_round_count <- 0
    comp.executor_phase_round_count <- 0
    comp.executor_last_slice_budget <- 0
    comp.executor_phase_budget_scale <- 1
    comp.executor_phase_feedback_score <- 2
    comp.executor_last_round_completed_jobs <- 0
    check validate_compiled_function_executor(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec invalid"
        yield comp
    }
    yield comp
}

flow default_compiled_function_executor_schedule_policy() -> CompiledFunctionExecutorSchedulePolicy {
    yield CompiledFunctionExecutorSchedulePolicy{
        plan_job_budget = 32,
        apply_job_budget = 32
    }
}

flow normalize_compiled_function_executor_schedule_policy(policy :: CompiledFunctionExecutorSchedulePolicy) -> CompiledFunctionExecutorSchedulePolicy {
    bind default_policy :: CompiledFunctionExecutorSchedulePolicy = default_compiled_function_executor_schedule_policy()
    vary normalized :: CompiledFunctionExecutorSchedulePolicy = policy
    check normalized.plan_job_budget <= 0 {
        normalized.plan_job_budget <- default_policy.plan_job_budget
    }
    check normalized.apply_job_budget <= 0 {
        normalized.apply_job_budget <- default_policy.apply_job_budget
    }
    yield normalized
}

flow default_compiled_function_executor_scheduler() -> CompiledFunctionExecutorScheduler {
    bind policy :: CompiledFunctionExecutorSchedulePolicy = default_compiled_function_executor_schedule_policy()
    yield CompiledFunctionExecutorScheduler{
        scheduler_kind = 1,
        plan_job_budget = policy.plan_job_budget,
        apply_job_budget = policy.apply_job_budget
    }
}

flow pick_compiled_function_executor_scheduler(comp :: Compiler) -> CompiledFunctionExecutorScheduler {
    bind scope :: LayoutScope = make_layout_scope(comp)
    check scope.user_func_count <= 16 {
        yield CompiledFunctionExecutorScheduler{
            scheduler_kind = 2,
            plan_job_budget = 32,
            apply_job_budget = 32
        }
    }
    check scope.user_func_count >= 128 {
        yield CompiledFunctionExecutorScheduler{
            scheduler_kind = 7,
            plan_job_budget = 64,
            apply_job_budget = 32
        }
    }
    yield default_compiled_function_executor_scheduler()
}

flow normalize_compiled_function_executor_scheduler(scheduler :: CompiledFunctionExecutorScheduler) -> CompiledFunctionExecutorScheduler {
    bind default_scheduler :: CompiledFunctionExecutorScheduler = default_compiled_function_executor_scheduler()
    bind normalized_policy :: CompiledFunctionExecutorSchedulePolicy = normalize_compiled_function_executor_schedule_policy(
        CompiledFunctionExecutorSchedulePolicy{
            plan_job_budget = scheduler.plan_job_budget,
            apply_job_budget = scheduler.apply_job_budget
        }
    )
    vary normalized :: CompiledFunctionExecutorScheduler = CompiledFunctionExecutorScheduler{
        scheduler_kind = scheduler.scheduler_kind,
        plan_job_budget = normalized_policy.plan_job_budget,
        apply_job_budget = normalized_policy.apply_job_budget
    }
    check normalized.scheduler_kind != 1 and normalized.scheduler_kind != 2 and normalized.scheduler_kind != 3 and normalized.scheduler_kind != 4 and normalized.scheduler_kind != 5 and normalized.scheduler_kind != 6 and normalized.scheduler_kind != 7 {
        normalized.scheduler_kind <- default_scheduler.scheduler_kind
    }
    yield normalized
}

flow configured_compiled_function_executor_scheduler(comp :: Compiler) -> CompiledFunctionExecutorScheduler {
    yield normalize_compiled_function_executor_scheduler(
        CompiledFunctionExecutorScheduler{
            scheduler_kind = comp.executor_scheduler_kind,
            plan_job_budget = comp.executor_scheduler_plan_budget,
            apply_job_budget = comp.executor_scheduler_apply_budget
        }
    )
}

flow configure_compiled_function_executor_scheduler(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> Compiler {
    bind normalized :: CompiledFunctionExecutorScheduler = normalize_compiled_function_executor_scheduler(scheduler)
    comp.executor_scheduler_kind <- normalized.scheduler_kind
    comp.executor_scheduler_plan_budget <- normalized.plan_job_budget
    comp.executor_scheduler_apply_budget <- normalized.apply_job_budget
    yield comp
}

flow compiled_function_executor_scheduler_phase_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind normalized :: CompiledFunctionExecutorScheduler = normalize_compiled_function_executor_scheduler(scheduler)
    check comp.executor_phase == 1 {
        yield normalized.plan_job_budget
    }
    check comp.executor_phase == 2 {
        yield normalized.apply_job_budget
    }
    yield 0
}

flow pick_compiled_function_executor_adaptive_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    vary adaptive_budget :: i64 = phase_budget
    check pending <= 0 {
        yield 0
    }
    check phase_budget <= 0 {
        yield 0
    }
    check pending >= phase_budget * 8 {
        adaptive_budget <- phase_budget * 4
    } otherwise {
        check pending >= phase_budget * 4 {
            adaptive_budget <- phase_budget * 2
        }
    }
    check adaptive_budget > pending {
        yield pending
    }
    yield adaptive_budget
}

flow compiled_function_executor_observed_phase_cost(comp :: Compiler) -> i64 {
    check comp.executor_phase == 1 {
        bind completed_jobs :: i64 = comp.executor_job_cursor
        check completed_jobs <= 0 {
            yield 0
        }
        bind patch_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_patch_offset_store, comp.fn_artifact_patch_target_store)
        check patch_count_res.found == 0 {
            yield 2
        }
        bind avg_code_size :: i64 = buf_len(comp.code) / completed_jobs
        bind avg_patch_count :: i64 = patch_count_res.value / completed_jobs
        check avg_code_size >= 1024 or avg_patch_count >= 24 {
            yield 2
        }
        check avg_code_size >= 512 or avg_patch_count >= 12 {
            yield 1
        }
        yield 0
    }
    check comp.executor_phase == 2 {
        bind completed_apply_jobs :: i64 = comp.executor_apply_cursor
        check completed_apply_jobs <= 0 {
            yield 0
        }
        bind rip_patch_count_res :: LookupI64 = u32_store_pair_count_opt(comp.rip_patch_offsets_store, comp.rip_patch_targets_store)
        check rip_patch_count_res.found == 0 {
            yield 2
        }
        bind avg_rip_patch_count :: i64 = rip_patch_count_res.value / completed_apply_jobs
        check avg_rip_patch_count >= 6 {
            yield 2
        }
        check avg_rip_patch_count >= 3 {
            yield 1
        }
        yield 0
    }
    yield 0
}

flow compiled_function_executor_phase_completed_jobs(comp :: Compiler) -> i64 {
    check comp.executor_phase == 1 {
        yield comp.executor_job_cursor
    }
    check comp.executor_phase == 2 {
        yield comp.executor_apply_cursor
    }
    yield 0
}

flow compiled_function_executor_phase_progress_class(comp :: Compiler) -> i64 {
    bind completed_jobs :: i64 = compiled_function_executor_phase_completed_jobs(comp)
    vary total_jobs :: i64 = 0
    check comp.executor_phase == 1 {
        total_jobs <- compiled_function_executor_job_count(comp)
    } otherwise {
        check comp.executor_phase == 2 {
            bind scope :: LayoutScope = make_layout_scope(comp)
            total_jobs <- scope.user_func_count
        }
    }
    check total_jobs <= 0 {
        yield 0
    }
    check completed_jobs * 4 >= total_jobs * 3 {
        yield 2
    }
    check completed_jobs * 4 >= total_jobs {
        yield 1
    }
    yield 0
}

flow compiled_function_executor_phase_round_class(comp :: Compiler) -> i64 {
    bind phase_rounds :: i64 = comp.executor_phase_round_count
    check phase_rounds <= 1 {
        yield 0
    }
    check phase_rounds >= 5 {
        yield 2
    }
    yield 1
}

flow compiled_function_executor_last_round_fullness_class(comp :: Compiler) -> i64 {
    bind last_budget :: i64 = comp.executor_last_slice_budget
    bind last_completed :: i64 = comp.executor_last_round_completed_jobs
    check last_budget <= 0 {
        yield 0
    }
    check last_completed * 4 < last_budget {
        yield 0
    }
    check last_completed < last_budget {
        yield 1
    }
    yield 2
}

flow normalize_compiled_function_executor_budget_scale(scale :: i64) -> i64 {
    vary normalized :: i64 = scale
    check normalized <= 0 {
        normalized <- 1
    }
    check normalized > 4 {
        normalized <- 4
    }
    yield normalized
}

flow normalize_compiled_function_executor_feedback_score(score :: i64) -> i64 {
    vary normalized :: i64 = score
    check normalized < 0 {
        normalized <- 0
    }
    check normalized > 4 {
        normalized <- 4
    }
    yield normalized
}

flow pick_compiled_function_executor_cost_aware_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    bind pending_budget :: i64 = pick_compiled_function_executor_adaptive_slice_budget(comp, scheduler)
    bind observed_cost :: i64 = compiled_function_executor_observed_phase_cost(comp)
    check pending <= 0 {
        yield 0
    }
    check phase_budget <= 0 {
        yield 0
    }
    check pending_budget <= 0 {
        yield 0
    }
    check observed_cost >= 2 {
        check phase_budget > pending {
            yield pending
        }
        yield phase_budget
    }
    check observed_cost == 1 {
        bind medium_budget :: i64 = phase_budget * 2
        check medium_budget > pending {
            medium_budget <- pending
        }
        check pending_budget > medium_budget {
            yield medium_budget
        }
        yield pending_budget
    }
    check comp.executor_phase == 2 and pending <= phase_budget * 2 and pending_budget > phase_budget {
        check phase_budget > pending {
            yield pending
        }
        yield phase_budget
    }
    yield pending_budget
}

flow pick_compiled_function_executor_cost_progress_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    bind completed_jobs :: i64 = compiled_function_executor_phase_completed_jobs(comp)
    bind cost_budget :: i64 = pick_compiled_function_executor_cost_aware_slice_budget(comp, scheduler)
    bind progress_class :: i64 = compiled_function_executor_phase_progress_class(comp)
    vary progress_budget :: i64 = cost_budget
    check pending <= 0 {
        yield 0
    }
    check phase_budget <= 0 {
        yield 0
    }
    check progress_budget <= 0 {
        yield 0
    }
    check completed_jobs <= 0 and progress_budget > phase_budget {
        progress_budget <- phase_budget
    }
    check progress_class == 0 and progress_budget > phase_budget * 2 {
        progress_budget <- phase_budget * 2
    }
    check progress_class == 2 and progress_budget > phase_budget {
        progress_budget <- phase_budget
    }
    check progress_budget > pending {
        yield pending
    }
    yield progress_budget
}

flow pick_compiled_function_executor_round_aware_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    bind progress_budget :: i64 = pick_compiled_function_executor_cost_progress_slice_budget(comp, scheduler)
    bind round_class :: i64 = compiled_function_executor_phase_round_class(comp)
    bind observed_cost :: i64 = compiled_function_executor_observed_phase_cost(comp)
    bind last_budget :: i64 = comp.executor_last_slice_budget
    vary round_budget :: i64 = progress_budget
    check pending <= 0 {
        yield 0
    }
    check phase_budget <= 0 {
        yield 0
    }
    check round_budget <= 0 {
        yield 0
    }
    check round_class == 0 and round_budget > phase_budget {
        round_budget <- phase_budget
    }
    check round_class == 1 and observed_cost == 0 and pending >= phase_budget * 4 and round_budget < phase_budget * 3 {
        round_budget <- phase_budget * 3
    }
    check last_budget > 0 and round_budget > last_budget * 2 {
        round_budget <- last_budget * 2
    }
    check round_class == 2 and comp.executor_phase == 2 and round_budget > phase_budget {
        round_budget <- phase_budget
    }
    check round_budget > pending {
        yield pending
    }
    yield round_budget
}

flow pick_compiled_function_executor_stateful_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    bind round_budget :: i64 = pick_compiled_function_executor_round_aware_slice_budget(comp, scheduler)
    vary scale_limit :: i64 = phase_budget * normalize_compiled_function_executor_budget_scale(comp.executor_phase_budget_scale)
    check pending <= 0 {
        yield 0
    }
    check phase_budget <= 0 or round_budget <= 0 {
        yield 0
    }
    check scale_limit > pending {
        scale_limit <- pending
    }
    check round_budget > scale_limit {
        yield scale_limit
    }
    yield round_budget
}

flow update_compiled_function_executor_budget_scale(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler, phase_before :: i64, round_budget :: i64) -> Compiler {
    check phase_before != comp.executor_phase {
        yield comp
    }
    check phase_before != 1 and phase_before != 2 {
        yield comp
    }
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, scheduler)
    bind pending_after :: i64 = compiled_function_executor_pending_jobs(comp)
    bind observed_cost :: i64 = compiled_function_executor_observed_phase_cost(comp)
    bind last_fullness :: i64 = compiled_function_executor_last_round_fullness_class(comp)
    vary scale :: i64 = normalize_compiled_function_executor_budget_scale(comp.executor_phase_budget_scale)
    vary feedback_score :: i64 = normalize_compiled_function_executor_feedback_score(comp.executor_phase_feedback_score)
    check phase_budget <= 0 {
        comp.executor_phase_budget_scale <- scale
        comp.executor_phase_feedback_score <- feedback_score
        yield comp
    }
    check pending_after <= phase_budget * 2 {
        scale <- 1
        feedback_score <- 2
    } otherwise {
        check last_fullness == 0 or observed_cost >= 2 {
            check feedback_score > 0 {
                feedback_score <- feedback_score - 1
            }
            check feedback_score == 0 and scale > 1 {
                scale <- scale - 1
                feedback_score <- 2
            }
        } otherwise {
            check observed_cost == 0 and last_fullness == 2 and comp.executor_phase_round_count >= 2 and pending_after >= phase_budget * 4 and round_budget >= phase_budget * scale {
                check feedback_score < 4 {
                    feedback_score <- feedback_score + 1
                }
                check feedback_score == 4 and scale < 4 {
                    scale <- scale + 1
                    feedback_score <- 2
                }
            } otherwise {
                check feedback_score < 2 {
                    feedback_score <- feedback_score + 1
                }
                check feedback_score > 2 {
                    feedback_score <- feedback_score - 1
                }
            }
        }
    }
    comp.executor_phase_budget_scale <- normalize_compiled_function_executor_budget_scale(scale)
    comp.executor_phase_feedback_score <- normalize_compiled_function_executor_feedback_score(feedback_score)
    yield comp
}

flow pick_compiled_function_executor_slice_budget(comp :: Compiler, scheduler :: CompiledFunctionExecutorScheduler) -> i64 {
    bind normalized :: CompiledFunctionExecutorScheduler = normalize_compiled_function_executor_scheduler(scheduler)
    bind pending :: i64 = compiled_function_executor_pending_jobs(comp)
    check pending <= 0 {
        yield 0
    }
    check normalized.scheduler_kind == 2 {
        yield pending
    }
    check normalized.scheduler_kind == 3 {
        yield pick_compiled_function_executor_adaptive_slice_budget(comp, normalized)
    }
    check normalized.scheduler_kind == 4 {
        yield pick_compiled_function_executor_cost_aware_slice_budget(comp, normalized)
    }
    check normalized.scheduler_kind == 5 {
        yield pick_compiled_function_executor_cost_progress_slice_budget(comp, normalized)
    }
    check normalized.scheduler_kind == 6 {
        yield pick_compiled_function_executor_round_aware_slice_budget(comp, normalized)
    }
    check normalized.scheduler_kind == 7 {
        yield pick_compiled_function_executor_stateful_slice_budget(comp, normalized)
    }
    bind phase_budget :: i64 = compiled_function_executor_scheduler_phase_budget(comp, normalized)
    check phase_budget <= 0 {
        yield 0
    }
    check phase_budget > pending {
        yield pending
    }
    yield phase_budget
}

flow record_compiled_function_artifact(comp :: Compiler, compiled :: CompiledFunction) -> Compiler {
    bind patch_start_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_patch_offset_store, comp.fn_artifact_patch_target_store)
    bind rdata_patch_start_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_rdata_patch_offset_store, comp.fn_artifact_rdata_patch_target_store)
    bind import_patch_start_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_import_patch_offset_store, comp.fn_artifact_import_patch_target_store)
    check patch_start_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art p store"
        yield comp
    }
    check rdata_patch_start_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art r store"
        yield comp
    }
    check import_patch_start_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art i store"
        yield comp
    }
    comp.code <- buf_append(comp.code, compiled.code_buf)
    comp.rdata <- buf_append(comp.rdata, compiled.rdata_buf)
    comp.fn_artifact_patch_offsets <- emit_u32(comp.fn_artifact_patch_offsets, patch_start_res.value)
    comp.fn_artifact_patch_targets <- emit_u32(comp.fn_artifact_patch_targets, compiled.patch_count_local)
    comp.fn_artifact_patch_offset_store <- buf_append(comp.fn_artifact_patch_offset_store, compiled.patch_offsets_local_store)
    comp.fn_artifact_patch_target_store <- buf_append(comp.fn_artifact_patch_target_store, compiled.patch_targets_local_store)
    comp.fn_artifact_rdata_patch_offsets <- emit_u32(comp.fn_artifact_rdata_patch_offsets, rdata_patch_start_res.value)
    comp.fn_artifact_rdata_patch_targets <- emit_u32(comp.fn_artifact_rdata_patch_targets, compiled.rdata_patch_count_local)
    comp.fn_artifact_rdata_patch_offset_store <- buf_append(comp.fn_artifact_rdata_patch_offset_store, compiled.rdata_patch_offsets_local_store)
    comp.fn_artifact_rdata_patch_target_store <- buf_append(comp.fn_artifact_rdata_patch_target_store, compiled.rdata_patch_targets_local_store)
    comp.fn_artifact_import_patch_offsets <- emit_u32(comp.fn_artifact_import_patch_offsets, import_patch_start_res.value)
    comp.fn_artifact_import_patch_targets <- emit_u32(comp.fn_artifact_import_patch_targets, compiled.import_patch_count_local)
    comp.fn_artifact_import_patch_offset_store <- buf_append(comp.fn_artifact_import_patch_offset_store, compiled.import_patch_offsets_local_store)
    comp.fn_artifact_import_patch_target_store <- buf_append(comp.fn_artifact_import_patch_target_store, compiled.import_patch_targets_local_store)
    yield comp
}

flow compile_function_planned(comp :: Compiler, plan :: FunctionCompilePlan) -> CompiledFunction {
    vary local_comp :: Compiler = empty_local_compile_state(comp)
    bind param_count :: i64 = plan.param_count
    bind param_start :: i64 = plan.param_start
    bind body_start :: i64 = plan.body_start
    bind body_local_count :: i64 = plan.body_local_count

    // Register parameters as variables
    local_comp <- register_params(local_comp, param_start, param_count)

    // Count locals for stack frame
    bind local_count :: i64 = body_local_count + param_count
    bind frame_size :: i64 = (local_count + 1) * 8
    // Align to 16 bytes
    bind aligned_frame :: i64 = ((frame_size + 15) / 16) * 16

    // Function prologue
    local_comp.code <- x_push_reg(local_comp.code, 5)              // push rbp
    local_comp.code <- x_mov_reg_reg(local_comp.code, 5, 4)        // mov rbp, rsp
    check aligned_frame <= 127 {
        local_comp.code <- x_sub_rsp_imm8(local_comp.code, aligned_frame)
    } otherwise {
        local_comp.code <- x_sub_rsp_imm32(local_comp.code, aligned_frame)
    }

    // Spill parameters from registers to stack
    check param_count >= 1 {
        local_comp.code <- x_mov_rbp_off8_reg(local_comp.code, -8, 1)   // [rbp-8] = rcx
    }
    check param_count >= 2 {
        local_comp.code <- x_mov_rbp_off8_reg(local_comp.code, -16, 2)  // [rbp-16] = rdx
    }
    check param_count >= 3 {
        // r8 -> [rbp-24]: need REX prefix for r8
        // mov [rbp-24], r8: 4C 89 45 E8
        local_comp.code <- buf_push(local_comp.code, 76)   // 4C = REX.WR
        local_comp.code <- buf_push(local_comp.code, 137)  // 89
        local_comp.code <- buf_push(local_comp.code, 69)   // 45 = ModRM [rbp+disp8]
        local_comp.code <- buf_push(local_comp.code, 232)  // E8 = -24
    }
    check param_count >= 4 {
        // r9 -> [rbp-32]: 4C 89 4D E0
        local_comp.code <- buf_push(local_comp.code, 76)
        local_comp.code <- buf_push(local_comp.code, 137)
        local_comp.code <- buf_push(local_comp.code, 77)   // 4D
        local_comp.code <- buf_push(local_comp.code, 224)  // E0 = -32
    }

    // Compile body
    local_comp <- compile_body(local_comp, body_start)
    check local_comp.failed == 1 {
        yield CompiledFunction{
            fn_idx = plan.fn_idx,
            compile_ok = 0,
            failure_message = local_comp.failure_message,
            code_buf = buf_new(),
            rdata_buf = buf_new(),
            patch_offsets_local = "",
            patch_targets_local = "",
            patch_count_local = 0,
            patch_offsets_local_store = buf_new(),
            patch_targets_local_store = buf_new(),
            rdata_patch_offsets_local = "",
            rdata_patch_targets_local = "",
            rdata_patch_count_local = 0,
            rdata_patch_offsets_local_store = buf_new(),
            rdata_patch_targets_local_store = buf_new(),
            import_patch_offsets_local = "",
            import_patch_targets_local = "",
            import_patch_count_local = 0,
            import_patch_offsets_local_store = buf_new(),
            import_patch_targets_local_store = buf_new()
        }
    }

    // Safety: add epilogue in case body didn't yield
    local_comp.code <- x_xor_reg_reg(local_comp.code, 0, 0)  // xor rax, rax (return 0)
    local_comp.code <- x_mov_reg_reg(local_comp.code, 4, 5)
    local_comp.code <- x_pop_reg(local_comp.code, 5)
    local_comp.code <- x_ret(local_comp.code)

    bind patch_offsets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.patch_offsets)
    bind patch_targets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.patch_targets)
    bind patch_count_local_res :: LookupI64 = u32_store_pair_count_opt(patch_offsets_local_store, patch_targets_local_store)
    bind patch_count_local :: i64 = patch_count_local_res.value
    bind rdata_patch_offsets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.rdata_patch_offsets)
    bind rdata_patch_targets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.rdata_patch_targets)
    bind rdata_patch_count_local_res :: LookupI64 = u32_store_pair_count_opt(rdata_patch_offsets_local_store, rdata_patch_targets_local_store)
    bind rdata_patch_count_local :: i64 = rdata_patch_count_local_res.value
    bind import_patch_offsets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.import_patch_offsets)
    bind import_patch_targets_local_store :: i64 = append_csv_i64_to_u32_store(buf_new(), local_comp.import_patch_targets)
    bind import_patch_count_local_res :: LookupI64 = u32_store_pair_count_opt(import_patch_offsets_local_store, import_patch_targets_local_store)
    bind import_patch_count_local :: i64 = import_patch_count_local_res.value
    yield CompiledFunction{
        fn_idx = plan.fn_idx,
        compile_ok = 1,
        failure_message = "",
        code_buf = local_comp.code,
        rdata_buf = local_comp.rdata,
        patch_offsets_local = local_comp.patch_offsets,
        patch_targets_local = local_comp.patch_targets,
        patch_count_local = patch_count_local,
        patch_offsets_local_store = patch_offsets_local_store,
        patch_targets_local_store = patch_targets_local_store,
        rdata_patch_offsets_local = local_comp.rdata_patch_offsets,
        rdata_patch_targets_local = local_comp.rdata_patch_targets,
        rdata_patch_count_local = rdata_patch_count_local,
        rdata_patch_offsets_local_store = rdata_patch_offsets_local_store,
        rdata_patch_targets_local_store = rdata_patch_targets_local_store,
        import_patch_offsets_local = local_comp.import_patch_offsets,
        import_patch_targets_local = local_comp.import_patch_targets,
        import_patch_count_local = import_patch_count_local,
        import_patch_offsets_local_store = import_patch_offsets_local_store,
        import_patch_targets_local_store = import_patch_targets_local_store
    }
}

flow prepare_planned_compiled_function_result(comp :: Compiler, plan :: FunctionCompilePlan) -> CompiledFunction {
    bind compiled :: CompiledFunction = compile_function_planned(comp, plan)
    bind compiled_validation :: LookupStr = validate_compiled_function_contract(compiled, plan.fn_idx)
    check compiled_validation.found == 0 {
        yield CompiledFunction{
            fn_idx = plan.fn_idx,
            compile_ok = 0,
            failure_message = compiled_validation.value,
            code_buf = buf_new(),
            rdata_buf = buf_new(),
            patch_offsets_local = "",
            patch_targets_local = "",
            patch_count_local = 0,
            patch_offsets_local_store = buf_new(),
            patch_targets_local_store = buf_new(),
            rdata_patch_offsets_local = "",
            rdata_patch_targets_local = "",
            rdata_patch_count_local = 0,
            rdata_patch_offsets_local_store = buf_new(),
            rdata_patch_targets_local_store = buf_new(),
            import_patch_offsets_local = "",
            import_patch_targets_local = "",
            import_patch_count_local = 0,
            import_patch_offsets_local_store = buf_new(),
            import_patch_targets_local_store = buf_new()
        }
    }
    yield compiled
}

flow execute_compiled_function_job(comp :: Compiler, job :: CompiledFunctionJob) -> CompiledFunctionJobResult {
    bind plan :: FunctionCompilePlan = FunctionCompilePlan{
        fn_idx = job.fn_idx,
        param_count = job.param_count,
        param_start = job.param_start,
        body_start = job.body_start,
        body_local_count = job.body_local_count
    }
    bind compiled :: CompiledFunction = prepare_planned_compiled_function_result(comp, plan)
    check compiled.compile_ok == 0 {
        yield CompiledFunctionJobResult{
            fn_idx = job.fn_idx,
            record_ok = 0,
            message = compiled.failure_message,
            code_buf = buf_new(),
            rdata_buf = buf_new(),
            patch_offsets_local = "",
            patch_targets_local = "",
            patch_count_local = 0,
            patch_offsets_local_store = buf_new(),
            patch_targets_local_store = buf_new(),
            rdata_patch_offsets_local = "",
            rdata_patch_targets_local = "",
            rdata_patch_count_local = 0,
            rdata_patch_offsets_local_store = buf_new(),
            rdata_patch_targets_local_store = buf_new(),
            import_patch_offsets_local = "",
            import_patch_targets_local = "",
            import_patch_count_local = 0,
            import_patch_offsets_local_store = buf_new(),
            import_patch_targets_local_store = buf_new(),
            code_start = 0,
            rdata_start = 0,
            code_size = 0,
            rdata_size = 0
        }
    }
    check validate_compiled_function_patch_tables(comp, compiled) == 0 {
        yield CompiledFunctionJobResult{
            fn_idx = job.fn_idx,
            record_ok = 0,
            message = str_concat("cf patch bad ", str_from_i64(job.fn_idx)),
            code_buf = buf_new(),
            rdata_buf = buf_new(),
            patch_offsets_local = "",
            patch_targets_local = "",
            patch_count_local = 0,
            patch_offsets_local_store = buf_new(),
            patch_targets_local_store = buf_new(),
            rdata_patch_offsets_local = "",
            rdata_patch_targets_local = "",
            rdata_patch_count_local = 0,
            rdata_patch_offsets_local_store = buf_new(),
            rdata_patch_targets_local_store = buf_new(),
            import_patch_offsets_local = "",
            import_patch_targets_local = "",
            import_patch_count_local = 0,
            import_patch_offsets_local_store = buf_new(),
            import_patch_targets_local_store = buf_new(),
            code_start = 0,
            rdata_start = 0,
            code_size = 0,
            rdata_size = 0
        }
    }
    bind schedule_entry :: CompiledFunctionScheduleEntry = build_compiled_function_schedule_entry(comp, compiled)
    bind schedule_validation :: LookupStr = validate_compiled_function_schedule_entry(compiled, schedule_entry)
    check schedule_validation.found == 0 {
        yield CompiledFunctionJobResult{
            fn_idx = job.fn_idx,
            record_ok = 0,
            message = schedule_validation.value,
            code_buf = buf_new(),
            rdata_buf = buf_new(),
            patch_offsets_local = "",
            patch_targets_local = "",
            patch_count_local = 0,
            patch_offsets_local_store = buf_new(),
            patch_targets_local_store = buf_new(),
            rdata_patch_offsets_local = "",
            rdata_patch_targets_local = "",
            rdata_patch_count_local = 0,
            rdata_patch_offsets_local_store = buf_new(),
            rdata_patch_targets_local_store = buf_new(),
            import_patch_offsets_local = "",
            import_patch_targets_local = "",
            import_patch_count_local = 0,
            import_patch_offsets_local_store = buf_new(),
            import_patch_targets_local_store = buf_new(),
            code_start = 0,
            rdata_start = 0,
            code_size = 0,
            rdata_size = 0
        }
    }
    yield CompiledFunctionJobResult{
        fn_idx = job.fn_idx,
        record_ok = 1,
        message = "",
        code_buf = compiled.code_buf,
        rdata_buf = compiled.rdata_buf,
        patch_offsets_local = compiled.patch_offsets_local,
        patch_targets_local = compiled.patch_targets_local,
        patch_count_local = compiled.patch_count_local,
        patch_offsets_local_store = compiled.patch_offsets_local_store,
        patch_targets_local_store = compiled.patch_targets_local_store,
        rdata_patch_offsets_local = compiled.rdata_patch_offsets_local,
        rdata_patch_targets_local = compiled.rdata_patch_targets_local,
        rdata_patch_count_local = compiled.rdata_patch_count_local,
        rdata_patch_offsets_local_store = compiled.rdata_patch_offsets_local_store,
        rdata_patch_targets_local_store = compiled.rdata_patch_targets_local_store,
        import_patch_offsets_local = compiled.import_patch_offsets_local,
        import_patch_targets_local = compiled.import_patch_targets_local,
        import_patch_count_local = compiled.import_patch_count_local,
        import_patch_offsets_local_store = compiled.import_patch_offsets_local_store,
        import_patch_targets_local_store = compiled.import_patch_targets_local_store,
        code_start = schedule_entry.code_start,
        rdata_start = schedule_entry.rdata_start,
        code_size = schedule_entry.code_size,
        rdata_size = schedule_entry.rdata_size
    }
}

flow build_compiled_function_job_queue(comp :: Compiler) -> Compiler {
    bind scope :: LayoutScope = make_layout_scope(comp)
    check validate_function_metadata_tables(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "fn meta bad"
        yield comp
    }
    println("D queue+")
    vary i :: i64 = 0
    spin i < scope.user_func_count {
        check comp.failed == 1 {
            yield comp
        }
        bind fn_name_res :: LookupStr = load_function_name_opt(comp, i)
        check fn_name_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn name"
            yield comp
        }
        bind param_count_res :: LookupI64 = load_function_param_count_opt(comp, i)
        check param_count_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn params"
            yield comp
        }
        bind body_start_res :: LookupI64 = load_function_body_start_opt(comp, i)
        check body_start_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn body"
            yield comp
        }
        bind param_start_res :: LookupI64 = load_function_param_start_opt(comp, i)
        check param_start_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn pstart"
            yield comp
        }
        bind local_count_res :: LookupI64 = load_function_local_count_opt(comp, i)
        check local_count_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn locals"
            yield comp
        }
        check scope.user_func_count <= 20 {
            println(str_concat("Q ", fn_name_res.value))
        } otherwise {
            check i % 100 == 0 or i + 1 == scope.user_func_count {
                println(str_concat("Q[", str_concat(str_from_i64(i + 1), str_concat("/", str_concat(str_from_i64(scope.user_func_count), "]")))))
            }
        }
        i <- i + 1
    }
    check validate_compiled_function_job_queue(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf queue invalid"
        yield comp
    }
    println("D queue")
    yield comp
}

flow step_compiled_function_executor(comp :: Compiler) -> Compiler {
    bind scope :: LayoutScope = make_layout_scope(comp)
    check validate_compiled_function_executor(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec invalid"
        yield comp
    }
    check comp.executor_phase == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec idle"
        yield comp
    }
    check comp.executor_phase == 1 {
        check comp.executor_job_cursor == 0 {
            println("D plan+")
        }
        bind job_count :: i64 = compiled_function_executor_job_count(comp)
        check comp.executor_job_cursor >= job_count {
            check validate_compiled_function_schedule_table(comp) == 0 {
                comp.failed <- 1
                comp.failure_message <- "cf sched invalid"
                yield comp
            }
            println("D plan done")
            comp.executor_phase <- 2
            comp.executor_phase_round_count <- 0
            comp.executor_last_slice_budget <- 0
            comp.executor_phase_budget_scale <- 1
            comp.executor_phase_feedback_score <- 2
            comp <- start_apply_user_functions_serial(comp)
            yield comp
        }
        bind job_idx :: i64 = comp.executor_job_cursor
        bind job :: CompiledFunctionJob = load_compiled_function_job_queue_entry(comp, job_idx)
        bind job_name_res :: LookupStr = load_function_name_opt(comp, job_idx)
        check job_name_res.found == 0 or str_eq(job_name_res.value, "") {
            comp.failed <- 1
            comp.failure_message <- "no queue job"
            yield comp
        }
        bind job_result :: CompiledFunctionJobResult = execute_compiled_function_job(comp, job)
        check scope.user_func_count <= 20 {
            println(str_concat("C ", str_concat(job_name_res.value, str_concat(" (", str_concat(str_from_i64(job_result.code_size), "b)")))))
        } otherwise {
            check job_idx % 100 == 0 or job_idx + 1 == job_count {
                println(str_concat("C[", str_concat(str_from_i64(job_idx + 1), str_concat("/", str_concat(str_from_i64(job_count), "]")))))
            }
        }
        check job_result.record_ok == 0 {
            comp.failed <- 1
            comp.failure_message <- job_result.message
            yield comp
        }
        bind compiled :: CompiledFunction = CompiledFunction{
            fn_idx = job_result.fn_idx,
            compile_ok = 1,
            failure_message = "",
            code_buf = job_result.code_buf,
            rdata_buf = job_result.rdata_buf,
            patch_offsets_local = job_result.patch_offsets_local,
            patch_targets_local = job_result.patch_targets_local,
            patch_count_local = job_result.patch_count_local,
            patch_offsets_local_store = job_result.patch_offsets_local_store,
            patch_targets_local_store = job_result.patch_targets_local_store,
            rdata_patch_offsets_local = job_result.rdata_patch_offsets_local,
            rdata_patch_targets_local = job_result.rdata_patch_targets_local,
            rdata_patch_count_local = job_result.rdata_patch_count_local,
            rdata_patch_offsets_local_store = job_result.rdata_patch_offsets_local_store,
            rdata_patch_targets_local_store = job_result.rdata_patch_targets_local_store,
            import_patch_offsets_local = job_result.import_patch_offsets_local,
            import_patch_targets_local = job_result.import_patch_targets_local,
            import_patch_count_local = job_result.import_patch_count_local,
            import_patch_offsets_local_store = job_result.import_patch_offsets_local_store,
            import_patch_targets_local_store = job_result.import_patch_targets_local_store
        }
        bind schedule_entry :: CompiledFunctionScheduleEntry = CompiledFunctionScheduleEntry{
            fn_idx = job_result.fn_idx,
            code_start = job_result.code_start,
            rdata_start = job_result.rdata_start,
            code_size = job_result.code_size,
            rdata_size = job_result.rdata_size
        }
        comp <- record_compiled_function_schedule(comp, schedule_entry)
        comp <- record_compiled_function_artifact(comp, compiled)
        check comp.failed == 1 {
            yield comp
        }
        comp.executor_job_cursor <- job_idx + 1
        check comp.executor_job_cursor >= job_count {
            check validate_compiled_function_schedule_table(comp) == 0 {
                comp.failed <- 1
                comp.failure_message <- "cf sched invalid"
                yield comp
            }
            println("D plan done")
            comp.executor_phase <- 2
            comp.executor_phase_round_count <- 0
            comp.executor_last_slice_budget <- 0
            comp.executor_phase_budget_scale <- 1
            comp.executor_phase_feedback_score <- 2
            comp <- start_apply_user_functions_serial(comp)
        }
        yield comp
    }
    check comp.executor_phase == 2 {
        bind scope :: LayoutScope = make_layout_scope(comp)
        check comp.executor_apply_cursor >= scope.user_func_count {
            comp <- finish_apply_user_functions_serial(comp)
            check comp.failed == 1 {
                yield comp
            }
            comp.executor_phase <- 3
            comp.executor_phase_round_count <- 0
            comp.executor_last_slice_budget <- 0
            comp.executor_phase_budget_scale <- 0
            comp.executor_phase_feedback_score <- 0
            yield comp
        }
        comp <- step_apply_user_functions_serial(comp)
        check comp.failed == 1 {
            yield comp
        }
        check comp.executor_apply_cursor >= scope.user_func_count {
            comp <- finish_apply_user_functions_serial(comp)
            check comp.failed == 1 {
                yield comp
            }
            comp.executor_phase <- 3
            comp.executor_phase_round_count <- 0
            comp.executor_last_slice_budget <- 0
            comp.executor_phase_budget_scale <- 0
            comp.executor_phase_feedback_score <- 0
        }
        yield comp
    }
    yield comp
}

flow run_compiled_function_executor_budget(comp :: Compiler, job_budget :: i64) -> Compiler {
    vary remaining_jobs :: i64 = job_budget
    check validate_compiled_function_executor(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec invalid"
        yield comp
    }
    check remaining_jobs <= 0 {
        yield comp
    }
    spin compiled_function_executor_done(comp) == 0 {
        check comp.failed == 1 {
            yield comp
        }
        check remaining_jobs <= 0 and compiled_function_executor_pending_jobs(comp) > 0 {
            yield comp
        }
        bind phase_before :: i64 = comp.executor_phase
        bind cursor_before :: i64 = comp.executor_job_cursor
        bind apply_cursor_before :: i64 = comp.executor_apply_cursor
        comp <- step_compiled_function_executor(comp)
        check comp.failed == 1 {
            yield comp
        }
        check phase_before == 1 and comp.executor_job_cursor > cursor_before {
            remaining_jobs <- remaining_jobs - (comp.executor_job_cursor - cursor_before)
        }
        check phase_before == 2 and comp.executor_apply_cursor > apply_cursor_before {
            remaining_jobs <- remaining_jobs - (comp.executor_apply_cursor - apply_cursor_before)
        }
    }
    yield comp
}

flow run_compiled_function_executor(comp :: Compiler) -> Compiler {
    bind scheduler :: CompiledFunctionExecutorScheduler = configured_compiled_function_executor_scheduler(comp)
    println("D exec+")
    spin compiled_function_executor_done(comp) == 0 {
        check comp.failed == 1 {
            yield comp
        }
        bind slice_budget :: i64 = pick_compiled_function_executor_slice_budget(comp, scheduler)
        check slice_budget <= 0 {
            check compiled_function_executor_done(comp) == 0 {
                comp.failed <- 1
                comp.failure_message <- "cf exec stall"
                yield comp
            }
            yield comp
        }
        bind phase_before :: i64 = comp.executor_phase
        bind cursor_before :: i64 = comp.executor_job_cursor
        bind apply_cursor_before :: i64 = comp.executor_apply_cursor
        comp.executor_total_round_count <- comp.executor_total_round_count + 1
        comp.executor_phase_round_count <- comp.executor_phase_round_count + 1
        comp.executor_last_slice_budget <- slice_budget
        comp <- run_compiled_function_executor_budget(comp, slice_budget)
        check comp.failed == 1 {
            yield comp
        }
        vary completed_jobs :: i64 = 0
        check phase_before == comp.executor_phase {
            check phase_before == 1 and comp.executor_job_cursor > cursor_before {
                completed_jobs <- comp.executor_job_cursor - cursor_before
            } otherwise {
                check phase_before == 2 and comp.executor_apply_cursor > apply_cursor_before {
                    completed_jobs <- comp.executor_apply_cursor - apply_cursor_before
                }
            }
        }
        comp.executor_last_round_completed_jobs <- completed_jobs
        comp <- update_compiled_function_executor_budget_scale(comp, scheduler, phase_before, slice_budget)
        check comp.failed == 1 {
            yield comp
        }
    }
    check validate_compiled_function_executor(comp) == 0 {
        comp.failed <- 1
        comp.failure_message <- "cf exec invalid"
        yield comp
    }
    bind main_idx_res :: LookupI64 = find_func_opt(comp, "main")
    check main_idx_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "no main"
        yield comp
    }
    bind main_off_res :: LookupI64 = load_effective_function_offset_opt(comp, main_idx_res.value)
    check main_off_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "main off bad"
        yield comp
    }
    comp.final_main_code_offset <- main_off_res.value
    check validate_final_layout_contract(comp, main_idx_res.value, main_off_res.value, buf_len(comp.code)) == 0 {
        comp.failed <- 1
        comp.failure_message <- "layout bad"
        yield comp
    }
    println("D exec done")
    yield comp
}

flow start_apply_user_functions_serial(comp :: Compiler) -> Compiler {
    bind scope :: LayoutScope = make_layout_scope(comp)
    bind total_function_count :: i64 = function_name_count(comp)
    check buf_len(comp.fn_schedule_code_starts) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "cf c len bad"
        yield comp
    }
    check buf_len(comp.fn_schedule_rdata_starts) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "cf r len bad"
        yield comp
    }
    check buf_len(comp.fn_schedule_code_sizes) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "cf cs len bad"
        yield comp
    }
    check buf_len(comp.fn_schedule_rdata_sizes) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "cf rs len bad"
        yield comp
    }
    check buf_len(comp.fn_artifact_patch_offsets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art p0 len"
        yield comp
    }
    check buf_len(comp.fn_artifact_patch_targets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art pc len"
        yield comp
    }
    check buf_len(comp.fn_artifact_rdata_patch_offsets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art r0 len"
        yield comp
    }
    check buf_len(comp.fn_artifact_rdata_patch_targets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art rc len"
        yield comp
    }
    check buf_len(comp.fn_artifact_import_patch_offsets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art i0 len"
        yield comp
    }
    check buf_len(comp.fn_artifact_import_patch_targets) != scope.user_func_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "art ic len"
        yield comp
    }
    bind patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_patch_offset_store, comp.fn_artifact_patch_target_store)
    bind rdata_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_rdata_patch_offset_store, comp.fn_artifact_rdata_patch_target_store)
    bind import_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_import_patch_offset_store, comp.fn_artifact_import_patch_target_store)
    check patch_store_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art p store"
        yield comp
    }
    check rdata_patch_store_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art r store"
        yield comp
    }
    check import_patch_store_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "art i store"
        yield comp
    }
    vary expected_patch_start :: i64 = 0
    vary expected_rdata_patch_start :: i64 = 0
    vary expected_import_patch_start :: i64 = 0
    vary art_idx :: i64 = 0
    spin art_idx < scope.user_func_count {
        bind patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_offsets, art_idx)
        bind patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_targets, art_idx)
        bind rdata_patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_offsets, art_idx)
        bind rdata_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_targets, art_idx)
        bind import_patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_offsets, art_idx)
        bind import_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_targets, art_idx)
        check patch_start_res.found == 0 or patch_count_res.found == 0 or rdata_patch_start_res.found == 0 or rdata_patch_count_res.found == 0 or import_patch_start_res.found == 0 or import_patch_count_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "art p hdr"
            yield comp
        }
        bind patch_start :: i64 = patch_start_res.value
        bind patch_count :: i64 = patch_count_res.value
        bind rdata_patch_start :: i64 = rdata_patch_start_res.value
        bind rdata_patch_count :: i64 = rdata_patch_count_res.value
        bind import_patch_start :: i64 = import_patch_start_res.value
        bind import_patch_count :: i64 = import_patch_count_res.value
        check patch_start != expected_patch_start {
            comp.failed <- 1
            comp.failure_message <- "art p hdr"
            yield comp
        }
        check rdata_patch_start != expected_rdata_patch_start {
            comp.failed <- 1
            comp.failure_message <- "art r hdr"
            yield comp
        }
        check import_patch_start != expected_import_patch_start {
            comp.failed <- 1
            comp.failure_message <- "art i hdr"
            yield comp
        }
        check patch_start + patch_count > patch_store_count_res.value {
            comp.failed <- 1
            comp.failure_message <- "art p span"
            yield comp
        }
        check rdata_patch_start + rdata_patch_count > rdata_patch_store_count_res.value {
            comp.failed <- 1
            comp.failure_message <- "art r span"
            yield comp
        }
        check import_patch_start + import_patch_count > import_patch_store_count_res.value {
            comp.failed <- 1
            comp.failure_message <- "art i span"
            yield comp
        }
        expected_patch_start <- patch_start + patch_count
        expected_rdata_patch_start <- rdata_patch_start + rdata_patch_count
        expected_import_patch_start <- import_patch_start + import_patch_count
        art_idx <- art_idx + 1
    }
    check expected_patch_start != patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "art p total"
        yield comp
    }
    check expected_rdata_patch_start != rdata_patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "art r total"
        yield comp
    }
    check expected_import_patch_start != import_patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "art i total"
        yield comp
    }
    vary effective_offsets :: i64 = buf_new()
    vary user_idx :: i64 = 0
    spin user_idx < scope.user_func_count {
        bind user_off_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, user_idx)
        check user_off_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "cf c len bad"
            yield comp
        }
        effective_offsets <- emit_u32(effective_offsets, user_off_res.value)
        user_idx <- user_idx + 1
    }
    vary builtin_idx :: i64 = 0
    bind builtin_count :: i64 = builtin_function_count()
    spin builtin_idx < builtin_count {
        bind builtin_off_res :: LookupI64 = load_builtin_offset_opt(comp, builtin_idx)
        check builtin_off_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no builtin off"
            yield comp
        }
        effective_offsets <- emit_u32(effective_offsets, builtin_off_res.value)
        builtin_idx <- builtin_idx + 1
    }
    println("D apply+")
    check buf_len(effective_offsets) != total_function_count * 4 {
        comp.failed <- 1
        comp.failure_message <- "eff off len bad"
        yield comp
    }
    comp.executor_apply_cursor <- 0
    comp.executor_effective_offsets <- effective_offsets
    comp.final_effective_offsets <- effective_offsets
    yield comp
}

flow step_apply_user_functions_serial(comp :: Compiler) -> Compiler {
    bind scope :: LayoutScope = make_layout_scope(comp)
    bind i :: i64 = comp.executor_apply_cursor
    check i >= scope.user_func_count {
        yield comp
    }
    vary fn_name :: str = ""
    check scope.user_func_count <= 20 {
        bind fn_name_res :: LookupStr = load_function_name_opt(comp, i)
        check fn_name_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "no fn name apply"
            yield comp
        }
        fn_name <- fn_name_res.value
    }
    bind code_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, i)
    bind rdata_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_starts, i)
    bind code_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_sizes, i)
    bind rdata_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_sizes, i)
    bind patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_offsets, i)
    bind patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_targets, i)
    bind rdata_patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_offsets, i)
    bind rdata_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_targets, i)
    bind import_patch_start_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_offsets, i)
    bind import_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_targets, i)
    check code_start_res.found == 0 or code_size_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "apply c bad"
        yield comp
    }
    check rdata_start_res.found == 0 or rdata_size_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "apply r bad"
        yield comp
    }
    check patch_start_res.found == 0 or patch_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "apply p span"
        yield comp
    }
    check rdata_patch_start_res.found == 0 or rdata_patch_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "apply r span"
        yield comp
    }
    check import_patch_start_res.found == 0 or import_patch_count_res.found == 0 {
        comp.failed <- 1
        comp.failure_message <- "apply i span"
        yield comp
    }
    bind code_start :: i64 = code_start_res.value
    bind rdata_start :: i64 = rdata_start_res.value
    bind code_size :: i64 = code_size_res.value
    bind rdata_size :: i64 = rdata_size_res.value
    bind patch_start :: i64 = patch_start_res.value
    bind patch_count :: i64 = patch_count_res.value
    bind rdata_patch_start :: i64 = rdata_patch_start_res.value
    bind rdata_patch_count :: i64 = rdata_patch_count_res.value
    bind import_patch_start :: i64 = import_patch_start_res.value
    bind import_patch_count :: i64 = import_patch_count_res.value
    bind patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_patch_offset_store, comp.fn_artifact_patch_target_store)
    bind rdata_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_rdata_patch_offset_store, comp.fn_artifact_rdata_patch_target_store)
    bind import_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_import_patch_offset_store, comp.fn_artifact_import_patch_target_store)
    check patch_store_count_res.found == 0 or patch_start + patch_count > patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "apply p span"
        yield comp
    }
    check rdata_patch_store_count_res.found == 0 or rdata_patch_start + rdata_patch_count > rdata_patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "apply r span"
        yield comp
    }
    check import_patch_store_count_res.found == 0 or import_patch_start + import_patch_count > import_patch_store_count_res.value {
        comp.failed <- 1
        comp.failure_message <- "apply i span"
        yield comp
    }
    check code_start + code_size > buf_len(comp.code) {
        comp.failed <- 1
        comp.failure_message <- "apply c bad"
        yield comp
    }
    check rdata_start + rdata_size > buf_len(comp.rdata) {
        comp.failed <- 1
        comp.failure_message <- "apply r bad"
        yield comp
    }
    vary pi :: i64 = 0
    vary patch_pos :: i64 = patch_start
    spin pi < patch_count {
        bind patch_offset_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_offset_store, patch_pos)
        bind patch_target_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_target_store, patch_pos)
        check patch_offset_res.found == 0 or patch_target_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "apply p span"
            yield comp
        }
        bind patch_offset :: i64 = patch_offset_res.value
        bind patch_target :: i64 = patch_target_res.value
        check patch_offset + 3 >= code_size {
            comp.failed <- 1
            comp.failure_message <- "apply p off"
            yield comp
        }
        bind target_off_res :: LookupI64 = load_u32_store_opt(comp.executor_effective_offsets, patch_target)
        check target_off_res.found == 0 {
            comp.failed <- 1
            comp.failure_message <- "apply p tgt"
            yield comp
        }
        bind target_off :: i64 = target_off_res.value
        bind applied_patch_offset :: i64 = code_start + patch_offset
        comp.patch_offsets_store <- emit_u32(comp.patch_offsets_store, applied_patch_offset)
        comp.patch_targets_store <- emit_u32(comp.patch_targets_store, target_off)
        patch_pos <- patch_pos + 1
        pi <- pi + 1
    }
    vary ri :: i64 = 0
    vary ii :: i64 = 0
    vary rdata_patch_pos :: i64 = rdata_patch_start
    vary import_patch_pos :: i64 = import_patch_start
    bind rdata_rva_base :: i64 = pe_rdata_rva() + rdata_start
    spin ri < rdata_patch_count or ii < import_patch_count {
        vary use_rdata_patch :: i64 = 0
        vary patch_off_local :: i64 = 0
        vary target_rva :: i64 = 0
        vary next_rdata_patch_off :: i64 = 0
        vary next_rdata_target_off :: i64 = 0
        vary next_import_patch_off :: i64 = 0
        vary next_import_target :: i64 = 0
        check ri < rdata_patch_count {
            bind next_rdata_patch_off_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_offset_store, rdata_patch_pos)
            bind next_rdata_target_off_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_target_store, rdata_patch_pos)
            check next_rdata_patch_off_res.found == 0 or next_rdata_target_off_res.found == 0 {
                comp.failed <- 1
                comp.failure_message <- "apply r span"
                yield comp
            }
            next_rdata_patch_off <- next_rdata_patch_off_res.value
            next_rdata_target_off <- next_rdata_target_off_res.value
            use_rdata_patch <- 1
        }
        check ii < import_patch_count {
            bind next_import_patch_off_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_offset_store, import_patch_pos)
            bind next_import_target_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_target_store, import_patch_pos)
            check next_import_patch_off_res.found == 0 or next_import_target_res.found == 0 {
                comp.failed <- 1
                comp.failure_message <- "apply i span"
                yield comp
            }
            next_import_patch_off <- next_import_patch_off_res.value
            next_import_target <- next_import_target_res.value
            check ri >= rdata_patch_count or next_import_patch_off < next_rdata_patch_off {
                use_rdata_patch <- 0
            }
        }
        check use_rdata_patch == 1 {
            check next_rdata_patch_off + 3 >= code_size {
                comp.failed <- 1
                comp.failure_message <- "apply r off"
                yield comp
            }
            check next_rdata_target_off >= rdata_size {
                comp.failed <- 1
                comp.failure_message <- "apply r tgt"
                yield comp
            }
            patch_off_local <- next_rdata_patch_off
            target_rva <- rdata_rva_base + next_rdata_target_off
            rdata_patch_pos <- rdata_patch_pos + 1
            ri <- ri + 1
        } otherwise {
            check next_import_patch_off + 3 >= code_size {
                comp.failed <- 1
                comp.failure_message <- "apply i off"
                yield comp
            }
            check next_import_target >= import_slot_count() {
                comp.failed <- 1
                comp.failure_message <- "apply i tgt"
                yield comp
            }
            patch_off_local <- next_import_patch_off
            target_rva <- iat_rva(next_import_target)
            import_patch_pos <- import_patch_pos + 1
            ii <- ii + 1
        }
        bind applied_patch_offset :: i64 = code_start + patch_off_local
        comp.rip_patch_offsets_store <- emit_u32(comp.rip_patch_offsets_store, applied_patch_offset)
        comp.rip_patch_targets_store <- emit_u32(comp.rip_patch_targets_store, target_rva)
    }
    check scope.user_func_count <= 20 {
        println(str_concat("Applied: ", fn_name))
    } otherwise {
        check i % 100 == 0 or i + 1 == scope.user_func_count {
            println(str_concat("A[", str_concat(str_from_i64(i + 1), str_concat("/", str_concat(str_from_i64(scope.user_func_count), "]")))))
        }
    }
    comp.executor_apply_cursor <- i + 1
    yield comp
}

flow finish_apply_user_functions_serial(comp :: Compiler) -> Compiler {
    check buf_len(comp.code) != compiled_function_schedule_code_end(comp) {
        comp.failed <- 1
        comp.failure_message <- "final c bad"
        yield comp
    }
    check buf_len(comp.rdata) != compiled_function_schedule_rdata_end(comp) {
        comp.failed <- 1
        comp.failure_message <- "final r bad"
        yield comp
    }
    println("D apply done")
    yield comp
}

flow compile_user_functions_serial(comp :: Compiler) -> Compiler {
    bind scheduler :: CompiledFunctionExecutorScheduler = pick_compiled_function_executor_scheduler(comp)
    comp <- reset_compiled_function_schedule_table(comp)
    comp <- reset_compiled_function_job_queue(comp)
    comp <- reset_compiled_function_executor(comp)
    comp.final_main_code_offset <- 0
    comp.final_effective_offsets <- buf_new()
    comp <- build_compiled_function_job_queue(comp)
    check comp.failed == 1 {
        yield comp
    }
    comp <- configure_compiled_function_executor_scheduler(comp, scheduler)
    comp <- start_compiled_function_executor(comp)
    check comp.failed == 1 {
        yield comp
    }
    comp <- run_compiled_function_executor(comp)
    check comp.failed == 1 {
        yield comp
    }
    println("D loop done")
    yield comp
}

flow validate_compiled_function_schedule_table(comp :: Compiler) -> i64 {
    bind scope :: LayoutScope = make_layout_scope(comp)
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        println("E cf sched cstart len")
        yield 0
    }
    bind schedule_count :: i64 = schedule_count_res.value
    check schedule_count != scope.user_func_count {
        println(str_concat("E cf sched count ", str_concat(str_from_i64(scope.user_func_count), str_concat("/", str_from_i64(schedule_count)))))
        yield 0
    }
    check buf_len(comp.fn_schedule_code_starts) != schedule_count * 4 {
        println("E cf sched cstart len")
        yield 0
    }
    check buf_len(comp.fn_schedule_rdata_starts) != schedule_count * 4 {
        println("E cf sched rstart len")
        yield 0
    }
    check buf_len(comp.fn_schedule_code_sizes) != schedule_count * 4 {
        println("E cf sched csize len")
        yield 0
    }
    check buf_len(comp.fn_schedule_rdata_sizes) != schedule_count * 4 {
        println("E cf sched rsize len")
        yield 0
    }
    check buf_len(comp.fn_artifact_patch_offsets) != schedule_count * 4 or buf_len(comp.fn_artifact_patch_targets) != schedule_count * 4 {
        println("E cf art p hdr len")
        yield 0
    }
    check buf_len(comp.fn_artifact_rdata_patch_offsets) != schedule_count * 4 or buf_len(comp.fn_artifact_rdata_patch_targets) != schedule_count * 4 {
        println("E cf art r hdr len")
        yield 0
    }
    check buf_len(comp.fn_artifact_import_patch_offsets) != schedule_count * 4 or buf_len(comp.fn_artifact_import_patch_targets) != schedule_count * 4 {
        println("E cf art i hdr len")
        yield 0
    }
    bind patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_patch_offset_store, comp.fn_artifact_patch_target_store)
    bind rdata_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_rdata_patch_offset_store, comp.fn_artifact_rdata_patch_target_store)
    bind import_patch_store_count_res :: LookupI64 = u32_store_pair_count_opt(comp.fn_artifact_import_patch_offset_store, comp.fn_artifact_import_patch_target_store)
    check patch_store_count_res.found == 0 {
        println("E cf art p store len")
        yield 0
    }
    check rdata_patch_store_count_res.found == 0 {
        println("E cf art r store len")
        yield 0
    }
    check import_patch_store_count_res.found == 0 {
        println("E cf art i store len")
        yield 0
    }

    vary si :: i64 = 0
    vary prev_code_end :: i64 = 0
    vary prev_rdata_end :: i64 = 0
    spin si < scope.user_func_count {
        bind code_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, si)
        bind rdata_start_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_starts, si)
        bind code_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_sizes, si)
        bind rdata_size_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_rdata_sizes, si)
        check code_start_res.found == 0 or rdata_start_res.found == 0 or code_size_res.found == 0 or rdata_size_res.found == 0 {
            println("E cf sched cstart len")
            yield 0
        }
        bind code_start :: i64 = code_start_res.value
        bind rdata_start :: i64 = rdata_start_res.value
        bind code_size :: i64 = code_size_res.value
        bind rdata_size :: i64 = rdata_size_res.value
        check code_size < 0 or rdata_size < 0 {
            println(str_concat("E cf neg size ", str_from_i64(si)))
            yield 0
        }
        check si > 0 and code_start != prev_code_end {
            println(str_concat("E cf code gap ", str_from_i64(si)))
            yield 0
        }
        check si > 0 and rdata_start != prev_rdata_end {
            println(str_concat("E cf rdata gap ", str_from_i64(si)))
            yield 0
        }
        prev_code_end <- code_start + code_size
        prev_rdata_end <- rdata_start + rdata_size
        si <- si + 1
    }
    yield 1
}

flow validate_compiled_function_patch_tables(comp :: Compiler, compiled :: CompiledFunction) -> i64 {
    bind patch_count :: i64 = compiled.patch_count_local
    bind rdata_patch_count :: i64 = compiled.rdata_patch_count_local
    bind import_patch_count :: i64 = compiled.import_patch_count_local
    bind total_function_count :: i64 = function_name_count(comp)
    bind patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.patch_offsets_local_store)
    bind patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.patch_targets_local_store)
    bind rdata_patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.rdata_patch_offsets_local_store)
    bind rdata_patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.rdata_patch_targets_local_store)
    bind import_patch_offset_store_count_res :: LookupI64 = u32_store_count_opt(compiled.import_patch_offsets_local_store)
    bind import_patch_target_store_count_res :: LookupI64 = u32_store_count_opt(compiled.import_patch_targets_local_store)
    check buf_len(compiled.patch_offsets_local_store) != patch_count * 4 or buf_len(compiled.patch_targets_local_store) != patch_count * 4 {
        println(str_concat("E patch count fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }
    check buf_len(compiled.rdata_patch_offsets_local_store) != rdata_patch_count * 4 or buf_len(compiled.rdata_patch_targets_local_store) != rdata_patch_count * 4 {
        println(str_concat("E rdata count fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }
    check buf_len(compiled.import_patch_offsets_local_store) != import_patch_count * 4 or buf_len(compiled.import_patch_targets_local_store) != import_patch_count * 4 {
        println(str_concat("E import count fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }
    check patch_offset_store_count_res.found == 0 or patch_target_store_count_res.found == 0 or patch_offset_store_count_res.value != patch_count or patch_target_store_count_res.value != patch_count {
        println(str_concat("E patch align fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }
    check rdata_patch_offset_store_count_res.found == 0 or rdata_patch_target_store_count_res.found == 0 or rdata_patch_offset_store_count_res.value != rdata_patch_count or rdata_patch_target_store_count_res.value != rdata_patch_count {
        println(str_concat("E rdata align fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }
    check import_patch_offset_store_count_res.found == 0 or import_patch_target_store_count_res.found == 0 or import_patch_offset_store_count_res.value != import_patch_count or import_patch_target_store_count_res.value != import_patch_count {
        println(str_concat("E import align fn ", str_from_i64(compiled.fn_idx)))
        yield 0
    }

    vary pi :: i64 = 0
    spin pi < patch_count {
        bind patch_offset_res :: LookupI64 = load_u32_store_opt(compiled.patch_offsets_local_store, pi)
        check patch_offset_res.found == 0 {
            println(str_concat("E patch entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        bind patch_target_res :: LookupI64 = load_u32_store_opt(compiled.patch_targets_local_store, pi)
        check patch_target_res.found == 0 {
            println(str_concat("E patch entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check patch_offset_res.value < 0 or patch_offset_res.value + 3 >= buf_len(compiled.code_buf) {
            println(str_concat("E patch off fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check patch_target_res.value < 0 or patch_target_res.value >= total_function_count {
            println(str_concat("E patch tgt fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        pi <- pi + 1
    }

    vary ri :: i64 = 0
    spin ri < rdata_patch_count {
        bind rdata_patch_offset_res :: LookupI64 = load_u32_store_opt(compiled.rdata_patch_offsets_local_store, ri)
        check rdata_patch_offset_res.found == 0 {
            println(str_concat("E rdata entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        bind rdata_patch_target_res :: LookupI64 = load_u32_store_opt(compiled.rdata_patch_targets_local_store, ri)
        check rdata_patch_target_res.found == 0 {
            println(str_concat("E rdata entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check rdata_patch_offset_res.value < 0 or rdata_patch_offset_res.value + 3 >= buf_len(compiled.code_buf) {
            println(str_concat("E rdata off fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check rdata_patch_target_res.value < 0 or rdata_patch_target_res.value >= buf_len(compiled.rdata_buf) {
            println(str_concat("E rdata tgt fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        ri <- ri + 1
    }

    vary ii :: i64 = 0
    spin ii < import_patch_count {
        bind import_patch_offset_res :: LookupI64 = load_u32_store_opt(compiled.import_patch_offsets_local_store, ii)
        check import_patch_offset_res.found == 0 {
            println(str_concat("E import entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        bind import_patch_target_res :: LookupI64 = load_u32_store_opt(compiled.import_patch_targets_local_store, ii)
        check import_patch_target_res.found == 0 {
            println(str_concat("E import entry fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check import_patch_offset_res.value < 0 or import_patch_offset_res.value + 3 >= buf_len(compiled.code_buf) {
            println(str_concat("E import off fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        check import_patch_target_res.value < 0 or import_patch_target_res.value >= import_slot_count() {
            println(str_concat("E import tgt fn ", str_from_i64(compiled.fn_idx)))
            yield 0
        }
        ii <- ii + 1
    }

    yield 1
}

flow validate_compiled_function_offsets(comp :: Compiler) -> i64 {
    vary fn_idx :: i64 = 0
    bind total_function_count :: i64 = effective_function_offset_count(comp)
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        yield 0
    }
    bind schedule_count :: i64 = schedule_count_res.value
    bind code_len :: i64 = buf_len(comp.code)
    spin fn_idx < total_function_count {
        bind offset_res :: LookupI64 = load_effective_function_offset_opt(comp, fn_idx)
        check offset_res.found == 0 {
            println(str_concat("E missing fn off ", str_from_i64(fn_idx)))
            yield 0
        }
        check offset_res.value < 0 or offset_res.value > code_len {
            println(str_concat("E fn off idx ", str_from_i64(fn_idx)))
            yield 0
        }
        check fn_idx < schedule_count {
            bind sched_off_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, fn_idx)
            check sched_off_res.found == 0 or offset_res.value != sched_off_res.value {
                println(str_concat("E fn off user ", str_from_i64(fn_idx)))
                yield 0
            }
        } otherwise {
            bind builtin_off_res :: LookupI64 = load_builtin_offset_opt(comp, fn_idx - schedule_count)
            check builtin_off_res.found == 0 or offset_res.value != builtin_off_res.value {
                yield 0
            }
        }
        fn_idx <- fn_idx + 1
    }

    yield 1
}

flow validate_final_patch_totals(comp :: Compiler) -> i64 {
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        yield 0
    }
    bind schedule_count :: i64 = schedule_count_res.value
    bind final_patch_count_res :: LookupI64 = u32_store_count_opt(comp.patch_offsets_store)
    bind final_patch_target_count_res :: LookupI64 = u32_store_count_opt(comp.patch_targets_store)
    bind final_rip_patch_count_res :: LookupI64 = u32_store_count_opt(comp.rip_patch_offsets_store)
    bind final_rip_patch_target_count_res :: LookupI64 = u32_store_count_opt(comp.rip_patch_targets_store)
    check final_patch_count_res.found == 0 or final_patch_target_count_res.found == 0 {
        yield 0
    }
    check final_rip_patch_count_res.found == 0 or final_rip_patch_target_count_res.found == 0 {
        yield 0
    }
    vary expected_patch_count :: i64 = 0
    vary expected_rip_patch_count :: i64 = 0
    vary si :: i64 = 0
    spin si < schedule_count {
        bind patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_patch_targets, si)
        bind rdata_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_rdata_patch_targets, si)
        bind import_patch_count_res :: LookupI64 = load_u32_store_opt(comp.fn_artifact_import_patch_targets, si)
        check patch_count_res.found == 0 or rdata_patch_count_res.found == 0 or import_patch_count_res.found == 0 {
            yield 0
        }
        expected_patch_count <- expected_patch_count + patch_count_res.value
        expected_rip_patch_count <- expected_rip_patch_count + rdata_patch_count_res.value + import_patch_count_res.value
        si <- si + 1
    }
    check final_patch_count_res.value != expected_patch_count or final_patch_target_count_res.value != expected_patch_count {
        yield 0
    }
    check final_rip_patch_count_res.value != expected_rip_patch_count or final_rip_patch_target_count_res.value != expected_rip_patch_count {
        yield 0
    }
    yield 1
}

flow validate_final_patch_table(comp :: Compiler, entry_offset :: i64) -> i64 {
    bind patch_count_res :: LookupI64 = u32_store_pair_count_opt(comp.patch_offsets_store, comp.patch_targets_store)
    check patch_count_res.found == 0 {
        println("E final patch align")
        yield 0
    }
    bind patch_count :: i64 = patch_count_res.value
    vary pi :: i64 = 0
    spin pi < patch_count {
        bind patch_off_res :: LookupI64 = load_u32_store_opt(comp.patch_offsets_store, pi)
        bind target_off_res :: LookupI64 = load_u32_store_opt(comp.patch_targets_store, pi)
        check patch_off_res.found == 0 or target_off_res.found == 0 {
            println("E final patch entry")
            yield 0
        }
        check patch_off_res.value < 0 or patch_off_res.value + 3 >= entry_offset {
            println("E final patch off")
            yield 0
        }
        check target_off_res.value < 0 or target_off_res.value >= entry_offset {
            println("E final patch tgt")
            yield 0
        }
        check is_known_function_offset(comp, target_off_res.value) == 0 {
            println("E final patch tgt fn")
            yield 0
        }
        pi <- pi + 1
    }
    yield 1
}

flow validate_final_rip_patch_table(comp :: Compiler, entry_offset :: i64) -> i64 {
    bind rip_patch_count_res :: LookupI64 = u32_store_pair_count_opt(comp.rip_patch_offsets_store, comp.rip_patch_targets_store)
    check rip_patch_count_res.found == 0 {
        println("E final rip align")
        yield 0
    }
    bind rip_patch_count :: i64 = rip_patch_count_res.value
    vary rpi :: i64 = 0
    spin rpi < rip_patch_count {
        bind patch_off_res :: LookupI64 = load_u32_store_opt(comp.rip_patch_offsets_store, rpi)
        bind target_rva_res :: LookupI64 = load_u32_store_opt(comp.rip_patch_targets_store, rpi)
        check patch_off_res.found == 0 or target_rva_res.found == 0 {
            println("E final rip entry")
            yield 0
        }
        check patch_off_res.value < 0 or patch_off_res.value + 3 >= entry_offset {
            println("E final rip off")
            yield 0
        }
        check is_known_rip_patch_target_rva(comp, target_rva_res.value) == 0 {
            println("E final rip tgt")
            yield 0
        }
        rpi <- rpi + 1
    }
    yield 1
}

flow validate_final_layout_contract(comp :: Compiler, main_idx :: i64, main_code_offset :: i64, entry_offset :: i64) -> i64 {
    bind total_function_count :: i64 = effective_function_offset_count(comp)
    bind schedule_count_res :: LookupI64 = compiled_function_schedule_count_opt(comp)
    check schedule_count_res.found == 0 {
        yield 0
    }
    bind schedule_count :: i64 = schedule_count_res.value
    bind builtin_count :: i64 = builtin_function_count()
    bind final_count_res :: LookupI64 = u32_store_count_opt(comp.final_effective_offsets)
    bind exec_count_res :: LookupI64 = u32_store_count_opt(comp.executor_effective_offsets)
    check validate_compiled_function_schedule_table(comp) == 0 {
        println("E final sched")
        yield 0
    }
    bind schedule_code_end :: i64 = compiled_function_schedule_code_end(comp)
    bind schedule_rdata_end :: i64 = compiled_function_schedule_rdata_end(comp)
    check buf_len(comp.builtin_offset_store) != builtin_count * 4 {
        yield 0
    }
    check buf_len(comp.fn_schedule_code_starts) != schedule_count * 4 {
        yield 0
    }
    check function_name_count(comp) != schedule_count + builtin_count {
        println("E final eff total")
        yield 0
    }
    check entry_offset != buf_len(comp.code) or schedule_code_end != entry_offset or schedule_rdata_end != buf_len(comp.rdata) {
        yield 0
    }
    check buf_len(comp.final_effective_offsets) == 0 or final_count_res.found == 0 or final_count_res.value != total_function_count {
        println("E final eff")
        yield 0
    }
    check buf_len(comp.executor_effective_offsets) > 0 and (exec_count_res.found == 0 or exec_count_res.value != total_function_count) {
        println("E final exec eff")
        yield 0
    }
    check buf_len(comp.executor_effective_offsets) > 0 {
        vary exec_idx :: i64 = 0
        spin exec_idx < total_function_count {
            bind exec_off_res :: LookupI64 = load_u32_store_opt(comp.executor_effective_offsets, exec_idx)
            check exec_off_res.found == 0 {
                yield 0
            }
            check exec_idx < schedule_count {
                bind sched_off_res :: LookupI64 = load_u32_store_opt(comp.fn_schedule_code_starts, exec_idx)
                check sched_off_res.found == 0 or exec_off_res.value != sched_off_res.value {
                    yield 0
                }
            } otherwise {
                bind builtin_off_res :: LookupI64 = load_builtin_offset_opt(comp, exec_idx - schedule_count)
                check builtin_off_res.found == 0 or exec_off_res.value != builtin_off_res.value {
                    yield 0
                }
            }
            exec_idx <- exec_idx + 1
        }
    }
    check validate_compiled_function_offsets(comp) == 0 or validate_final_patch_totals(comp) == 0 {
        println("E final offs")
        yield 0
    }
    check main_idx < 0 or main_idx >= schedule_count {
        println("E final main idx")
        yield 0
    }
    bind main_off_res :: LookupI64 = load_effective_function_offset_opt(comp, main_idx)
    check main_off_res.found == 0 {
        println("E final main miss")
        yield 0
    }
    check main_off_res.value != main_code_offset or main_code_offset < 0 or main_code_offset >= entry_offset {
        println("E final main off")
        yield 0
    }
    check validate_final_patch_table(comp, entry_offset) == 0 {
        yield 0
    }
    check validate_final_rip_patch_table(comp, entry_offset) == 0 {
        yield 0
    }
    yield 1
}

// ==================================================================
// SECTION 7: PE FILE BUILDER (with msvcrt.dll imports)
// ==================================================================

flow x_call_iat(buf :: i64, iat_slot_rva :: i64, current_code_off :: i64) -> i64 {
    vary b :: i64 = buf
    bind text_rva :: i64 = pe_text_rva()
    bind rip_after :: i64 = text_rva + current_code_off + 6
    bind disp :: i64 = iat_slot_rva - rip_after
    b <- buf_push(b, 255)  // FF
    b <- buf_push(b, 21)   // 15 = call [rip + disp32]
    b <- emit_u32(b, disp)
    yield b
}

flow emit_runtime_import_call(code :: i64, import_slot :: i64) -> i64 {
    yield x_call_iat(code, iat_rva(import_slot), buf_len(code))
}

flow empty_code_import_patch_state(code :: i64) -> CodeImportPatchState {
    yield CodeImportPatchState{ code = code, import_patch_offsets = "", import_patch_targets = "" }
}

flow emit_deferred_runtime_import_call(state :: CodeImportPatchState, import_slot :: i64) -> CodeImportPatchState {
    vary out :: CodeImportPatchState = state
    bind patch_off :: i64 = buf_len(out.code) + 2
    out.code <- x_call_iat(out.code, 0, 0)
    out.import_patch_offsets <- csv_append(out.import_patch_offsets, str_from_i64(patch_off))
    out.import_patch_targets <- csv_append(out.import_patch_targets, str_from_i64(import_slot))
    yield out
}

flow append_deferred_runtime_import_patches(comp :: Compiler, state :: CodeImportPatchState) -> Compiler {
    vary out :: Compiler = comp
    out.import_patch_offsets <- state.import_patch_offsets
    out.import_patch_targets <- state.import_patch_targets
    yield out
}

flow append_local_import_patch(comp :: Compiler, import_slot :: i64, patch_off :: i64) -> Compiler {
    vary out :: Compiler = comp
    out.import_patch_offsets <- csv_append(out.import_patch_offsets, str_from_i64(patch_off))
    out.import_patch_targets <- csv_append(out.import_patch_targets, str_from_i64(import_slot))
    yield out
}

flow emit_local_import_call(comp :: Compiler, import_slot :: i64) -> Compiler {
    vary out :: Compiler = comp
    bind patch_off :: i64 = buf_len(out.code) + 2
    out.code <- x_call_iat(out.code, 0, 0)
    out <- append_local_import_patch(out, import_slot, patch_off)
    yield out
}

flow build_pe(code_buf :: i64, rdata_buf :: i64, entry_offset :: i64) -> i64 {
    vary pe :: i64 = buf_new()
    bind text_rva :: i64 = pe_text_rva()
    bind rdata_rva :: i64 = pe_rdata_rva()
    bind idata_rva :: i64 = pe_idata_rva()
    bind bss_rva :: i64 = pe_bss_rva()

    bind text_size :: i64 = buf_len(code_buf)
    bind text_raw :: i64 = ((text_size + 511) / 512) * 512
    bind rdata_size :: i64 = buf_len(rdata_buf)
    check rdata_size < 1 { rdata_size <- 1 }
    bind rdata_raw :: i64 = ((rdata_size + 511) / 512) * 512
    bind idata_raw :: i64 = 1024
    bind bss_size :: i64 = 65536      // 64KB for string buffers
    bind image_size :: i64 = bss_rva + bss_size

    // === DOS Header ===
    pe <- emit_u16(pe, 23117)          // MZ
    pe <- emit_zeros(pe, 58)
    pe <- emit_u32(pe, 128)            // e_lfanew
    pe <- emit_zeros(pe, 64)

    // === PE Signature ===
    pe <- emit_u32(pe, 17744)          // PE\0\0

    // === COFF Header ===
    pe <- emit_u16(pe, 34404)          // AMD64
    pe <- emit_u16(pe, 4)              // 4 sections
    pe <- emit_u32(pe, 0)              // TimeDateStamp
    pe <- emit_u32(pe, 0)              // SymbolTable
    pe <- emit_u32(pe, 0)              // NumSymbols
    pe <- emit_u16(pe, 240)            // OptionalHeader size
    pe <- emit_u16(pe, 34)             // EXECUTABLE_IMAGE | LARGE_ADDRESS_AWARE

    // === Optional Header PE32+ ===
    pe <- emit_u16(pe, 523)            // PE32+
    pe <- emit_u8(pe, 14)
    pe <- emit_u8(pe, 0)
    pe <- emit_u32(pe, text_raw)       // SizeOfCode
    pe <- emit_u32(pe, rdata_raw + idata_raw)  // SizeOfInitializedData
    pe <- emit_u32(pe, bss_size)       // SizeOfUninitializedData
    pe <- emit_u32(pe, text_rva + entry_offset) // EntryPoint
    pe <- emit_u32(pe, text_rva)       // BaseOfCode
    pe <- emit_u64(pe, 4194304)        // ImageBase = 0x400000
    pe <- emit_u32(pe, pe_page_size()) // SectionAlignment
    pe <- emit_u32(pe, 512)            // FileAlignment
    pe <- emit_u16(pe, 6)              // OS version
    pe <- emit_u16(pe, 0)
    pe <- emit_u16(pe, 0)              // Image version
    pe <- emit_u16(pe, 0)
    pe <- emit_u16(pe, 6)              // Subsystem version
    pe <- emit_u16(pe, 0)
    pe <- emit_u32(pe, 0)              // Win32VersionValue
    pe <- emit_u32(pe, image_size)     // SizeOfImage
    pe <- emit_u32(pe, 1024)           // SizeOfHeaders
    pe <- emit_u32(pe, 0)              // CheckSum
    pe <- emit_u16(pe, 3)              // CONSOLE
    pe <- emit_u16(pe, 96)             // DYNAMIC_BASE | NX_COMPAT
    pe <- emit_u64(pe, 1048576)        // StackReserve
    pe <- emit_u64(pe, pe_page_size()) // StackCommit
    pe <- emit_u64(pe, 1048576)        // HeapReserve
    pe <- emit_u64(pe, pe_page_size()) // HeapCommit
    pe <- emit_u32(pe, 0)              // LoaderFlags
    pe <- emit_u32(pe, 16)             // NumberOfRvaAndSizes

    // Data directories
    pe <- emit_u64(pe, 0)              // Export
    pe <- emit_u32(pe, idata_rva)      // Import RVA
    pe <- emit_u32(pe, 512)            // Import Size
    pe <- emit_zeros(pe, 112)          // Remaining 14 dirs

    // === Section Headers (4 sections * 40 bytes = 160 bytes) ===
    bind headers_file :: i64 = 1024
    bind text_file :: i64 = headers_file
    bind rdata_file :: i64 = text_file + text_raw
    bind idata_file :: i64 = rdata_file + rdata_raw

    // .text
    pe <- emit_bytes(pe, ".text")
    pe <- emit_zeros(pe, 3)
    pe <- emit_u32(pe, 1048576)        // VirtualSize = 1MB (0x100000) reserved
    pe <- emit_u32(pe, text_rva)
    pe <- emit_u32(pe, text_raw)
    pe <- emit_u32(pe, text_file)
    pe <- emit_zeros(pe, 12)
    pe <- emit_u32(pe, 1610612768)     // CODE|EXECUTE|READ

    // .rdata
    pe <- emit_bytes(pe, ".rdata")
    pe <- emit_zeros(pe, 2)
    pe <- emit_u32(pe, 16384)
    pe <- emit_u32(pe, rdata_rva)
    pe <- emit_u32(pe, rdata_raw)
    pe <- emit_u32(pe, rdata_file)
    pe <- emit_zeros(pe, 12)
    pe <- emit_u32(pe, 1073741888)     // INITIALIZED_DATA|READ = 0x40000040

    // .idata
    pe <- emit_bytes(pe, ".idata")
    pe <- emit_zeros(pe, 2)
    pe <- emit_u32(pe, 512)
    pe <- emit_u32(pe, idata_rva)
    pe <- emit_u32(pe, idata_raw)
    pe <- emit_u32(pe, idata_file)
    pe <- emit_zeros(pe, 12)
    pe <- emit_u32(pe, 3221225536)     // INITIALIZED_DATA|READ|WRITE = 0xC0000040

    // .bss
    pe <- emit_bytes(pe, ".bss")
    pe <- emit_zeros(pe, 4)
    pe <- emit_u32(pe, bss_size)
    pe <- emit_u32(pe, bss_rva)
    pe <- emit_u32(pe, 0)              // No raw data
    pe <- emit_u32(pe, 0)
    pe <- emit_zeros(pe, 12)
    pe <- emit_u32(pe, 3221225600)     // UNINITIALIZED|READ|WRITE = 0xC0000080

    pe <- pad_to(pe, 512)

    // === .text ===
    pe <- buf_append(pe, code_buf)
    pe <- pad_to(pe, 512)

    // === .rdata ===
    pe <- buf_append(pe, rdata_buf)
    pe <- pad_to(pe, 512)

    // === .idata ===
    // Import Directory Table: 3 entries (kernel32, msvcrt, null)
    // kernel32 imports: ExitProcess, GetProcessHeap, HeapAlloc, HeapFree, GetCommandLineA (5 funcs)
    // msvcrt imports: printf, strlen, strcmp, memcpy, sprintf, fopen, fwrite, fclose, malloc, free, fread (11 funcs)
    // Total IAT slots: 16 + 2 null = 18 entries

    bind idt_base :: i64 = idata_rva
    bind iat_base :: i64 = pe_iat_base_rva()
    bind ilt_base :: i64 = iat_base + 144     // after 18*8=144
    bind names_base :: i64 = ilt_base + 144   // after ILT (same count)

    // Track start of idata in pe buffer for patching
    bind idata_start :: i64 = buf_len(pe)

    // IDT entry 1: kernel32.dll (5 imports: slots 0-4)
    pe <- emit_u32(pe, ilt_base)       // ILT
    pe <- emit_u32(pe, 0)
    pe <- emit_u32(pe, 0)
    pe <- emit_u32(pe, 0)              // DLL name (patched below)
    pe <- emit_u32(pe, iat_base)       // IAT

    // IDT entry 2: msvcrt.dll (11 imports: slots 5-15)
    pe <- emit_u32(pe, ilt_base + 48)  // ILT for msvcrt (after 5+1 entries * 8 = 48)
    pe <- emit_u32(pe, 0)
    pe <- emit_u32(pe, 0)
    pe <- emit_u32(pe, 0)              // DLL name (patched below)
    pe <- emit_u32(pe, iat_base + 48)  // IAT for msvcrt (after 5+1 null entries * 8 = 48)

    // IDT null terminator
    pe <- emit_zeros(pe, 20)

    // Now build names section to figure out RVAs, then patch IDT
    // We know the structure, let's compute name positions

    // Hint/Name entries (each: 2-byte hint + name + null + optional pad)
    // Entries: ExitProcess, GetProcessHeap, HeapAlloc, HeapFree,
    //          printf, strlen, strcmp, memcpy, sprintf, fopen, fwrite, fclose, malloc, free

    // Build names block
    vary names :: i64 = buf_new()
    // ExitProcess (11+1=12, +2 hint = 14)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "ExitProcess")
    names <- emit_u8(names, 0)
    // GetProcessHeap (14+1=15, +2 hint = 17, pad to 18)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "GetProcessHeap")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)  // pad to even
    // HeapAlloc (9+1=10, +2=12)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "HeapAlloc")
    names <- emit_u8(names, 0)
    // HeapFree (8+1=9, +2=11, pad to 12)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "HeapFree")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)  // pad
    // GetCommandLineA (15+1=16, +2 hint = 18)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "GetCommandLineA")
    names <- emit_u8(names, 0)
    bind k32_names_end :: i64 = buf_len(names)  // = 14+18+12+12+18 = 74

    // msvcrt names
    // printf (6+1=7, +2=9, pad=10)
    bind msvcrt_names_start :: i64 = buf_len(names)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "printf")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // strlen (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "strlen")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // strcmp (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "strcmp")
    names <- emit_u8(names, 0)
    // memcpy (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "memcpy")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // sprintf (7+1=8, +2=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "sprintf")
    names <- emit_u8(names, 0)
    // fopen (5+1=6, +2=8)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "fopen")
    names <- emit_u8(names, 0)
    // fwrite (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "fwrite")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // fclose (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "fclose")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // malloc (6+1=7, +2=9, pad=10)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "malloc")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // free (4+1=5, +2=7, pad=8)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "free")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)
    // fread (5+1=6, +2=8)
    names <- emit_u16(names, 0)
    names <- emit_bytes(names, "fread")
    names <- emit_u8(names, 0)

    // DLL name strings
    bind k32_name_off :: i64 = buf_len(names)
    names <- emit_bytes(names, "kernel32.dll")
    names <- emit_u8(names, 0)
    names <- emit_u8(names, 0)  // pad
    bind msvcrt_name_off :: i64 = buf_len(names)
    names <- emit_bytes(names, "msvcrt.dll")
    names <- emit_u8(names, 0)

    // Compute hint/name RVAs for each function
    // ExitProcess starts at names_base + 0
    // GetProcessHeap at names_base + 14
    // HeapAlloc at names_base + 32
    // HeapFree at names_base + 44
    bind hn_ExitProcess :: i64 = names_base
    bind hn_GetProcessHeap :: i64 = names_base + 14
    bind hn_HeapAlloc :: i64 = names_base + 32
    bind hn_HeapFree :: i64 = names_base + 44
    bind hn_GetCommandLineA :: i64 = names_base + 56

    bind hn_printf :: i64 = names_base + msvcrt_names_start
    bind hn_strlen :: i64 = hn_printf + 10
    bind hn_strcmp :: i64 = hn_strlen + 10
    bind hn_memcpy :: i64 = hn_strcmp + 9
    bind hn_sprintf :: i64 = hn_memcpy + 10
    bind hn_fopen :: i64 = hn_sprintf + 10
    bind hn_fwrite :: i64 = hn_fopen + 8
    bind hn_fclose :: i64 = hn_fwrite + 10
    bind hn_malloc :: i64 = hn_fclose + 10
    bind hn_free :: i64 = hn_malloc + 10
    bind hn_fread :: i64 = hn_free + 8

    // Patch IDT DLL name fields
    // IDT entry 1 Name is at idata_start + 12
    // IDT entry 2 Name is at idata_start + 20 + 12 = idata_start + 32
    pe <- patch_u32(pe, idata_start + 12, names_base + k32_name_off)
    pe <- patch_u32(pe, idata_start + 32, names_base + msvcrt_name_off)

    // === IAT (Import Address Table) ===
    // kernel32: 5 entries + null (6 * 8 = 48 bytes)
    pe <- emit_u64(pe, hn_ExitProcess)
    pe <- emit_u64(pe, hn_GetProcessHeap)
    pe <- emit_u64(pe, hn_HeapAlloc)
    pe <- emit_u64(pe, hn_HeapFree)
    pe <- emit_u64(pe, hn_GetCommandLineA)
    pe <- emit_u64(pe, 0)  // null terminator

    // msvcrt: 11 entries + null (12 * 8 = 96 bytes)
    pe <- emit_u64(pe, hn_printf)
    pe <- emit_u64(pe, hn_strlen)
    pe <- emit_u64(pe, hn_strcmp)
    pe <- emit_u64(pe, hn_memcpy)
    pe <- emit_u64(pe, hn_sprintf)
    pe <- emit_u64(pe, hn_fopen)
    pe <- emit_u64(pe, hn_fwrite)
    pe <- emit_u64(pe, hn_fclose)
    pe <- emit_u64(pe, hn_malloc)
    pe <- emit_u64(pe, hn_free)
    pe <- emit_u64(pe, hn_fread)
    pe <- emit_u64(pe, 0)  // null terminator

    // === ILT (same as IAT) ===
    // kernel32
    pe <- emit_u64(pe, hn_ExitProcess)
    pe <- emit_u64(pe, hn_GetProcessHeap)
    pe <- emit_u64(pe, hn_HeapAlloc)
    pe <- emit_u64(pe, hn_HeapFree)
    pe <- emit_u64(pe, hn_GetCommandLineA)
    pe <- emit_u64(pe, 0)
    // msvcrt
    pe <- emit_u64(pe, hn_printf)
    pe <- emit_u64(pe, hn_strlen)
    pe <- emit_u64(pe, hn_strcmp)
    pe <- emit_u64(pe, hn_memcpy)
    pe <- emit_u64(pe, hn_sprintf)
    pe <- emit_u64(pe, hn_fopen)
    pe <- emit_u64(pe, hn_fwrite)
    pe <- emit_u64(pe, hn_fclose)
    pe <- emit_u64(pe, hn_malloc)
    pe <- emit_u64(pe, hn_free)
    pe <- emit_u64(pe, hn_fread)
    pe <- emit_u64(pe, 0)

    // === Hint/Name table + DLL names ===
    pe <- buf_append(pe, names)

    pe <- pad_to(pe, 512)

    yield pe
}

// ==================================================================
// SECTION 8: BUILTIN STUBS (native implementations)
// ==================================================================

// Emit builtin: ng_print(const char* s) -> calls printf("%s", s)
// rcx = s. We need to set rcx=fmt, rdx=s, call printf
flow emit_builtin_print(code :: i64, rdata_rva :: i64, fmt_s_off :: i64) -> i64 {
    vary b :: i64 = code
    // push rbp; mov rbp, rsp; sub rsp, 32
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // mov rdx, rcx (s is second arg)
    b <- x_mov_reg_reg(b, 2, 1)
    // lea rcx, [rip + fmt_s_off] - "%s" format string
    bind lea_pos :: i64 = buf_len(b)
    bind fmt_rva :: i64 = rdata_rva + fmt_s_off
    bind rip_after :: i64 = pe_text_rva() + lea_pos + 7
    b <- buf_push(b, 72)    // REX.W
    b <- buf_push(b, 141)   // 8D = LEA
    b <- buf_push(b, 13)    // 0D = ModRM for rcx, rip-relative
    b <- emit_u32(b, fmt_rva - rip_after)
    // call [IAT printf]
    b <- emit_runtime_import_call(b, 5)
    // xor rax, rax; epilogue
    b <- x_xor_reg_reg(b, 0, 0)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: ng_println(const char* s) -> calls printf("%s\n", s)
flow emit_builtin_println(code :: i64, rdata_rva :: i64, fmt_sn_off :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    b <- x_mov_reg_reg(b, 2, 1)
    bind lea_pos :: i64 = buf_len(b)
    bind fmt_rva :: i64 = rdata_rva + fmt_sn_off
    bind rip_after :: i64 = pe_text_rva() + lea_pos + 7
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 13)
    b <- emit_u32(b, fmt_rva - rip_after)
    b <- emit_runtime_import_call(b, 5)
    b <- x_xor_reg_reg(b, 0, 0)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: ng_str_len(const char* s) -> strlen(s)
flow emit_builtin_str_len(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // rcx already = s
    b <- emit_runtime_import_call(b, 6)  // strlen
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: ng_str_byte_at(s, i) -> (unsigned char)s[i] or -1
flow emit_builtin_str_byte_at(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // rcx=s, rdx=i. Load byte: movzx rax, byte [rcx+rdx]
    b <- buf_push(b, 72)    // REX.W
    b <- buf_push(b, 15)    // 0F
    b <- buf_push(b, 182)   // B6 = MOVZX r64, r/m8
    b <- buf_push(b, 4)     // ModRM: 04 = SIB follows, base=rcx+rdx
    b <- buf_push(b, 17)    // SIB: scale=1, index=rdx(2), base=rcx(1)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: ng_str_eq(a, b) -> strcmp(a,b)==0
flow emit_builtin_str_eq(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // rcx=a, rdx=b already set
    b <- emit_runtime_import_call(b, 7)  // strcmp
    // rax = strcmp result. We want rax = (rax == 0)
    b <- buf_push(b, 72)  // REX.W test rax, rax
    b <- buf_push(b, 133)
    b <- buf_push(b, 192)
    b <- x_sete_al(b)
    b <- x_movzx_rax_al(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: str_concat(a, b) -> malloc + memcpy + memcpy
flow emit_builtin_str_concat(code :: i64) -> i64 {
    vary b :: i64 = code
    // push rbp; mov rbp, rsp; sub rsp, 80
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)
    // save args: [rbp-8]=a, [rbp-16]=b
    b <- x_mov_rbp_off8_reg(b, -8, 1)
    b <- x_mov_rbp_off8_reg(b, -16, 2)
    // strlen(a): rcx already = a
    b <- emit_runtime_import_call(b, 6)
    b <- x_mov_rbp_off8_reg(b, -24, 0)  // [rbp-24] = len_a
    // strlen(b)
    b <- x_mov_reg_rbp_off8(b, 1, -16)
    b <- emit_runtime_import_call(b, 6)
    b <- x_mov_rbp_off8_reg(b, -32, 0)  // [rbp-32] = len_b
    // malloc(len_a + len_b + 1)
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    b <- x_add_reg_reg(b, 1, 0)  // rcx = len_a + len_b
    // add rcx, 1
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 1)
    b <- emit_runtime_import_call(b, 13)
    b <- x_mov_rbp_off8_reg(b, -40, 0)  // [rbp-40] = result
    // memcpy(result, a, len_a): rcx=result, rdx=a, r8=len_a
    b <- x_mov_reg_reg(b, 1, 0)
    b <- x_mov_reg_rbp_off8(b, 2, -8)
    b <- x_mov_reg_rbp_off8(b, 0, -24)
    // mov r8, rax: 49 89 C0
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)
    // memcpy(result+len_a, b, len_b+1): include null terminator
    b <- x_mov_reg_rbp_off8(b, 1, -40)
    b <- x_mov_reg_rbp_off8(b, 0, -24)
    b <- x_add_reg_reg(b, 1, 0)  // rcx = result + len_a
    b <- x_mov_reg_rbp_off8(b, 2, -16)  // rdx = b
    b <- x_mov_reg_rbp_off8(b, 0, -32)
    // add rax, 1 (for null terminator)
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 192)
    b <- buf_push(b, 1)
    // mov r8, rax: 49 89 C0
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)
    // return result
    b <- x_mov_reg_rbp_off8(b, 0, -40)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: str_slice(s, start, end) -> substring
flow emit_builtin_str_slice(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)
    // save args: [rbp-8]=s, [rbp-16]=start, [rbp-24]=end
    b <- x_mov_rbp_off8_reg(b, -8, 1)
    b <- x_mov_rbp_off8_reg(b, -16, 2)
    // mov [rbp-24], r8: 4C 89 45 E8
    b <- buf_push(b, 76)
    b <- buf_push(b, 137)
    b <- buf_push(b, 69)
    b <- buf_push(b, 232)
    // len = end - start
    // mov rax, r8: 4C 89 C0
    b <- buf_push(b, 76)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- x_sub_reg_reg(b, 0, 2)  // rax = end - start
    b <- x_mov_rbp_off8_reg(b, -32, 0)  // [rbp-32] = len
    // malloc(len + 1)
    b <- x_mov_reg_reg(b, 1, 0)
    // add rcx, 1
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 1)
    b <- emit_runtime_import_call(b, 13)
    b <- x_mov_rbp_off8_reg(b, -40, 0)  // [rbp-40] = result
    // memcpy(result, s+start, len)
    b <- x_mov_reg_reg(b, 1, 0)  // rcx = result
    b <- x_mov_reg_rbp_off8(b, 2, -8)  // rdx = s
    b <- x_mov_reg_rbp_off8(b, 0, -16)
    b <- x_add_reg_reg(b, 2, 0)  // rdx = s + start
    b <- x_mov_reg_rbp_off8(b, 0, -32)
    // mov r8, rax: 49 89 C0
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)
    // null-terminate: result[len] = 0
    b <- x_mov_reg_rbp_off8(b, 0, -40)  // rax = result
    b <- x_mov_reg_rbp_off8(b, 1, -32)  // rcx = len
    // mov byte [rax+rcx], 0: C6 04 08 00
    b <- buf_push(b, 198)
    b <- buf_push(b, 4)
    b <- buf_push(b, 8)
    b <- buf_push(b, 0)
    // return result
    b <- x_mov_reg_rbp_off8(b, 0, -40)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: str_from_i64(n) -> sprintf(buf, "%lld", n)
flow emit_builtin_str_from_i64(code :: i64, rdata_rva :: i64, fmt_lld_off :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)
    b <- x_mov_rbp_off8_reg(b, -8, 1)  // [rbp-8] = n
    // malloc(32)
    b <- x_mov_reg_imm64(b, 1, 32)
    b <- emit_runtime_import_call(b, 13)
    b <- x_mov_rbp_off8_reg(b, -16, 0)  // [rbp-16] = buf
    // sprintf(buf, "%lld", n): rcx=buf, rdx=fmt, r8=n
    b <- x_mov_reg_reg(b, 1, 0)  // rcx = buf
    // lea rdx, [rip+disp] for "%lld"
    bind lea_pos :: i64 = buf_len(b)
    bind fmt_rva :: i64 = rdata_rva + fmt_lld_off
    bind rip_after :: i64 = pe_text_rva() + lea_pos + 7
    b <- buf_push(b, 72)   // REX.W
    b <- buf_push(b, 141)  // LEA
    b <- buf_push(b, 21)   // ModRM: rdx, [rip+disp32]
    b <- emit_u32(b, fmt_rva - rip_after)
    // mov r8, [rbp-8]: 4C 8B 45 F8
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 69)
    b <- buf_push(b, 248)
    b <- emit_runtime_import_call(b, 9)
    // return buf
    b <- x_mov_reg_rbp_off8(b, 0, -16)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: str_from_byte(ch) -> single-char string
flow emit_builtin_str_from_byte(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 48)
    b <- x_mov_rbp_off8_reg(b, -8, 1)  // [rbp-8] = ch
    // malloc(2)
    b <- x_mov_reg_imm64(b, 1, 2)
    b <- emit_runtime_import_call(b, 13)
    // mov byte [rax], cl: put ch byte at result[0]
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    // mov byte [rax], cl: 88 08
    b <- buf_push(b, 136)
    b <- buf_push(b, 8)
    // mov byte [rax+1], 0: C6 40 01 00
    b <- buf_push(b, 198)
    b <- buf_push(b, 64)
    b <- buf_push(b, 1)
    b <- buf_push(b, 0)
    // rax already = result
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_new() -> allocate [cap:8][len:8][data...]
flow emit_builtin_buf_new(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // malloc(16+64) = 80
    b <- x_mov_reg_imm64(b, 1, 80)
    b <- emit_runtime_import_call(b, 13)
    // [rax+0] = 64 (capacity)
    b <- x_mov_reg_imm64(b, 1, 64)
    // mov [rax], rcx: 48 89 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 8)
    // [rax+8] = 0 (length)
    b <- x_mov_reg_imm64(b, 1, 0)
    // mov [rax+8], rcx: 48 89 48 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 72)
    b <- buf_push(b, 8)
    // return rax
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_push(buf, byte) -> append byte, return buf (may realloc)
flow emit_builtin_buf_push(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)
    // [rbp-8] = buf, [rbp-16] = byte
    b <- x_mov_rbp_off8_reg(b, -8, 1)
    b <- x_mov_rbp_off8_reg(b, -16, 2)
    // load cap=[buf], len=[buf+8]
    // mov rax, [rcx]: 48 8B 01
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 1)
    b <- x_mov_rbp_off8_reg(b, -24, 0)  // cap
    // mov rax, [rcx+8]: 48 8B 41 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 65)
    b <- buf_push(b, 8)
    b <- x_mov_rbp_off8_reg(b, -32, 0)  // len
    // if len >= cap, realloc
    b <- x_mov_reg_rbp_off8(b, 1, -24)  // rcx = cap
    b <- x_cmp_reg_reg(b, 0, 1)  // cmp rax(len), rcx(cap)
    // jl skip_realloc (short jump)
    bind jl_pos :: i64 = buf_len(b)
    b <- buf_push(b, 15)   // 0F 8C = JL rel32
    b <- buf_push(b, 140)
    b <- emit_u32(b, 0)    // patched below
    // realloc: new_cap = cap * 2, malloc(16 + new_cap)
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    // shl rcx, 1: 48 D1 E1
    b <- buf_push(b, 72)
    b <- buf_push(b, 209)
    b <- buf_push(b, 225)
    b <- x_mov_rbp_off8_reg(b, -24, 1)  // update cap
    // add rcx, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    b <- emit_runtime_import_call(b, 13)  // malloc
    b <- x_mov_rbp_off8_reg(b, -40, 0)  // new_buf
    // copy: memcpy(new_buf, old_buf, 16 + old_len)
    b <- x_mov_reg_reg(b, 1, 0)  // dst = new_buf
    b <- x_mov_reg_rbp_off8(b, 2, -8)  // src = old_buf
    b <- x_mov_reg_rbp_off8(b, 0, -32)  // len
    // add rax, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 192)
    b <- buf_push(b, 16)
    // mov r8, rax: 49 89 C0
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)  // memcpy
    // free old buf
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 14)  // free
    // update buf ptr and cap
    b <- x_mov_reg_rbp_off8(b, 0, -40)
    b <- x_mov_rbp_off8_reg(b, -8, 0)  // buf = new_buf
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    // mov [rax], rcx (set new cap): 48 89 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 8)
    // patch jl
    bind after_realloc :: i64 = buf_len(b)
    b <- patch_u32(b, jl_pos + 2, after_realloc - (jl_pos + 6))
    // store byte: buf[16+len] = byte
    b <- x_mov_reg_rbp_off8(b, 0, -8)   // rax = buf
    b <- x_mov_reg_rbp_off8(b, 1, -32)  // rcx = len
    b <- x_mov_reg_rbp_off8(b, 2, -16)  // rdx = byte
    // add rax, 16: 48 83 C0 10
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 192)
    b <- buf_push(b, 16)
    // mov byte [rax+rcx], dl: 88 14 08
    b <- buf_push(b, 136)
    b <- buf_push(b, 20)
    b <- buf_push(b, 8)
    // increment len: [buf+8] = len+1
    b <- x_mov_reg_rbp_off8(b, 0, -8)
    b <- x_mov_reg_rbp_off8(b, 1, -32)
    // add rcx, 1
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 1)
    // mov [rax+8], rcx: 48 89 48 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 72)
    b <- buf_push(b, 8)
    // return buf
    b <- x_mov_reg_rbp_off8(b, 0, -8)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_len(buf) -> [buf+8]
flow emit_builtin_buf_len(code :: i64) -> i64 {
    vary b :: i64 = code
    // mov rax, [rcx+8]: 48 8B 41 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 65)
    b <- buf_push(b, 8)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_get(buf, i) -> byte at buf[16+i]
flow emit_builtin_buf_get(code :: i64) -> i64 {
    vary b :: i64 = code
    // add rcx, 16: 48 83 C1 10
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    // movzx rax, byte [rcx+rdx]: 48 0F B6 04 11
    b <- buf_push(b, 72)
    b <- buf_push(b, 15)
    b <- buf_push(b, 182)
    b <- buf_push(b, 4)
    b <- buf_push(b, 17)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_set(buf, i, val) -> store byte, return buf
flow emit_builtin_buf_set(code :: i64) -> i64 {
    vary b :: i64 = code
    // buf[16+i] = val
    // add rcx, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    // r8 has val. mov byte [rcx+rdx], r8b: 44 88 04 11
    b <- buf_push(b, 68)
    b <- buf_push(b, 136)
    b <- buf_push(b, 4)
    b <- buf_push(b, 17)
    // return buf (first arg = rcx minus the add we did)
    // Actually, need original buf. sub rcx, 16 then mov rax, rcx
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 233)
    b <- buf_push(b, 16)
    b <- x_mov_reg_reg(b, 0, 1)
    b <- x_ret(b)
    yield b
}

// Emit builtin: buf_append(dst, src) -> ensure capacity, memcpy, update len
flow emit_builtin_buf_append(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)
    // [rbp-8]=dst, [rbp-16]=src
    b <- x_mov_rbp_off8_reg(b, -8, 1)
    b <- x_mov_rbp_off8_reg(b, -16, 2)
    // src_len = [src+8]
    // mov rax, [rdx+8]: 48 8B 42 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 66)
    b <- buf_push(b, 8)
    b <- x_mov_rbp_off8_reg(b, -24, 0)  // [rbp-24] = src_len
    // dst_len = [dst+8]
    // mov rax, [rcx+8]: 48 8B 41 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 65)
    b <- buf_push(b, 8)
    b <- x_mov_rbp_off8_reg(b, -32, 0)  // [rbp-32] = dst_len
    // dst_cap = [dst]
    // mov rax, [rcx]: 48 8B 01
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 1)
    b <- x_mov_rbp_off8_reg(b, -40, 0)  // [rbp-40] = dst_cap
    // needed = dst_len + src_len
    b <- x_mov_reg_rbp_off8(b, 0, -32)
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    b <- x_add_reg_reg(b, 0, 1)  // rax = needed
    // if needed <= cap, skip realloc
    b <- x_mov_reg_rbp_off8(b, 1, -40)  // rcx = cap
    b <- x_cmp_reg_reg(b, 0, 1)
    bind jle_pos :: i64 = buf_len(b)
    b <- x_jle_rel32(b, 0)  // patched below
    // realloc: new_cap = needed * 2
    // shl rax, 1
    b <- buf_push(b, 72)
    b <- buf_push(b, 209)
    b <- buf_push(b, 224)
    b <- x_mov_rbp_off8_reg(b, -40, 0)  // update cap
    // malloc(new_cap + 16)
    b <- x_mov_reg_reg(b, 1, 0)
    // add rcx, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    b <- emit_runtime_import_call(b, 13)
    b <- x_mov_rbp_off8_reg(b, -48, 0)  // [rbp-48] = new_buf
    // memcpy(new_buf, old_dst, 16+dst_len)
    b <- x_mov_reg_reg(b, 1, 0)   // rcx = new_buf
    b <- x_mov_reg_rbp_off8(b, 2, -8)   // rdx = old_dst
    b <- x_mov_reg_rbp_off8(b, 0, -32)  // rax = dst_len
    // add rax, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 192)
    b <- buf_push(b, 16)
    // mov r8, rax
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)
    // free old dst
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 14)
    // dst = new_buf, write new cap
    b <- x_mov_reg_rbp_off8(b, 0, -48)
    b <- x_mov_rbp_off8_reg(b, -8, 0)   // dst = new_buf
    b <- x_mov_reg_rbp_off8(b, 1, -40)  // rcx = new_cap
    // mov [rax], rcx: 48 89 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 8)
    // patch jle
    bind after_realloc :: i64 = buf_len(b)
    b <- patch_u32(b, jle_pos + 2, after_realloc - (jle_pos + 6))
    // memcpy(dst+16+dst_len, src+16, src_len)
    b <- x_mov_reg_rbp_off8(b, 1, -8)   // rcx = dst
    b <- x_mov_reg_rbp_off8(b, 0, -32)  // rax = dst_len
    b <- x_add_reg_reg(b, 1, 0)         // rcx = dst + dst_len
    // add rcx, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    b <- x_mov_reg_rbp_off8(b, 2, -16)  // rdx = src
    // add rdx, 16
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 194)
    b <- buf_push(b, 16)
    b <- x_mov_reg_rbp_off8(b, 0, -24)  // rax = src_len
    // mov r8, rax
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    b <- emit_runtime_import_call(b, 8)
    // update dst len: [dst+8] = dst_len + src_len
    b <- x_mov_reg_rbp_off8(b, 0, -8)   // rax = dst
    b <- x_mov_reg_rbp_off8(b, 1, -32)  // rcx = dst_len
    b <- x_mov_reg_rbp_off8(b, 2, -24)  // rdx = src_len
    b <- x_add_reg_reg(b, 1, 2)         // rcx = dst_len + src_len
    // mov [rax+8], rcx: 48 89 48 08
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 72)
    b <- buf_push(b, 8)
    // return dst
    b <- x_mov_reg_rbp_off8(b, 0, -8)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_create(path) -> fopen(path, "wb")
flow emit_builtin_file_create(code :: i64, rdata_rva :: i64, wb_off :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // rcx = path, rdx = "wb"
    bind lea_pos :: i64 = buf_len(b)
    bind rip_after :: i64 = pe_text_rva() + lea_pos + 7
    // lea rdx, [rip+disp] for "wb"
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 21)   // ModRM for rdx
    b <- emit_u32(b, rdata_rva + wb_off - rip_after)
    b <- emit_runtime_import_call(b, 10)  // fopen
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_write_buf(fd, buf) -> fwrite(buf+16, 1, len, fd)
flow emit_builtin_file_write_buf(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 48)
    // rcx=fd, rdx=buf
    b <- x_mov_rbp_off8_reg(b, -8, 1)   // fd
    b <- x_mov_rbp_off8_reg(b, -16, 2)  // buf
    // fwrite(data, 1, len, fd)
    // rcx = buf+16 (data), rdx = 1, r8 = len, r9 = fd
    b <- x_mov_reg_rbp_off8(b, 1, -16)
    // mov rax, [rcx+8]: get len
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 65)
    b <- buf_push(b, 8)
    // mov r8, rax (len): 49 89 C0
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)
    // add rcx, 16 (data ptr)
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)
    b <- x_mov_reg_imm64(b, 2, 1)  // rdx = 1 (element size)
    // mov r9, [rbp-8] (fd): 4C 8B 4D F8
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 77)
    b <- buf_push(b, 248)
    b <- emit_runtime_import_call(b, 11)  // fwrite
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_write_byte(fd, byte) -> fwrite(&byte, 1, 1, fd)
flow emit_builtin_file_write_byte(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 48)
    // save fd and byte
    b <- x_mov_rbp_off8_reg(b, -8, 1)   // fd
    b <- x_mov_rbp_off8_reg(b, -16, 2)  // byte
    // fwrite(&byte_on_stack, 1, 1, fd)
    // lea rcx, [rbp-16] (address of byte): 48 8D 4D F0
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 77)
    b <- buf_push(b, 240)
    b <- x_mov_reg_imm64(b, 2, 1)  // rdx = 1
    // mov r8, 1: 49 C7 C0 01 00 00 00
    b <- buf_push(b, 73)
    b <- buf_push(b, 199)
    b <- buf_push(b, 192)
    b <- buf_push(b, 1)
    b <- buf_push(b, 0)
    b <- buf_push(b, 0)
    b <- buf_push(b, 0)
    // mov r9, [rbp-8]: 4C 8B 4D F8
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 77)
    b <- buf_push(b, 248)
    b <- emit_runtime_import_call(b, 11)  // fwrite
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_close(fd) -> fclose(fd)
flow emit_builtin_file_close(code :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 32)
    // rcx = fd
    b <- emit_runtime_import_call(b, 12)  // fclose
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_read_all_buf(path) -> buf or 0 on open/alloc failure
flow emit_builtin_file_read_all_buf(code :: i64, rdata_rva :: i64, rb_off :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 64)
    b <- x_xor_reg_reg(b, 0, 0)
    b <- x_mov_rbp_off8_reg(b, -16, 0)  // buf = 0 for failure cleanup

    // fopen(path, "rb")
    bind lea_rb :: i64 = buf_len(b)
    bind rip_rb :: i64 = pe_text_rva() + lea_rb + 7
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 21)
    b <- emit_u32(b, rdata_rva + rb_off - rip_rb)
    b <- emit_runtime_import_call(b, 10)
    b <- x_test_rax_rax(b)
    bind je_open_fail :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -8, 0)   // fd

    // malloc initial buf: 16 + 4096
    b <- x_mov_reg_imm64(b, 1, 4112)
    b <- emit_runtime_import_call(b, 13)
    b <- x_test_rax_rax(b)
    bind je_alloc_fail0 :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -16, 0)  // buf

    // [buf] = cap, [buf+8] = 0
    b <- x_mov_reg_imm64(b, 1, 4096)
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 8)
    b <- x_mov_reg_imm64(b, 1, 0)
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 72)
    b <- buf_push(b, 8)

    bind loop_start :: i64 = buf_len(b)

    // load cap = [buf], len = [buf+8]
    b <- x_mov_reg_rbp_off8(b, 1, -16)  // rcx = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 1)
    b <- x_mov_rbp_off8_reg(b, -24, 0)  // cap
    b <- buf_push(b, 72)
    b <- buf_push(b, 139)
    b <- buf_push(b, 65)
    b <- buf_push(b, 8)
    b <- x_mov_rbp_off8_reg(b, -32, 0)  // len

    // available = cap - len
    b <- x_mov_reg_rbp_off8(b, 0, -24)
    b <- x_mov_reg_rbp_off8(b, 1, -32)
    b <- x_sub_reg_reg(b, 0, 1)
    b <- x_mov_rbp_off8_reg(b, -40, 0)
    b <- x_test_rax_rax(b)
    bind jne_have_space :: i64 = buf_len(b)
    b <- x_jne_rel32(b, 0)

    // grow buf when available == 0
    b <- x_mov_reg_rbp_off8(b, 1, -24)  // rcx = cap
    b <- buf_push(b, 72)
    b <- buf_push(b, 209)
    b <- buf_push(b, 225)               // shl rcx, 1
    b <- x_mov_rbp_off8_reg(b, -24, 1)  // new_cap
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)                // add rcx, 16
    b <- emit_runtime_import_call(b, 13)
    b <- x_test_rax_rax(b)
    bind je_alloc_fail1 :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -48, 0)  // new_buf

    // memcpy(new_buf, old_buf, len + 16)
    b <- x_mov_reg_reg(b, 1, 0)         // rcx = new_buf
    b <- x_mov_reg_rbp_off8(b, 2, -16)  // rdx = old_buf
    b <- x_mov_reg_rbp_off8(b, 0, -32)  // rax = len
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 192)
    b <- buf_push(b, 16)                // add rax, 16
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)               // mov r8, rax
    b <- emit_runtime_import_call(b, 8)

    // free old buf
    b <- x_mov_reg_rbp_off8(b, 1, -16)
    b <- emit_runtime_import_call(b, 14)

    // buf = new_buf, [buf] = new_cap
    b <- x_mov_reg_rbp_off8(b, 0, -48)
    b <- x_mov_rbp_off8_reg(b, -16, 0)
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 8)
    b <- x_jmp_rel32(b, loop_start - (buf_len(b) + 5))

    bind have_space :: i64 = buf_len(b)
    b <- patch_u32(b, jne_have_space + 2, have_space - (jne_have_space + 6))

    // fread(buf + 16 + len, 1, available, fd)
    b <- x_mov_reg_rbp_off8(b, 1, -16)  // rcx = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 131)
    b <- buf_push(b, 193)
    b <- buf_push(b, 16)                // add rcx, 16
    b <- x_mov_reg_rbp_off8(b, 2, -32)  // rdx = len
    b <- x_add_reg_reg(b, 1, 2)         // rcx = buf + 16 + len
    b <- x_mov_reg_imm64(b, 2, 1)
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 69)
    b <- buf_push(b, 216)               // mov r8, [rbp-40]
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 77)
    b <- buf_push(b, 248)               // mov r9, [rbp-8]
    b <- emit_runtime_import_call(b, 15)

    b <- x_test_rax_rax(b)
    bind je_done :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)

    // len += bytes_read
    b <- x_mov_rbp_off8_reg(b, -48, 0)  // bytes_read
    b <- x_mov_reg_rbp_off8(b, 1, -32)  // rcx = len
    b <- x_add_reg_reg(b, 1, 0)         // rcx += bytes_read
    b <- x_mov_reg_rbp_off8(b, 0, -16)  // rax = buf
    b <- buf_push(b, 72)
    b <- buf_push(b, 137)
    b <- buf_push(b, 72)
    b <- buf_push(b, 8)                 // mov [rax+8], rcx

    // short read => done, full read => continue
    b <- x_mov_reg_rbp_off8(b, 0, -48)  // rax = bytes_read
    b <- x_mov_reg_rbp_off8(b, 1, -40)  // rcx = available
    b <- x_cmp_reg_reg(b, 0, 1)
    bind jl_done :: i64 = buf_len(b)
    b <- x_jl_rel32(b, 0)
    b <- x_jmp_rel32(b, loop_start - (buf_len(b) + 5))

    // fclose(fd)
    bind done :: i64 = buf_len(b)
    b <- patch_u32(b, je_done + 2, done - (je_done + 6))
    b <- patch_u32(b, jl_done + 2, done - (jl_done + 6))
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 12)

    // return buf
    b <- x_mov_reg_rbp_off8(b, 0, -16)
    bind ret_ok :: i64 = buf_len(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)

    bind open_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_open_fail + 2, open_fail - (je_open_fail + 6))
    b <- x_mov_reg_imm64(b, 0, 0)
    bind ret_open_fail :: i64 = buf_len(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)

    bind alloc_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_alloc_fail0 + 2, alloc_fail - (je_alloc_fail0 + 6))
    b <- patch_u32(b, je_alloc_fail1 + 2, alloc_fail - (je_alloc_fail1 + 6))
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 12)
    b <- x_mov_reg_rbp_off8(b, 1, -16)
    b <- emit_runtime_import_call(b, 14)
    b <- x_mov_reg_imm64(b, 0, 0)
    bind ret_alloc_fail :: i64 = buf_len(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

// Emit builtin: file_read_all_text(path) -> str
// Current implementation uses a fixed 1 MiB read budget, which is sufficient
// for the current suite/compiler sources and avoids buf->str reconstruction in tooling.
flow emit_builtin_file_read_all_text(code :: i64, rdata_rva :: i64, rb_off :: i64) -> i64 {
    vary b :: i64 = code
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 48)

    // fopen(path, "rb")
    bind lea_rb :: i64 = buf_len(b)
    bind rip_rb :: i64 = pe_text_rva() + lea_rb + 7
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 21)
    b <- emit_u32(b, rdata_rva + rb_off - rip_rb)
    b <- emit_runtime_import_call(b, 10)
    b <- x_test_rax_rax(b)
    bind je_open_fail :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -8, 0)   // fd

    // malloc(1048577) for payload plus null terminator
    b <- x_mov_reg_imm64(b, 1, 1048577)
    b <- emit_runtime_import_call(b, 13)
    b <- x_test_rax_rax(b)
    bind je_alloc_fail :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -16, 0)  // text buf

    // fread(buf, 1, 1048576, fd)
    b <- x_mov_reg_reg(b, 1, 0)         // rcx = buf
    b <- x_mov_reg_imm64(b, 2, 1)       // rdx = 1
    b <- x_mov_reg_imm64(b, 0, 1048576)
    b <- buf_push(b, 73)
    b <- buf_push(b, 137)
    b <- buf_push(b, 192)               // mov r8, rax
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 77)
    b <- buf_push(b, 248)               // mov r9, [rbp-8]
    b <- emit_runtime_import_call(b, 15)

    // null terminate at buf[bytes_read]
    b <- x_mov_reg_rbp_off8(b, 1, -16)  // rcx = buf
    b <- x_add_reg_reg(b, 1, 0)         // rcx += bytes_read
    b <- buf_push(b, 198)
    b <- buf_push(b, 1)
    b <- buf_push(b, 0)                 // mov byte [rcx], 0

    // fclose(fd)
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 12)

    // return buf
    b <- x_mov_reg_rbp_off8(b, 0, -16)
    bind ret_ok :: i64 = buf_len(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)

    bind alloc_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_alloc_fail + 2, alloc_fail - (je_alloc_fail + 6))
    b <- x_mov_reg_rbp_off8(b, 1, -8)
    b <- emit_runtime_import_call(b, 12)

    bind open_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_open_fail + 2, open_fail - (je_open_fail + 6))

    // return empty string on failure
    b <- x_mov_reg_imm64(b, 1, 1)
    b <- emit_runtime_import_call(b, 13)
    b <- x_test_rax_rax(b)
    bind je_empty_null :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- buf_push(b, 198)
    b <- buf_push(b, 0)
    b <- buf_push(b, 0)                 // mov byte [rax], 0
    bind ret_empty :: i64 = buf_len(b)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)

    bind empty_null :: i64 = buf_len(b)
    b <- patch_u32(b, je_empty_null + 2, empty_null - (je_empty_null + 6))
    b <- x_xor_reg_reg(b, 0, 0)
    b <- x_mov_reg_reg(b, 4, 5)
    b <- x_pop_reg(b, 5)
    b <- x_ret(b)
    yield b
}

form RuntimeRdataLayout {
    fmt_s_off :: i64,
    fmt_sn_off :: i64,
    fmt_lld_off :: i64,
    fmt_lld_no_nl_off :: i64,
    wb_off :: i64,
    rb_off :: i64
}

form RuntimeBootstrap {
    valid :: i64,
    comp :: Compiler,
    main_idx :: i64,
    main_code_offset :: i64,
    exit_code :: i64,
    message :: str
}

form CodeImportPatchState {
    code :: i64,
    import_patch_offsets :: str,
    import_patch_targets :: str
}

flow trace(msg :: str) -> i64 {
    println(msg)
    yield 0
}

flow fatal(msg :: str, code :: i64) -> i64 {
    println(str_concat("FATAL: ", msg))
    yield code
}

flow append_builtin_registration(comp :: Compiler, name :: str, param_count :: i64, code_offset :: i64) -> Compiler {
    vary out :: Compiler = comp
    out.fn_names <- csv_append(out.fn_names, name)
    out.fn_params <- emit_u32(out.fn_params, param_count)
    out.fn_param_starts <- emit_u32(out.fn_param_starts, 0)
    out.fn_bodies <- emit_u32(out.fn_bodies, 0)
    out.fn_local_counts <- emit_u32(out.fn_local_counts, 0)
    out.builtin_offset_store <- emit_u32(out.builtin_offset_store, code_offset)
    yield out
}

flow build_runtime_rdata(comp :: Compiler) -> Compiler {
    vary out :: Compiler = comp
    out.rdata <- buf_push(out.rdata, 37)
    out.rdata <- buf_push(out.rdata, 115)
    out.rdata <- buf_push(out.rdata, 0)

    out.rdata <- buf_push(out.rdata, 37)
    out.rdata <- buf_push(out.rdata, 115)
    out.rdata <- buf_push(out.rdata, 10)
    out.rdata <- buf_push(out.rdata, 0)

    out.rdata <- buf_push(out.rdata, 37)
    out.rdata <- buf_push(out.rdata, 108)
    out.rdata <- buf_push(out.rdata, 108)
    out.rdata <- buf_push(out.rdata, 100)
    out.rdata <- buf_push(out.rdata, 10)
    out.rdata <- buf_push(out.rdata, 0)

    out.rdata <- buf_push(out.rdata, 37)
    out.rdata <- buf_push(out.rdata, 108)
    out.rdata <- buf_push(out.rdata, 108)
    out.rdata <- buf_push(out.rdata, 100)
    out.rdata <- buf_push(out.rdata, 0)

    out.rdata <- buf_push(out.rdata, 119)
    out.rdata <- buf_push(out.rdata, 98)
    out.rdata <- buf_push(out.rdata, 0)

    out.rdata <- buf_push(out.rdata, 114)
    out.rdata <- buf_push(out.rdata, 98)
    out.rdata <- buf_push(out.rdata, 0)
    yield out
}

flow emit_runtime_builtins(comp :: Compiler, rdata_rva :: i64, layout :: RuntimeRdataLayout) -> Compiler {
    vary out :: Compiler = comp

    bind print_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_print(out.code, rdata_rva, layout.fmt_s_off)
    out <- append_builtin_registration(out, "print", 1, print_off)

    bind println_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_println(out.code, rdata_rva, layout.fmt_sn_off)
    out <- append_builtin_registration(out, "println", 1, println_off)

    bind str_len_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_len(out.code)
    out <- append_builtin_registration(out, "str_len", 1, str_len_off)

    bind str_byte_at_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_byte_at(out.code)
    out <- append_builtin_registration(out, "str_byte_at", 2, str_byte_at_off)

    bind str_eq_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_eq(out.code)
    out <- append_builtin_registration(out, "str_eq", 2, str_eq_off)

    bind str_concat_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_concat(out.code)
    out <- append_builtin_registration(out, "str_concat", 2, str_concat_off)

    bind str_slice_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_slice(out.code)
    out <- append_builtin_registration(out, "str_slice", 3, str_slice_off)

    bind str_from_i64_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_from_i64(out.code, rdata_rva, layout.fmt_lld_no_nl_off)
    out <- append_builtin_registration(out, "str_from_i64", 1, str_from_i64_off)

    bind str_from_byte_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_str_from_byte(out.code)
    out <- append_builtin_registration(out, "str_from_byte", 1, str_from_byte_off)

    bind buf_new_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_new(out.code)
    out <- append_builtin_registration(out, "buf_new", 0, buf_new_off)

    bind buf_push_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_push(out.code)
    out <- append_builtin_registration(out, "buf_push", 2, buf_push_off)

    bind buf_len_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_len(out.code)
    out <- append_builtin_registration(out, "buf_len", 1, buf_len_off)

    bind buf_get_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_get(out.code)
    out <- append_builtin_registration(out, "buf_get", 2, buf_get_off)

    bind buf_set_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_set(out.code)
    out <- append_builtin_registration(out, "buf_set", 3, buf_set_off)

    bind buf_append_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_buf_append(out.code)
    out <- append_builtin_registration(out, "buf_append", 2, buf_append_off)

    bind file_create_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_create(out.code, rdata_rva, layout.wb_off)
    out <- append_builtin_registration(out, "file_create", 1, file_create_off)

    bind file_write_buf_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_write_buf(out.code)
    out <- append_builtin_registration(out, "file_write_buf", 2, file_write_buf_off)

    bind file_write_byte_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_write_byte(out.code)
    out <- append_builtin_registration(out, "file_write_byte", 2, file_write_byte_off)

    bind file_close_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_close(out.code)
    out <- append_builtin_registration(out, "file_close", 1, file_close_off)

    bind file_read_all_buf_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_read_all_buf(out.code, rdata_rva, layout.rb_off)
    out <- append_builtin_registration(out, "file_read_all_buf", 1, file_read_all_buf_off)

    bind file_read_all_text_off :: i64 = buf_len(out.code)
    out.code <- emit_builtin_file_read_all_text(out.code, rdata_rva, layout.rb_off)
    out <- append_builtin_registration(out, "file_read_all_text", 1, file_read_all_text_off)

    yield out
}

flow bootstrap_runtime(source :: str, rdata_rva :: i64, layout :: RuntimeRdataLayout) -> RuntimeBootstrap {
    vary comp :: Compiler = collect_functions(source)
    bind trace1 :: i64 = trace("D collect")
    bind trace2 :: i64 = trace(str_concat("Fns ", str_from_i64(function_name_count(comp))))
    bind trace3 :: i64 = trace(str_concat("Structs: ", str_from_i64(struct_name_count(comp))))

    comp <- build_runtime_rdata(comp)
    comp <- emit_runtime_builtins(comp, rdata_rva, layout)

    bind trace4 :: i64 = trace("D builtins")
    bind trace5 :: i64 = trace(str_concat("Builtins ", str_from_i64(buf_len(comp.code))))

    comp <- compile_user_functions_serial(comp)
    check comp.failed == 1 {
        yield RuntimeBootstrap{ valid = 0, comp = comp, main_idx = 0, main_code_offset = 0, exit_code = 1, message = comp.failure_message }
    }
    bind main_idx_res :: LookupI64 = find_func_opt(comp, "main")
    check main_idx_res.found == 0 {
        yield RuntimeBootstrap{ valid = 0, comp = comp, main_idx = 0, main_code_offset = 0, exit_code = 1, message = "no main" }
    }
    bind main_idx :: i64 = main_idx_res.value

    yield RuntimeBootstrap{ valid = 1, comp = comp, main_idx = main_idx, main_code_offset = comp.final_main_code_offset, exit_code = 0, message = "" }
}

flow emit_entry_stub_main0(comp :: Compiler, main_code_offset :: i64) -> Compiler {
    vary b :: i64 = comp.code
    // Simple entry: call main(), ExitProcess(rax)
    b <- x_sub_rsp_imm8(b, 40)
    bind call_main0 :: i64 = buf_len(b)
    b <- x_call_rel32(b, main_code_offset - (call_main0 + 5))
    b <- x_mov_reg_reg(b, 1, 0)
    bind patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 0, patch_off)
    comp.code <- b
    yield comp
}

flow emit_entry_stub_main1(comp :: Compiler, main_code_offset :: i64, rdata_rva :: i64, rb_off :: i64) -> Compiler {
    vary b :: i64 = comp.code
    // File-reading entry: GetCommandLineA -> parse argv[1] -> fopen -> fread -> main(source)
    b <- x_push_reg(b, 5)
    b <- x_mov_reg_reg(b, 5, 4)
    b <- x_sub_rsp_imm8(b, 80)

    // GetCommandLineA() -> rax = command line string
    bind get_cmd_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 4, get_cmd_patch_off)
    b <- x_mov_rbp_off8_reg(b, -8, 0)
    b <- x_mov_reg_reg(b, 1, 0)

    // Skip exe name: scan to first space
    bind skip_loop :: i64 = buf_len(b)
    b <- buf_push(b, 15)
    b <- buf_push(b, 182)
    b <- buf_push(b, 1)
    b <- buf_push(b, 132)
    b <- buf_push(b, 192)
    bind je_na1 :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- buf_push(b, 60)
    b <- buf_push(b, 32)
    bind je_fs :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- buf_push(b, 72)
    b <- buf_push(b, 255)
    b <- buf_push(b, 193)
    b <- x_jmp_rel32(b, skip_loop - (buf_len(b) + 5))

    // found_space: skip whitespace
    bind found_space :: i64 = buf_len(b)
    b <- patch_u32(b, je_fs + 2, found_space - (je_fs + 6))
    b <- buf_push(b, 72)
    b <- buf_push(b, 255)
    b <- buf_push(b, 193)
    b <- buf_push(b, 15)
    b <- buf_push(b, 182)
    b <- buf_push(b, 1)
    b <- buf_push(b, 60)
    b <- buf_push(b, 32)
    b <- x_je_rel32(b, found_space - (buf_len(b) + 6))
    b <- buf_push(b, 132)
    b <- buf_push(b, 192)
    bind je_na2 :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)

    // rcx = filename, save it
    b <- x_mov_rbp_off8_reg(b, -16, 1)

    // fopen(filename, "rb")
    bind lea_rb :: i64 = buf_len(b)
    bind rip_rb :: i64 = pe_text_rva() + lea_rb + 7
    b <- buf_push(b, 72)
    b <- buf_push(b, 141)
    b <- buf_push(b, 21)
    b <- emit_u32(b, rdata_rva + rb_off - rip_rb)
    bind fopen_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 10, fopen_patch_off)
    b <- x_test_rax_rax(b)
    bind je_open_fail :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -24, 0)

    // malloc(1048576) = 1MB buffer
    b <- buf_push(b, 185)
    b <- emit_u32(b, 1048576)
    bind malloc_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 13, malloc_patch_off)
    b <- x_test_rax_rax(b)
    bind je_alloc_fail :: i64 = buf_len(b)
    b <- x_je_rel32(b, 0)
    b <- x_mov_rbp_off8_reg(b, -32, 0)

    // fread(buffer, 1, 1048576, fd)
    b <- x_mov_reg_reg(b, 1, 0)
    b <- buf_push(b, 186)
    b <- emit_u32(b, 1)
    b <- buf_push(b, 65)
    b <- buf_push(b, 184)
    b <- emit_u32(b, 1048576)
    b <- buf_push(b, 76)
    b <- buf_push(b, 139)
    b <- buf_push(b, 77)
    b <- buf_push(b, 232)
    bind fread_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 15, fread_patch_off)
    b <- x_mov_rbp_off8_reg(b, -40, 0)

    // null-terminate: buffer[bytes_read] = 0
    b <- x_mov_reg_rbp_off8(b, 1, -32)
    b <- x_add_reg_reg(b, 1, 0)
    b <- buf_push(b, 198)
    b <- buf_push(b, 1)
    b <- buf_push(b, 0)

    // fclose(fd)
    b <- x_mov_reg_rbp_off8(b, 1, -24)
    bind fclose_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 12, fclose_patch_off)

    // call main(source)
    b <- x_mov_reg_rbp_off8(b, 1, -32)
    bind call_main1 :: i64 = buf_len(b)
    b <- x_call_rel32(b, main_code_offset - (call_main1 + 5))

    // ExitProcess(result)
    b <- x_mov_reg_reg(b, 1, 0)
    bind exit_patch_off :: i64 = buf_len(b) + 2
    b <- x_call_iat(b, 0, 0)
    comp <- append_local_import_patch(comp, 0, exit_patch_off)

    // no_args: exit with standard compile/input error code
    bind no_args :: i64 = buf_len(b)
    b <- patch_u32(b, je_na1 + 2, no_args - (je_na1 + 6))
    b <- patch_u32(b, je_na2 + 2, no_args - (je_na2 + 6))
    comp.code <- b
    comp <- emit_exit_process_imm32(comp, 1)
    b <- comp.code

    bind open_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_open_fail + 2, open_fail - (je_open_fail + 6))
    comp.code <- b
    comp <- emit_exit_process_imm32(comp, 2)
    b <- comp.code

    bind alloc_fail :: i64 = buf_len(b)
    b <- patch_u32(b, je_alloc_fail + 2, alloc_fail - (je_alloc_fail + 6))
    comp.code <- b
    comp <- emit_exit_process_imm32(comp, 3)
    b <- comp.code
    comp.code <- b
    yield comp
}

flow compile_source_to_path(source :: str, output_path :: str) -> i64 {
    bind trace0 :: i64 = trace("D main")
    bind runtime_layout :: RuntimeRdataLayout = RuntimeRdataLayout{ fmt_s_off = 0, fmt_sn_off = 3, fmt_lld_off = 7, fmt_lld_no_nl_off = 13, wb_off = 18, rb_off = 21 }
    bind rdata_rva :: i64 = pe_rdata_rva()
    bind bootstrap :: RuntimeBootstrap = bootstrap_runtime(source, rdata_rva, runtime_layout)
    check bootstrap.valid == 0 {
        yield fatal(bootstrap.message, bootstrap.exit_code)
    }
    bind comp0 :: Compiler = bootstrap.comp
    bind main_idx :: i64 = bootstrap.main_idx
    bind main_code_offset :: i64 = bootstrap.main_code_offset
    bind entry_offset :: i64 = buf_len(comp0.code)
    check main_code_offset < 0 or main_code_offset >= entry_offset {
        yield fatal("main off bad", 1)
    }
    bind main_params_res :: LookupI64 = load_function_param_count_opt(comp0, main_idx)
    check main_params_res.found == 0 {
        yield fatal("main params bad", 1)
    }
    bind main_params :: i64 = main_params_res.value
    check main_params != 0 {
        check main_params != 1 {
            yield fatal("main arity bad", 4)
        }
    }
    vary comp1 :: Compiler = comp0
    comp1.import_patch_offsets <- ""
    comp1.import_patch_targets <- ""
    check main_params == 1 {
        comp1 <- emit_entry_stub_main1(comp1, main_code_offset, rdata_rva, runtime_layout.rb_off)
    }
    check main_params == 0 {
        comp1 <- emit_entry_stub_main0(comp1, main_code_offset)
    }
    vary code_buf :: i64 = comp1.code
    bind trace14 :: i64 = trace("D entry")
    bind trace15 :: i64 = trace(str_concat("Code ", str_from_i64(buf_len(code_buf))))
    bind patch_offset_count_res :: LookupI64 = u32_store_pair_count_opt(comp0.patch_offsets_store, comp0.patch_targets_store)
    check patch_offset_count_res.found == 0 {
        yield fatal("main off bad", 1)
    }
    bind patch_count :: i64 = patch_offset_count_res.value
    bind trace16 :: i64 = trace(str_concat("Patch ", str_from_i64(patch_count)))
    bind entry_import_patch_offsets_store :: i64 = append_csv_i64_to_u32_store(buf_new(), comp1.import_patch_offsets)
    bind entry_import_patch_targets_store :: i64 = append_csv_i64_to_u32_store(buf_new(), comp1.import_patch_targets)
    bind entry_import_patch_count_res :: LookupI64 = u32_store_pair_count_opt(entry_import_patch_offsets_store, entry_import_patch_targets_store)
    bind rip_patch_offset_count_res :: LookupI64 = u32_store_pair_count_opt(comp0.rip_patch_offsets_store, comp0.rip_patch_targets_store)
    check entry_import_patch_count_res.found == 0 {
        yield fatal("main off bad", 1)
    }
    check rip_patch_offset_count_res.found == 0 {
        yield fatal("main off bad", 1)
    }
    bind entry_import_patch_count :: i64 = entry_import_patch_count_res.value
    bind rip_patch_count :: i64 = rip_patch_offset_count_res.value + entry_import_patch_count
    bind trace16b :: i64 = trace(str_concat("RIP ", str_from_i64(rip_patch_count)))
    bind trace17 :: i64 = trace("D patch+")
    bind patch_offsets_buf :: i64 = comp0.patch_offsets_store
    bind patch_targets_buf :: i64 = comp0.patch_targets_store
    vary rip_patch_offsets_buf :: i64 = comp0.rip_patch_offsets_store
    vary rip_patch_targets_buf :: i64 = comp0.rip_patch_targets_store
    vary patch_log_step :: i64 = 250
    check patch_count > 1000 {
        patch_log_step <- 1000
    }
    vary pi :: i64 = 0
    vary next_patch_log :: i64 = 0
    spin pi < patch_count {
        check pi == next_patch_log or pi + 1 == patch_count {
            bind trace18 :: i64 = trace(str_concat("P ", str_concat(str_from_i64(pi + 1), str_concat("/", str_from_i64(patch_count)))))
            next_patch_log <- next_patch_log + patch_log_step
        }
        bind patch_off_res :: LookupI64 = load_u32_store_opt(patch_offsets_buf, pi)
        bind target_code_off_res :: LookupI64 = load_u32_store_opt(patch_targets_buf, pi)
        check patch_off_res.found == 0 or target_code_off_res.found == 0 {
            yield fatal("main off bad", 1)
        }
        bind patch_off :: i64 = patch_off_res.value
        bind target_code_off :: i64 = target_code_off_res.value
        bind rel :: i64 = target_code_off - (patch_off + 4)
        code_buf <- patch_u32(code_buf, patch_off, rel)
        pi <- pi + 1
    }
    bind trace19 :: i64 = trace("D patch")
    vary epi :: i64 = 0
    spin epi < entry_import_patch_count {
        bind patch_off_res :: LookupI64 = load_u32_store_opt(entry_import_patch_offsets_store, epi)
        bind import_slot_res :: LookupI64 = load_u32_store_opt(entry_import_patch_targets_store, epi)
        check patch_off_res.found == 0 or import_slot_res.found == 0 {
            yield fatal("main off bad", 1)
        }
        bind patch_off :: i64 = patch_off_res.value
        bind import_slot :: i64 = import_slot_res.value
        check patch_off < 0 or patch_off + 3 >= buf_len(code_buf) {
            yield fatal("main off bad", 1)
        }
        check import_slot < 0 or import_slot >= import_slot_count() {
            yield fatal("main params bad", 1)
        }
        rip_patch_offsets_buf <- emit_u32(rip_patch_offsets_buf, patch_off)
        rip_patch_targets_buf <- emit_u32(rip_patch_targets_buf, iat_rva(import_slot))
        epi <- epi + 1
    }
    bind trace19b :: i64 = trace("D rip+")
    vary rip_log_step :: i64 = 250
    check rip_patch_count > 200 {
        rip_log_step <- 500
    }
    vary rpi :: i64 = 0
    vary next_rip_log :: i64 = 0
    spin rpi < rip_patch_count {
        check rpi == next_rip_log or rpi + 1 == rip_patch_count {
            bind trace19c :: i64 = trace(str_concat("RP ", str_concat(str_from_i64(rpi + 1), str_concat("/", str_from_i64(rip_patch_count)))))
            next_rip_log <- next_rip_log + rip_log_step
        }
        bind patch_off_res :: LookupI64 = load_u32_store_opt(rip_patch_offsets_buf, rpi)
        bind target_rva_res :: LookupI64 = load_u32_store_opt(rip_patch_targets_buf, rpi)
        check patch_off_res.found == 0 or target_rva_res.found == 0 {
            yield fatal("main off bad", 1)
        }
        bind patch_off :: i64 = patch_off_res.value
        bind target_rva :: i64 = target_rva_res.value
        bind rel :: i64 = target_rva - (pe_text_rva() + patch_off + 4)
        code_buf <- patch_u32(code_buf, patch_off, rel)
        rpi <- rpi + 1
    }
    bind trace19d :: i64 = trace("D rip")
    bind trace20 :: i64 = trace("D pe+")
    bind pe :: i64 = build_pe(code_buf, comp0.rdata, entry_offset)
    bind trace21 :: i64 = trace("D pe")
    bind trace22 :: i64 = trace(str_concat("PE ", str_from_i64(buf_len(pe))))
    bind trace23 :: i64 = trace("D wr+")
    bind fd :: i64 = file_create(output_path)
    bind write0 :: i64 = file_write_buf(fd, pe)
    bind close0 :: i64 = file_close(fd)
    bind trace24 :: i64 = trace("D wr")
    bind trace25 :: i64 = trace(str_concat("W ", output_path))
    yield 0
}

flow tooling_verify_exit_code(suite_name :: str, case_name :: str, actual :: i64, expected :: i64) -> i64 {
    check actual == expected {
        bind trace_ok :: i64 = trace(str_concat(str_concat(suite_name, " P "), case_name))
        yield 1
    }
    bind trace_fail :: i64 = trace(
        str_concat(
            str_concat(suite_name, " F "),
            str_concat(
                case_name,
                str_concat(
                    ": ",
                    str_concat(
                        str_from_i64(expected),
                        str_concat("/", str_from_i64(actual))
                    )
                )
            )
        )
    )
    yield 0
}

flow buf_first_mismatch_pos_opt(actual_buf :: i64, expected_buf :: i64, len :: i64) -> LookupI64 {
    vary pos :: i64 = 0
    spin pos < len {
        check buf_get(actual_buf, pos) != buf_get(expected_buf, pos) {
            yield LookupI64{ found = 1, value = pos }
        }
        pos <- pos + 1
    }
    yield missing_i64()
}

flow tooling_verify_output_match(suite_name :: str, case_name :: str, actual_path :: str, expected_path :: str) -> i64 {
    bind actual_buf :: i64 = file_read_all_buf(actual_path)
    check actual_buf == 0 {
        bind trace_actual_read_fail :: i64 = trace(
            str_concat(
                str_concat(suite_name, " F "),
                str_concat(case_name, str_concat(": rf ", actual_path))
            )
        )
        yield 0
    }
    bind expected_buf :: i64 = file_read_all_buf(expected_path)
    check expected_buf == 0 {
        bind trace_expected_read_fail :: i64 = trace(
            str_concat(
                str_concat(suite_name, " F "),
                str_concat(case_name, str_concat(": rf ", expected_path))
            )
        )
        yield 0
    }
    bind actual_len :: i64 = buf_len(actual_buf)
    bind expected_len :: i64 = buf_len(expected_buf)
    check actual_len != expected_len {
        bind trace_len_fail :: i64 = trace(
            str_concat(
                str_concat(suite_name, " F "),
                str_concat(
                    case_name,
                    str_concat(
                        ": cmp len ",
                        str_concat(str_from_i64(expected_len), str_concat("/", str_from_i64(actual_len)))
                    )
                )
            )
        )
        yield 0
    }
    bind mismatch_res :: LookupI64 = buf_first_mismatch_pos_opt(actual_buf, expected_buf, actual_len)
    check mismatch_res.found == 1 {
        bind trace_cmp_fail :: i64 = trace(
            str_concat(
                str_concat(suite_name, " F "),
                str_concat(case_name, str_concat(": cmp byte ", str_from_i64(mismatch_res.value)))
            )
        )
        yield 0
    }
    yield 1
}

flow find_byte_opt(source :: str, start :: i64, target :: i64) -> LookupI64 {
    vary i :: i64 = start
    bind len :: i64 = str_len(source)
    spin i < len {
        check str_byte_at(source, i) == target {
            yield LookupI64{ found = 1, value = i }
        }
        i <- i + 1
    }
    yield missing_i64()
}

flow find_line_end(source :: str, start :: i64) -> i64 {
    bind nl_res :: LookupI64 = find_byte_opt(source, start, 10)
    check nl_res.found == 1 {
        yield nl_res.value
    }
    yield str_len(source)
}

flow next_line_start(source :: str, start :: i64) -> i64 {
    bind end :: i64 = find_line_end(source, start)
    bind len :: i64 = str_len(source)
    check end < len {
        yield end + 1
    }
    yield end
}

flow first_line(source :: str) -> str {
    bind end :: i64 = find_line_end(source, 0)
    yield trim_trailing_line_endings(str_slice(source, 0, end))
}

flow starts_with(source :: str, prefix :: str) -> i64 {
    bind prefix_len :: i64 = str_len(prefix)
    check str_len(source) < prefix_len {
        yield 0
    }
    check str_eq(str_slice(source, 0, prefix_len), prefix) {
        yield 1
    }
    yield 0
}

flow tooling_run_configured_suite(source :: str) -> i64 {
    vary suite_name :: str = ""
    vary output_prefix :: str = ""
    vary explicit_exit :: i64 = 0
    vary default_exit :: i64 = 0
    vary compare_output :: i64 = 0
    vary configured :: i64 = 0
    vary all_ok :: i64 = 1
    vary case_count :: i64 = 0
    vary pos :: i64 = next_line_start(source, 0)
    bind source_len :: i64 = str_len(source)
    spin pos < source_len {
        bind line_end :: i64 = find_line_end(source, pos)
        bind line :: str = trim_trailing_line_endings(str_slice(source, pos, line_end))
        bind next_pos :: i64 = next_line_start(source, pos)
        check str_len(line) > 0 {
            bind first_ch :: i64 = str_byte_at(line, 0)
            check first_ch != 35 {
                bind sep1_res :: LookupI64 = find_byte_opt(line, 0, 124)
                check configured == 0 {
                    check sep1_res.found == 0 {
                        bind trace_bad_config :: i64 = trace(str_concat("SF bad cfg ", line))
                        yield 1
                    }
                    bind sep1 :: i64 = sep1_res.value
                    bind tag :: str = str_slice(line, 0, sep1)
                    check str_eq(tag, "meta") {
                        bind sep2_res :: LookupI64 = find_byte_opt(line, sep1 + 1, 124)
                        check sep2_res.found == 0 {
                            bind trace_bad_config2 :: i64 = trace(str_concat("SF bad cfg ", line))
                            yield 1
                        }
                        bind sep2 :: i64 = sep2_res.value
                        bind key :: str = str_slice(line, sep1 + 1, sep2)
                        bind value :: str = str_slice(line, sep2 + 1, str_len(line))
                        check str_eq(key, "suite") {
                            suite_name <- value
                        } otherwise {
                            check str_eq(key, "prefix") {
                                output_prefix <- value
                            } otherwise {
                                check str_eq(key, "explicit_exit") {
                                    bind explicit_res :: LookupI64 = parse_int_result(value, 0, str_len(value))
                                    check explicit_res.found == 0 {
                                        bind trace_bad_config3 :: i64 = trace("SF bad ex")
                                        yield 1
                                    }
                                    explicit_exit <- explicit_res.value
                                } otherwise {
                                    check str_eq(key, "default_exit") {
                                        bind default_res :: LookupI64 = parse_int_result(value, 0, str_len(value))
                                        check default_res.found == 0 {
                                            bind trace_bad_config4 :: i64 = trace("SF bad def")
                                            yield 1
                                        }
                                        default_exit <- default_res.value
                                    } otherwise {
                                        check str_eq(key, "compare_output") {
                                            bind compare_res :: LookupI64 = parse_int_result(value, 0, str_len(value))
                                            check compare_res.found == 0 {
                                                bind trace_bad_config5 :: i64 = trace("SF bad cmp")
                                                yield 1
                                            }
                                            compare_output <- compare_res.value
                                        } otherwise {
                                            bind trace_bad_config6 :: i64 = trace(str_concat("SF bad meta ", key))
                                            yield 1
                                        }
                                    }
                                }
                            }
                        }
                    } otherwise {
                        check str_len(suite_name) == 0 {
                            bind trace_no_suite :: i64 = trace("SF no suite")
                            yield 1
                        }
                        check str_len(output_prefix) == 0 {
                            bind trace_no_prefix :: i64 = trace("SF no prefix")
                            yield 1
                        }
                        check compare_output < 0 or compare_output > 1 {
                            bind trace_bad_cmp_mode :: i64 = trace("SF bad cmp mode")
                            yield 1
                        }
                        configured <- 1
                    }
                }
                check configured == 1 {
                    bind case_sep1_res :: LookupI64 = find_byte_opt(line, 0, 124)
                    check case_sep1_res.found == 0 {
                        bind trace_bad_line :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("bad line ", line)))
                        all_ok <- 0
                    } otherwise {
                        bind case_sep1 :: i64 = case_sep1_res.value
                        bind case_name :: str = str_slice(line, 0, case_sep1)
                        vary expected_exit :: i64 = default_exit
                        vary case_path :: str = ""
                        vary expected_output_path :: str = ""
                        vary case_valid :: i64 = 1
                        check explicit_exit == 1 {
                            bind case_sep2_res :: LookupI64 = find_byte_opt(line, case_sep1 + 1, 124)
                            check case_sep2_res.found == 0 {
                                bind trace_bad_line2 :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("bad line ", line)))
                                all_ok <- 0
                                case_valid <- 0
                            }
                            check case_valid == 1 {
                                bind case_sep2 :: i64 = case_sep2_res.value
                                bind expected_res :: LookupI64 = parse_int_result(line, case_sep1 + 1, case_sep2)
                                check expected_res.found == 0 {
                                    bind trace_bad_exit :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("bad exit ", case_name)))
                                    all_ok <- 0
                                    case_valid <- 0
                                }
                                check case_valid == 1 {
                                    expected_exit <- expected_res.value
                                    check compare_output == 1 {
                                        bind case_sep3_res :: LookupI64 = find_byte_opt(line, case_sep2 + 1, 124)
                                        check case_sep3_res.found == 0 {
                                            bind trace_bad_line3 :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("bad line ", line)))
                                            all_ok <- 0
                                            case_valid <- 0
                                        }
                                        check case_valid == 1 {
                                            bind case_sep3 :: i64 = case_sep3_res.value
                                            case_path <- str_slice(line, case_sep2 + 1, case_sep3)
                                            expected_output_path <- str_slice(line, case_sep3 + 1, str_len(line))
                                        }
                                    } otherwise {
                                        case_path <- str_slice(line, case_sep2 + 1, str_len(line))
                                    }
                                }
                            }
                        } otherwise {
                            check compare_output == 1 {
                                bind case_sep2_res :: LookupI64 = find_byte_opt(line, case_sep1 + 1, 124)
                                check case_sep2_res.found == 0 {
                                    bind trace_bad_line4 :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("bad line ", line)))
                                    all_ok <- 0
                                    case_valid <- 0
                                }
                                check case_valid == 1 {
                                    bind case_sep2 :: i64 = case_sep2_res.value
                                    case_path <- str_slice(line, case_sep1 + 1, case_sep2)
                                    expected_output_path <- str_slice(line, case_sep2 + 1, str_len(line))
                                }
                            } otherwise {
                                case_path <- str_slice(line, case_sep1 + 1, str_len(line))
                            }
                        }
                        check case_valid == 1 {
                            bind case_source :: str = file_read_all_text(case_path)
                            check str_len(case_source) == 0 {
                                bind trace_read_fail :: i64 = trace(str_concat(str_concat(suite_name, " F "), str_concat("rf ", case_path)))
                                all_ok <- 0
                            } otherwise {
                                bind output_path :: str = str_concat(str_concat(output_prefix, case_name), ".exe")
                                bind case_ok :: i64 = tooling_verify_exit_code(
                                    suite_name,
                                    case_name,
                                    tooling_dispatch_or_compile_to_path(case_source, output_path),
                                    expected_exit)
                                check case_ok == 0 {
                                    all_ok <- 0
                                } otherwise {
                                    check compare_output == 1 {
                                        bind match_ok :: i64 = tooling_verify_output_match(suite_name, case_name, output_path, expected_output_path)
                                        check match_ok == 0 {
                                            all_ok <- 0
                                        }
                                    }
                                }
                            }
                            case_count <- case_count + 1
                        }
                    }
                }
            }
        }
        pos <- next_pos
    }
    check str_len(suite_name) == 0 {
        bind trace_no_suite2 :: i64 = trace("SF no suite")
        yield 1
    }
    check str_len(output_prefix) == 0 {
        bind trace_no_prefix2 :: i64 = trace("SF no prefix")
        yield 1
    }
    check case_count == 0 {
        bind trace_empty_manifest :: i64 = trace(str_concat(suite_name, " F no cases"))
        yield 1
    }
    check all_ok == 1 {
        bind trace_suite_ok :: i64 = trace(str_concat(suite_name, " P"))
        yield 0
    }
    bind trace_suite_fail :: i64 = trace(str_concat(suite_name, " F"))
    yield 1
}

flow trim_trailing_line_endings(source :: str) -> str {
    bind len :: i64 = str_len(source)
    check len <= 0 {
        yield source
    }

    bind last :: i64 = str_byte_at(source, len - 1)
    check last == 10 or last == 13 {
        yield trim_trailing_line_endings(str_slice(source, 0, len - 1))
    }
    yield source
}

flow tooling_dispatch_or_compile_to_path(source :: str, output_path :: str) -> i64 {
    bind command_line :: str = first_line(source)
    check str_eq(command_line, "#!ng-tool suite") {
        yield tooling_run_configured_suite(source)
    }
    check starts_with(command_line, "#!ng-tool ") == 1 {
        yield fatal(str_concat("bad ng-tool ", command_line), 1)
    }
    yield compile_source_to_path(source, output_path)
}

// ==================================================================
// SECTION 9: MAIN - PUT IT ALL TOGETHER
// ==================================================================

flow main(source :: str) -> i64 {
    yield tooling_dispatch_or_compile_to_path(source, "output.exe")
}
